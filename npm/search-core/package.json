{
  "name": "@trouve-ai/search-core",
  "version": "3.3.2",
  "description": "trouve-search native binary and MCP launcher for Node. Platform-specific binaries install via optional dependencies.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/platform.d.ts",
      "default": "./src/platform.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "trouve-search": "./bin/trouve-search.js"
  },
  "files": [
    "bin",
    "src"
  ],
  "keywords": [
    "code-search",
    "semantic-search",
    "mcp",
    "trouve"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimsimon/trouve.git",
    "directory": "npm/search-core"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "optionalDependencies": {
    "@trouve-ai/search-darwin-arm64": "3.3.2",
    "@trouve-ai/search-darwin-x64": "3.3.2",
    "@trouve-ai/search-linux-arm64-gnu": "3.3.2",
    "@trouve-ai/search-linux-arm64-musl": "3.3.2",
    "@trouve-ai/search-linux-x64-gnu": "3.3.2",
    "@trouve-ai/search-linux-x64-musl": "3.3.2",
    "@trouve-ai/search-win32-arm64": "3.3.2",
    "@trouve-ai/search-win32-x64": "3.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^7.0.0"
  }
}
