{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  labels: ['dependencies'],
  // Keep Cargo.lock fresh even when Cargo.toml ranges still match
  lockFileMaintenance: {
    enabled: true,
    schedule: ['before 6am on monday'],
  },
  packageRules: [
    {
      // The tree-sitter core and grammar crates move together; group them
      // into a single PR to avoid a flood of individual grammar bumps.
      groupName: 'tree-sitter',
      matchManagers: ['cargo'],
      matchPackageNames: ['tree-sitter', 'tree-sitter-*'],
    },
    {
      groupName: 'GitHub Actions',
      matchManagers: ['github-actions'],
    },
    {
      // Batch all semver patch and minor updates into a single PR. Same as
      // the group:allNonMajor preset, but declared last so it wins over the
      // groups above; those still apply to major and digest updates.
      groupName: 'all non-major dependencies',
      groupSlug: 'all-minor-patch',
      matchUpdateTypes: ['minor', 'patch'],
    },
  ],
}
