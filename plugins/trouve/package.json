{
  "name": "trouve-plugin",
  "version": "1.0.1",
  "description": "trouve code search as native agent tools: OpenCode and Kilo Code plugin backed by a persistent trouve server process. The same directory also packages the Claude Code and Codex plugins.",
  "type": "module",
  "main": "./src/plugin.ts",
  "exports": {
    ".": "./src/plugin.ts",
    "./server": "./src/plugin.ts"
  },
  "files": [
    "src"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "kilocode",
    "kilo",
    "code-search",
    "semantic-search",
    "trouve"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimsimon/trouve.git",
    "directory": "plugins/trouve"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.13"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.6.0"
  }
}
