// Window wrapper for direct instantiation from Rust (and the demo).

import { DiffView, DiffRow } from "diff-view.slint";

export { DiffRow }

export component DiffViewWindow inherits Window {
    preferred-width: 980px;
    preferred-height: 700px;
    title: "slint-diff-view";

    in property <[DiffRow]> rows <=> view.rows;
    in property <length> code-font-size <=> view.code-font-size;
    callback file-toggled <=> view.file-toggled;

    view := DiffView {
        width: 100%;
        height: 100%;
    }
}
