// Settings screen: provider configuration (incl. vendor CLIs), default
// model, agent modes, and the About section (AboutSlint attribution lives
// here, reachable from the left-column footer — royalty-free license
// requirement). Rendered full-window over the main layout; a side nav
// switches between sections and the header's Close button returns to the
// previous screen.
//
// Like the main window, this is dumb: models in, callbacks out.

import {
    AboutSlint, Button, CheckBox, ComboBox, LineEdit, ListView, ScrollView, TextEdit
} from "std-widgets.slint";
import { ScrollKeys } from "scroll-keys.slint";
import { Theme } from "theme.slint";

export struct ProviderItem {
    id: string,
    kind: string,
    base-url: string,
    has-credentials: bool,
    auth: string,
    experimental: bool,
}

// A vendor CLI (cursor-agent, claude, codex) trouve can download and manage.
export struct CliItem {
    id: string,
    display-name: string,
    // "not installed" / "1.2.3 (system)" / "1.2.3 (managed)" ...
    version-label: string,
    // "Install" / "Update" / "" (hidden when up to date and managed)
    action-label: string,
    // In-flight install feedback ("downloading…", "failed: …").
    status: string,
    busy: bool,
}

// Subscription usage for one agent-backend provider (flat: up to two
// metered windows, which is all any vendor reports today).
export struct SubscriptionItem {
    provider: string,
    // "ok" / "unavailable" / "unsupported"
    status: string,
    plan: string,
    credits: string,
    // Explanation for unavailable/unsupported entries.
    note: string,
    has-w1: bool,
    w1-label: string,
    w1-pct: int,
    w1-resets: string,
    has-w2: bool,
    w2-label: string,
    w2-pct: int,
    w2-resets: string,
}

// One agent mode for the Modes & Models section. allowed-tools is
// comma-joined for display and the edit form; model-index is the mode's
// default model as an index into the models list (-1 = global default).
export struct ModeItem {
    id: string,
    display-name: string,
    // "builtin" (pristine), "customized" (built-in with a user override),
    // "custom" (user-added), "workspace" (.agents/modes — file-managed).
    origin: string,
    read-only: bool,
    system-prompt: string,
    allowed-tools: string,
    // 0 ask, 1 allow-list, 2 yolo.
    permission-index: int,
    model-index: int,
}

// A user-managed MCP server (first-party servers trouve injects itself are
// never listed). command-line and env-lines are pre-rendered for display
// and round-trip through the edit form.
export struct McpServerItem {
    name: string,
    // "user" (config dir) or "workspace" (.agents/.mcp.json).
    scope: string,
    // Command plus args, shell-quoted.
    command-line: string,
    // One KEY=VALUE per line ("" when none).
    env-lines: string,
    // "ok" / "error" / "checking"
    health: string,
    // "5 tools" or the failure reason.
    detail: string,
}

// A well-known provider preset served by the backend; picking one prefills
// the add/edit form so nothing has to be typed by hand.
export struct KnownProviderItem {
    id: string,
    display-name: string,
    kind: string,
    base-url: string,
    api-key-env: string,
    // "api-key", "oauth" (subscription login), "cli" (vendor CLI holds the
    // subscription auth), or "none" (keyless local).
    auth: string,
    // Undocumented vendor endpoint; may break or be restricted at any time.
    experimental: bool,
}

// One metered subscription window: label, usage bar, reset note. The bar
// shifts to warn/err colors as the window fills up.
component SubscriptionMeter inherits VerticalLayout {
    in property <string> label;
    in property <int> pct;
    in property <string> resets;
    spacing: 3px;
    HorizontalLayout {
        Text {
            text: root.label;
            color: Theme.c.text-mid;
            font-size: Theme.fs(11px);
            horizontal-stretch: 1;
        }
        Text {
            text: root.pct + "% used" + (root.resets != "" ? " · " + root.resets : "");
            color: root.pct >= 90 ? Theme.c.err : Theme.c.text-mid;
            font-size: Theme.fs(11px);
        }
    }
    Rectangle {
        height: 6px;
        border-radius: 3px;
        background: Theme.c.control-bg;
        Rectangle {
            x: 0;
            width: max(parent.width * root.pct / 100, root.pct > 0 ? 6px : 0px);
            height: parent.height;
            border-radius: 3px;
            background: root.pct >= 90 ? Theme.c.err
                : root.pct >= 70 ? Theme.c.warn : Theme.c.ok;
        }
    }
}

export component SettingsScreen inherits Rectangle {
    background: Theme.c.win-bg;

    in property <[ProviderItem]> providers;
    in property <[CliItem]> clis;
    in property <[KnownProviderItem]> known-providers;
    // Preset display names (alphabetical; index i maps to
    // known-providers[i]) followed by "Custom" as the last entry.
    in property <[string]> known-provider-names;
    in property <[string]> models;
    in property <int> default-model-index: -1;
    // Modes & Models section: full mode cards plus the per-mode model
    // picker options ("Global default" followed by every model id).
    in property <[ModeItem]> mode-items;
    in property <[string]> mode-model-names;
    in property <string> settings-status: "";

    // Provider form state (prefilled by "Edit" or a preset).
    in-out property <string> form-id: "";
    in-out property <string> form-base-url: "";
    in-out property <int> form-kind-index: 0;
    // Wire kind actually saved; presets can carry kinds beyond the custom
    // combo's two entries (codex-app-server, cursor-cli, claude-cli, ...).
    in-out property <string> form-kind: "openai-compat";
    in-out property <string> form-hint: "";
    in-out property <bool> form-warning: false;
    // Index into known-provider-names: a preset (fields hidden, prefilled
    // from known-providers[index]) or the trailing "Custom" entry (id/kind/
    // url fields shown). The controller points it at Custom on load.
    in-out property <int> preset-index: 0;
    property <bool> preset-is-custom: root.preset-index >= root.known-providers.length;
    property <string> preset-auth:
        !root.preset-is-custom && root.preset-index >= 0
            ? root.known-providers[root.preset-index].auth
            : "api-key";

    // Appearance: built-in theme names, font sizes, and font families come
    // from Rust; the pickers report index selections back.
    in property <[string]> theme-names;
    in-out property <int> theme-index: 0;
    in property <[string]> font-size-names;
    in-out property <int> font-size-index: 0;
    in property <[string]> font-names;
    in-out property <int> font-index: 0;
    in-out property <bool> reduce-motion: false;

    callback provider-saved(/* id */ string, /* kind */ string,
                            /* base-url */ string, /* api-key */ string);
    callback provider-deleted(string);
    callback provider-login(string);
    callback default-model-picked(int);
    // Mode CRUD. mode-deleted covers both "Remove" (custom modes) and
    // "Reset to defaults" (customized built-ins) — both drop the user file.
    callback mode-saved(/* id */ string, /* display-name */ string,
                        /* system-prompt */ string, /* allowed-tools */ string,
                        /* read-only */ bool, /* permission-index */ int,
                        /* model-index */ int);
    callback mode-deleted(string);
    callback mode-model-picked(/* id */ string, /* model-index */ int);
    callback refresh-settings();
    callback cli-install(/* id */ string);
    callback theme-picked(int);
    callback font-size-picked(int);
    callback font-picked(int);
    callback reduce-motion-toggled(bool);
    callback close();

    // Integrations: GitHub token state comes from the server; saving an
    // empty token removes it.
    in property <bool> github-configured: false;
    // "environment" (GITHUB_TOKEN/GH_TOKEN) or "settings" (secret store).
    in property <string> github-source: "";
    callback github-token-saved(string);

    // Subscription health (Providers section).
    in property <[SubscriptionItem]> subscriptions;
    in property <string> subscriptions-status: "";

    // MCP servers (user config + current workspace).
    in property <[McpServerItem]> mcp-servers;
    in property <string> mcp-status: "";
    // Logs viewer: non-empty name shows the panel.
    in property <string> mcp-logs-name: "";
    in property <string> mcp-logs-text: "";
    // Add/edit form state. scope is fixed by the button that opened the
    // form; editing locks the name (it is the file key).
    in-out property <bool> mcp-form-open: false;
    in-out property <bool> mcp-form-editing: false;
    in-out property <string> mcp-form-scope: "user";
    in-out property <string> mcp-form-name: "";
    in-out property <string> mcp-form-command: "";
    in-out property <string> mcp-form-env: "";
    callback mcp-refresh();
    callback mcp-saved(/* name */ string, /* scope */ string,
                       /* command-line */ string, /* env-lines */ string);
    callback mcp-deleted(/* name */ string, /* scope */ string);
    callback mcp-logs-requested(string);
    callback mcp-logs-closed();

    // Mode add/edit form state. Editing locks the id (it is the file key);
    // saving under a built-in id customizes that built-in.
    in-out property <bool> mode-form-open: false;
    in-out property <bool> mode-form-editing: false;
    in-out property <string> mode-form-id: "";
    in-out property <string> mode-form-display: "";
    in-out property <string> mode-form-prompt: "";
    in-out property <string> mode-form-tools: "";
    in-out property <bool> mode-form-readonly: false;
    in-out property <int> mode-form-permission: 0;
    in-out property <int> mode-form-model: -1;

    // Side-nav selection: 0 providers, 1 modes & models, 2 mcp servers,
    // 3 integrations, 4 appearance, 5 about. in-out so the app can open
    // straight to a section (e.g. the PR tab's "set up GitHub" button).
    in-out property <int> section: 0;
    property <[string]> section-names: ["Providers", "Modes & Models", "MCP Servers", "Integrations", "Appearance", "About"];

    VerticalLayout {
        // Header: title + a way back to wherever the user came from.
        Rectangle {
            height: Theme.fs(44px);
            background: Theme.c.panel-bg;
            HorizontalLayout {
                padding-left: 16px;
                padding-right: 10px;
                spacing: 8px;
                Text {
                    text: "Settings";
                    color: Theme.c.text-hi;
                    font-size: Theme.fs(16px);
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                VerticalLayout {
                    alignment: center;
                    Button {
                        text: "✕ Close";
                        clicked => { root.close(); }
                    }
                }
            }
        }

        // Centered fixed-width block: section nav on the left, the active
        // section's content beside it.
        HorizontalLayout {
            vertical-stretch: 1;
            Rectangle { horizontal-stretch: 1; }

            // ---------------- section nav ----------------
            VerticalLayout {
                width: 170px;
                padding-top: 20px;
                padding-right: 12px;
                spacing: 2px;
                alignment: start;
                for name[i] in root.section-names: Rectangle {
                    height: Theme.fs(32px);
                    border-radius: 6px;
                    background: root.section == i ? Theme.c.accent-bg
                        : section-ta.has-hover ? Theme.c.raised-bg : transparent;
                    section-ta := TouchArea {
                        clicked => { root.section = i; }
                    }
                    Text {
                        x: 12px;
                        width: parent.width - 24px;
                        height: 100%;
                        text: name;
                        // accent-bg pairs with the normal text ramp (not
                        // on-accent, which is tuned for primary-bg).
                        color: root.section == i ? Theme.c.text-hi : Theme.c.text-mid;
                        font-size: Theme.fs(13px);
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            // ---------------- section content ----------------
            Rectangle {
                width: 640px;
                ScrollKeys {
                    target-y <=> body.viewport-y;
                    page: body.visible-height;
                    total: body.viewport-height;
                body := ScrollView {
                    width: 100%;
                    height: 100%;
                    VerticalLayout {
                        padding: 16px;
                        spacing: 12px;
                        alignment: start;

                        // ---------------- providers ----------------
                        if root.section == 0: VerticalLayout {
                            spacing: 12px;

                            HorizontalLayout {
                                Text {
                                    text: "Providers";
                                    color: Theme.c.text-hi;
                                    font-size: Theme.fs(16px);
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: "Refresh";
                                    clicked => { root.refresh-settings(); }
                                }
                            }

                            Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                height: 150px;
                                ListView {
                                    for provider in root.providers: Rectangle {
                                        height: Theme.fs(34px);
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 6px;
                                            spacing: 8px;
                                            Text {
                                                text: provider.id;
                                                color: Theme.c.text-hi;
                                                font-size: Theme.fs(13px);
                                                font-weight: 700;
                                                vertical-alignment: center;
                                                width: 110px;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: provider.kind
                                                    + (provider.base-url != "" ? "  ·  " + provider.base-url : "");
                                                color: Theme.c.text-dim;
                                                font-size: Theme.fs(12px);
                                                vertical-alignment: center;
                                                overflow: elide;
                                                horizontal-stretch: 1;
                                            }
                                            if provider.experimental: Text {
                                                text: "⚠ experimental";
                                                color: Theme.c.err;
                                                font-size: Theme.fs(11px);
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: provider.auth == "oauth"
                                                    ? (provider.has-credentials ? "✓ logged in" : "not logged in")
                                                    : (provider.auth == "cli"
                                                        ? (provider.has-credentials ? "✓ CLI ready" : "CLI not set up")
                                                        : (provider.has-credentials ? "✓ credentials" : "no credentials"));
                                                color: provider.has-credentials ? Theme.c.ok : Theme.c.warn;
                                                font-size: Theme.fs(11px);
                                                vertical-alignment: center;
                                            }
                                            if provider.auth == "oauth" || provider.auth == "cli": Button {
                                                text: provider.has-credentials ? "Re-login" : "Log in";
                                                clicked => { root.provider-login(provider.id); }
                                            }
                                            Button {
                                                text: "Edit";
                                                clicked => {
                                                    root.preset-index = root.known-providers.length;
                                                    root.form-id = provider.id;
                                                    root.form-base-url = provider.base-url;
                                                    root.form-kind-index = provider.kind == "anthropic" ? 1 : 0;
                                                    root.form-kind = provider.kind;
                                                    root.form-hint = "";
                                                    root.form-warning = false;
                                                }
                                            }
                                            Button {
                                                text: "Remove";
                                                clicked => { root.provider-deleted(provider.id); }
                                            }
                                        }
                                    }
                                }
                            }

                            // Provider add/edit form.
                            Text {
                                text: "Add or edit a provider";
                                color: Theme.c.text-mid;
                                font-size: Theme.fs(13px);
                                font-weight: 700;
                            }
                            // Provider picker: a known preset prefills (and
                            // hides) the id / protocol / URL details;
                            // "Custom" shows them for hand entry.
                            preset-box := ComboBox {
                                model: root.known-provider-names;
                                current-index <=> root.preset-index;
                                selected => {
                                    if (!root.preset-is-custom) {
                                        root.form-id = root.known-providers[root.preset-index].id;
                                        root.form-base-url = root.known-providers[root.preset-index].base-url;
                                        root.form-kind = root.known-providers[root.preset-index].kind;
                                        root.form-kind-index =
                                            root.known-providers[root.preset-index].kind == "anthropic" ? 1 : 0;
                                        root.form-warning = root.known-providers[root.preset-index].experimental;
                                        root.form-hint =
                                            root.known-providers[root.preset-index].experimental
                                            ? "Experimental: talks to an undocumented vendor endpoint using your `codex login` token. OpenAI may break or restrict it at any time — use at your own risk. Save, then log in via the Codex CLI."
                                            : (root.known-providers[root.preset-index].auth == "cli"
                                                ? "Subscription via the vendor's CLI: install it, save, then click \"Log in\" in the list above (or log in from a terminal)."
                                                : (root.known-providers[root.preset-index].auth == "oauth"
                                                    ? "Subscription login: save, then click \"Log in\" in the list above."
                                                    : (root.known-providers[root.preset-index].auth == "api-key"
                                                        ? "Paste your API key below and save. Also honors the "
                                                            + root.known-providers[root.preset-index].api-key-env
                                                            + " environment variable."
                                                        : "No API key needed — just save.")));
                                    } else {
                                        root.form-kind = root.form-kind-index == 1 ? "anthropic" : "openai-compat";
                                        root.form-hint = "";
                                        root.form-warning = false;
                                    }
                                }
                            }
                            if root.preset-is-custom: HorizontalLayout {
                                spacing: 8px;
                                LineEdit {
                                    width: 150px;
                                    placeholder-text: "id (e.g. openai)";
                                    text <=> root.form-id;
                                }
                                ComboBox {
                                    width: 150px;
                                    model: ["openai-compat", "anthropic"];
                                    current-index <=> root.form-kind-index;
                                    selected => {
                                        root.form-kind = root.form-kind-index == 1 ? "anthropic" : "openai-compat";
                                    }
                                }
                                LineEdit {
                                    horizontal-stretch: 1;
                                    placeholder-text: "base URL (optional)";
                                    text <=> root.form-base-url;
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                key-edit := LineEdit {
                                    horizontal-stretch: 1;
                                    visible: root.preset-auth == "api-key";
                                    placeholder-text: "API key (stored in the OS keychain; leave empty to keep)";
                                    input-type: password;
                                }
                                Button {
                                    text: "Save provider";
                                    primary: true;
                                    enabled: root.form-id != "";
                                    clicked => {
                                        root.provider-saved(
                                            root.form-id,
                                            root.form-kind,
                                            root.form-base-url,
                                            key-edit.text);
                                        key-edit.text = "";
                                        root.form-hint = "";
                                        root.form-warning = false;
                                    }
                                }
                            }
                            if root.form-hint != "": Text {
                                text: root.form-hint;
                                color: root.form-warning ? Theme.c.err : Theme.c.ok-dim;
                                font-size: Theme.fs(12px);
                                wrap: word-wrap;
                            }
                            if root.settings-status != "": Text {
                                text: root.settings-status;
                                color: Theme.c.accent-tint;
                                font-size: Theme.fs(12px);
                                wrap: word-wrap;
                            }

                            // ---------------- vendor CLIs ----------------
                            Text {
                                text: "Vendor CLIs";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }
                            Text {
                                text: "Agent backends (Cursor, Claude Code, Codex) run through the vendor's CLI. trouve can download and update these directly — managed installs live in trouve's data directory and take precedence over system packages.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }
                            Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                height: 118px;
                                ListView {
                                    for cli in root.clis: Rectangle {
                                        height: Theme.fs(38px);
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 6px;
                                            spacing: 8px;
                                            Text {
                                                text: cli.display-name;
                                                color: Theme.c.text-hi;
                                                font-size: Theme.fs(13px);
                                                font-weight: 700;
                                                vertical-alignment: center;
                                                width: 110px;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: cli.status != "" ? cli.status : cli.version-label;
                                                color: cli.status != "" ? Theme.c.accent-tint : Theme.c.text-dim;
                                                font-size: Theme.fs(12px);
                                                vertical-alignment: center;
                                                overflow: elide;
                                                horizontal-stretch: 1;
                                            }
                                            if cli.action-label != "": Button {
                                                text: cli.action-label;
                                                enabled: !cli.busy;
                                                clicked => { root.cli-install(cli.id); }
                                            }
                                        }
                                    }
                                }
                            }

                            // ---------------- subscription health ----------------
                            Text {
                                text: "Subscription health";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }
                            Text {
                                text: "How much of each subscription's metered allowance is used. Only Codex shares this with third-party apps — Cursor and Claude do not provide subscription information to third parties.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }
                            if root.subscriptions-status != "": Text {
                                text: root.subscriptions-status;
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                            }
                            if root.subscriptions.length == 0 && root.subscriptions-status == "": Text {
                                text: "No agent-backend providers configured.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                            }
                            for sub in root.subscriptions: Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: sub.provider;
                                            color: Theme.c.text-hi;
                                            font-size: Theme.fs(13px);
                                            font-weight: 700;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                        if sub.plan != "": Text {
                                            text: sub.plan + " plan";
                                            color: Theme.c.accent-tint;
                                            font-size: Theme.fs(11px);
                                            vertical-alignment: center;
                                        }
                                        if sub.credits != "": Text {
                                            text: sub.credits;
                                            color: Theme.c.text-mid;
                                            font-size: Theme.fs(11px);
                                            vertical-alignment: center;
                                        }
                                    }
                                    if sub.status != "ok": Text {
                                        text: sub.note;
                                        color: sub.status == "unavailable" ? Theme.c.warn : Theme.c.text-soft;
                                        font-size: Theme.fs(11px);
                                        wrap: word-wrap;
                                    }
                                    if sub.has-w1: SubscriptionMeter {
                                        label: sub.w1-label;
                                        pct: sub.w1-pct;
                                        resets: sub.w1-resets;
                                    }
                                    if sub.has-w2: SubscriptionMeter {
                                        label: sub.w2-label;
                                        pct: sub.w2-pct;
                                        resets: sub.w2-resets;
                                    }
                                }
                            }
                        }

                        // ---------------- modes & models ----------------
                        if root.section == 1: VerticalLayout {
                            spacing: 12px;

                            Text {
                                text: "Modes & Models";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }

                            // No providers → every model selector below is
                            // disabled; send the user to fix that first.
                            if root.models.length == 0: Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                height: no-models.preferred-height + 20px;
                                no-models := HorizontalLayout {
                                    padding: 10px;
                                    spacing: 10px;
                                    Text {
                                        text: "No models available — configure a provider to enable the model selectors.";
                                        color: Theme.c.warn;
                                        font-size: Theme.fs(12px);
                                        wrap: word-wrap;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                    Button {
                                        text: "Configure providers";
                                        primary: true;
                                        clicked => { root.section = 0; }
                                    }
                                }
                            }

                            Text {
                                text: "Global default model — used by new threads whose mode has no default of its own.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                model-box := ComboBox {
                                    horizontal-stretch: 1;
                                    model: root.models;
                                    current-index: root.default-model-index;
                                    enabled: root.models.length > 0;
                                }
                                Button {
                                    text: "Set default";
                                    enabled: root.models.length > 0 && model-box.current-index >= 0;
                                    clicked => { root.default-model-picked(model-box.current-index); }
                                }
                            }

                            Text {
                                text: "Modes";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(14px);
                                font-weight: 700;
                            }
                            Text {
                                text: "A mode is a prompt, a tool policy, and default permissions. Editing a built-in saves an override in ~/.config/trouve/modes/; Reset removes it. Workspace modes (.agents/modes/) are file-managed and read-only here.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }

                            Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                height: 240px;
                                ListView {
                                    for mode in root.mode-items: Rectangle {
                                        height: Theme.fs(44px);
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 6px;
                                            spacing: 8px;
                                            VerticalLayout {
                                                alignment: center;
                                                horizontal-stretch: 1;
                                                HorizontalLayout {
                                                    spacing: 6px;
                                                    alignment: start;
                                                    Text {
                                                        text: mode.display-name;
                                                        color: Theme.c.text-hi;
                                                        font-size: Theme.fs(13px);
                                                        font-weight: 700;
                                                        overflow: elide;
                                                    }
                                                    Text {
                                                        text: mode.id
                                                            + (mode.origin == "builtin" ? "" : "  ·  " + mode.origin)
                                                            + (mode.read-only ? "  ·  read-only" : "");
                                                        color: mode.origin == "customized" || mode.origin == "custom"
                                                            ? Theme.c.accent-tint : Theme.c.text-dim;
                                                        font-size: Theme.fs(11px);
                                                        vertical-alignment: center;
                                                    }
                                                }
                                                Text {
                                                    text: mode.system-prompt;
                                                    color: Theme.c.text-dim;
                                                    font-size: Theme.fs(11px);
                                                    overflow: elide;
                                                }
                                            }
                                            // Per-mode default model; entry 0
                                            // is "Global default".
                                            VerticalLayout {
                                                alignment: center;
                                                ComboBox {
                                                    width: 190px;
                                                    model: root.mode-model-names;
                                                    current-index: mode.model-index + 1;
                                                    enabled: root.models.length > 0
                                                        && mode.origin != "workspace";
                                                    selected => {
                                                        root.mode-model-picked(mode.id, self.current-index - 1);
                                                    }
                                                }
                                            }
                                            if mode.origin != "workspace": Button {
                                                text: "Edit";
                                                clicked => {
                                                    root.mode-form-open = true;
                                                    root.mode-form-editing = true;
                                                    root.mode-form-id = mode.id;
                                                    root.mode-form-display = mode.display-name;
                                                    root.mode-form-prompt = mode.system-prompt;
                                                    root.mode-form-tools = mode.allowed-tools;
                                                    root.mode-form-readonly = mode.read-only;
                                                    root.mode-form-permission = mode.permission-index;
                                                    root.mode-form-model = mode.model-index;
                                                }
                                            }
                                            if mode.origin == "customized": Button {
                                                text: "Reset";
                                                clicked => { root.mode-deleted(mode.id); }
                                            }
                                            if mode.origin == "custom": Button {
                                                text: "Remove";
                                                clicked => { root.mode-deleted(mode.id); }
                                            }
                                        }
                                    }
                                }
                            }

                            if !root.mode-form-open: HorizontalLayout {
                                alignment: start;
                                Button {
                                    text: "+ Add mode";
                                    clicked => {
                                        root.mode-form-open = true;
                                        root.mode-form-editing = false;
                                        root.mode-form-id = "";
                                        root.mode-form-display = "";
                                        root.mode-form-prompt = "";
                                        root.mode-form-tools = "";
                                        root.mode-form-readonly = false;
                                        root.mode-form-permission = 0;
                                        root.mode-form-model = -1;
                                    }
                                }
                            }

                            // ----- add / edit form -----
                            if root.mode-form-open: Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                height: mode-form.preferred-height + 24px;
                                mode-form := VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;
                                    Text {
                                        text: root.mode-form-editing
                                            ? "Edit mode \"" + root.mode-form-id + "\""
                                            : "Add mode";
                                        color: Theme.c.text-mid;
                                        font-size: Theme.fs(13px);
                                        font-weight: 700;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        if !root.mode-form-editing: LineEdit {
                                            width: 150px;
                                            placeholder-text: "id (e.g. docs)";
                                            text <=> root.mode-form-id;
                                        }
                                        LineEdit {
                                            horizontal-stretch: 1;
                                            placeholder-text: "display name";
                                            text <=> root.mode-form-display;
                                        }
                                    }
                                    Text {
                                        text: "System prompt (appended to the base prompt):";
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(11px);
                                    }
                                    TextEdit {
                                        height: 90px;
                                        text <=> root.mode-form-prompt;
                                        wrap: word-wrap;
                                    }
                                    LineEdit {
                                        placeholder-text: "allowed tools, comma-separated (empty = all tools)";
                                        text <=> root.mode-form-tools;
                                    }
                                    HorizontalLayout {
                                        spacing: 12px;
                                        CheckBox {
                                            text: "Read-only (never mutates the worktree)";
                                            checked <=> root.mode-form-readonly;
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        VerticalLayout {
                                            spacing: 2px;
                                            Text {
                                                text: "Default permissions";
                                                color: Theme.c.text-soft;
                                                font-size: Theme.fs(10px);
                                            }
                                            ComboBox {
                                                width: 150px;
                                                model: ["Ask", "Allow list", "Yolo"];
                                                current-index <=> root.mode-form-permission;
                                            }
                                        }
                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Default model";
                                                color: Theme.c.text-soft;
                                                font-size: Theme.fs(10px);
                                            }
                                            form-model-box := ComboBox {
                                                model: root.mode-model-names;
                                                current-index: root.mode-form-model + 1;
                                                enabled: root.models.length > 0;
                                                selected => {
                                                    root.mode-form-model = self.current-index - 1;
                                                }
                                            }
                                        }
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;
                                        Button {
                                            text: root.mode-form-editing ? "Save mode" : "Add mode";
                                            primary: true;
                                            enabled: root.mode-form-id != "" && root.mode-form-display != "";
                                            clicked => {
                                                root.mode-saved(
                                                    root.mode-form-id,
                                                    root.mode-form-display,
                                                    root.mode-form-prompt,
                                                    root.mode-form-tools,
                                                    root.mode-form-readonly,
                                                    root.mode-form-permission,
                                                    root.mode-form-model);
                                                root.mode-form-open = false;
                                            }
                                        }
                                        Button {
                                            text: "Cancel";
                                            clicked => { root.mode-form-open = false; }
                                        }
                                    }
                                }
                            }

                            if root.settings-status != "": Text {
                                text: root.settings-status;
                                color: Theme.c.accent-tint;
                                font-size: Theme.fs(12px);
                                wrap: word-wrap;
                            }
                        }

                        // ---------------- mcp servers ----------------
                        if root.section == 2: VerticalLayout {
                            spacing: 12px;

                            HorizontalLayout {
                                Text {
                                    text: "MCP Servers";
                                    color: Theme.c.text-hi;
                                    font-size: Theme.fs(16px);
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: "⟳ Refresh";
                                    clicked => { root.mcp-refresh(); }
                                }
                            }
                            Text {
                                text: "External tool servers offered to the agent as mcp__<server>__<tool>. Each one needs first-use approval per session. trouve's own built-in servers are not listed.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }
                            if root.mcp-status != "": Text {
                                text: root.mcp-status;
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                                wrap: word-wrap;
                            }

                            Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                height: 180px;
                                if root.mcp-servers.length == 0: Text {
                                    text: "No MCP servers configured.";
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(12px);
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                ListView {
                                    for server in root.mcp-servers: Rectangle {
                                        height: Theme.fs(40px);
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 6px;
                                            spacing: 8px;
                                            Text {
                                                text: server.health == "ok" ? "●"
                                                    : server.health == "error" ? "●" : "○";
                                                color: server.health == "ok" ? Theme.c.ok
                                                    : server.health == "error" ? Theme.c.err
                                                    : Theme.c.text-soft;
                                                font-size: Theme.fs(12px);
                                                vertical-alignment: center;
                                            }
                                            VerticalLayout {
                                                alignment: center;
                                                horizontal-stretch: 1;
                                                HorizontalLayout {
                                                    spacing: 6px;
                                                    alignment: start;
                                                    Text {
                                                        text: server.name;
                                                        color: Theme.c.text-hi;
                                                        font-size: Theme.fs(13px);
                                                        font-weight: 700;
                                                        overflow: elide;
                                                    }
                                                    Text {
                                                        text: server.scope;
                                                        color: Theme.c.accent-tint;
                                                        font-size: Theme.fs(10px);
                                                        vertical-alignment: center;
                                                    }
                                                }
                                                Text {
                                                    text: server.command-line
                                                        + (server.detail != "" ? "  ·  " + server.detail : "");
                                                    color: server.health == "error"
                                                        ? Theme.c.err-soft : Theme.c.text-dim;
                                                    font-size: Theme.fs(11px);
                                                    overflow: elide;
                                                }
                                            }
                                            Button {
                                                text: "Logs";
                                                clicked => { root.mcp-logs-requested(server.name); }
                                            }
                                            Button {
                                                text: "Edit";
                                                clicked => {
                                                    root.mcp-form-open = true;
                                                    root.mcp-form-editing = true;
                                                    root.mcp-form-scope = server.scope;
                                                    root.mcp-form-name = server.name;
                                                    root.mcp-form-command = server.command-line;
                                                    root.mcp-form-env = server.env-lines;
                                                }
                                            }
                                            Button {
                                                text: "Remove";
                                                clicked => { root.mcp-deleted(server.name, server.scope); }
                                            }
                                        }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                Button {
                                    text: "+ Add to user config";
                                    clicked => {
                                        root.mcp-form-open = true;
                                        root.mcp-form-editing = false;
                                        root.mcp-form-scope = "user";
                                        root.mcp-form-name = "";
                                        root.mcp-form-command = "";
                                        root.mcp-form-env = "";
                                    }
                                }
                                Button {
                                    text: "+ Add to workspace";
                                    clicked => {
                                        root.mcp-form-open = true;
                                        root.mcp-form-editing = false;
                                        root.mcp-form-scope = "workspace";
                                        root.mcp-form-name = "";
                                        root.mcp-form-command = "";
                                        root.mcp-form-env = "";
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }

                            // Add/edit form.
                            if root.mcp-form-open: Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 8px;
                                    Text {
                                        text: (root.mcp-form-editing ? "Edit " : "New ")
                                            + (root.mcp-form-scope == "user"
                                                ? "user server (~/.config/trouve/mcp.json)"
                                                : "workspace server (.agents/.mcp.json)");
                                        color: Theme.c.text-mid;
                                        font-size: Theme.fs(12px);
                                        font-weight: 700;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        LineEdit {
                                            text <=> root.mcp-form-name;
                                            placeholder-text: "name (e.g. jira)";
                                            enabled: !root.mcp-form-editing;
                                            width: 160px;
                                        }
                                        LineEdit {
                                            text <=> root.mcp-form-command;
                                            placeholder-text: "command and args (e.g. npx -y jira-mcp --stdio)";
                                            horizontal-stretch: 1;
                                        }
                                    }
                                    TextEdit {
                                        text <=> root.mcp-form-env;
                                        placeholder-text: "environment, one KEY=VALUE per line; ${VAR} expands at launch";
                                        height: Theme.fs(64px);
                                        wrap: no-wrap;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Button {
                                            text: root.mcp-form-editing ? "Save changes" : "Add server";
                                            primary: true;
                                            enabled: root.mcp-form-name != "" && root.mcp-form-command != "";
                                            clicked => {
                                                root.mcp-saved(root.mcp-form-name, root.mcp-form-scope,
                                                    root.mcp-form-command, root.mcp-form-env);
                                                root.mcp-form-open = false;
                                            }
                                        }
                                        Button {
                                            text: "Cancel";
                                            clicked => { root.mcp-form-open = false; }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }
                                }
                            }

                            // Logs viewer.
                            if root.mcp-logs-name != "": Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 6px;
                                    HorizontalLayout {
                                        Text {
                                            text: "Logs — " + root.mcp-logs-name;
                                            color: Theme.c.text-hi;
                                            font-size: Theme.fs(12px);
                                            font-weight: 700;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                        Button {
                                            text: "⟳";
                                            clicked => { root.mcp-logs-requested(root.mcp-logs-name); }
                                        }
                                        Button {
                                            text: "✕";
                                            clicked => { root.mcp-logs-closed(); }
                                        }
                                    }
                                    Rectangle {
                                        background: Theme.c.code-bg;
                                        border-radius: 4px;
                                        height: 180px;
                                        mcp-log-scroll := ScrollView {
                                            width: 100%;
                                            height: 100%;
                                            VerticalLayout {
                                                padding: 8px;
                                                Text {
                                                    text: root.mcp-logs-text == ""
                                                        ? "No log lines yet — logs appear after a health check or the first tool call."
                                                        : root.mcp-logs-text;
                                                    color: Theme.c.code-fg;
                                                    font-family: "monospace";
                                                    font-size: Theme.fs(11px);
                                                    wrap: word-wrap;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // ---------------- integrations ----------------
                        if root.section == 3: VerticalLayout {
                            spacing: 12px;

                            Text {
                                text: "Integrations";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }

                            Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;

                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: "GitHub";
                                            color: Theme.c.text-hi;
                                            font-size: Theme.fs(14px);
                                            font-weight: 700;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                        Text {
                                            text: root.github-configured
                                                ? (root.github-source == "environment"
                                                    ? "● connected (environment)"
                                                    : "● connected")
                                                : "○ not configured";
                                            color: root.github-configured ? Theme.c.ok : Theme.c.text-soft;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: "Powers the Pull Requests tab and PR creation. Create a fine-grained personal access token with read/write access to Pull requests (and read access to Checks) on github.com → Settings → Developer settings.";
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(11px);
                                        wrap: word-wrap;
                                    }
                                    if root.github-source == "environment": Text {
                                        text: "The token currently comes from the GITHUB_TOKEN / GH_TOKEN environment variable, which takes precedence over one saved here.";
                                        color: Theme.c.warn;
                                        font-size: Theme.fs(11px);
                                        wrap: word-wrap;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        gh-token := LineEdit {
                                            placeholder-text: root.github-configured && root.github-source == "settings"
                                                ? "••••••••  (saved — enter a new token to replace)"
                                                : "ghp_… or github_pat_…";
                                            input-type: password;
                                            horizontal-stretch: 1;
                                        }
                                        Button {
                                            text: "Save";
                                            primary: true;
                                            enabled: gh-token.text != "";
                                            clicked => {
                                                root.github-token-saved(gh-token.text);
                                                gh-token.text = "";
                                            }
                                        }
                                        if root.github-configured && root.github-source == "settings": Button {
                                            text: "Remove";
                                            clicked => { root.github-token-saved(""); }
                                        }
                                    }
                                }
                            }
                        }

                        // ---------------- appearance ----------------
                        if root.section == 4: VerticalLayout {
                            spacing: 12px;

                            Text {
                                text: "Appearance";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }

                            VerticalLayout {
                                spacing: 6px;
                                Text {
                                    text: "Theme";
                                    color: Theme.c.text-mid;
                                    font-size: Theme.fs(12px);
                                    font-weight: 700;
                                }
                                ComboBox {
                                    model: root.theme-names;
                                    current-index <=> root.theme-index;
                                    selected => { root.theme-picked(self.current-index); }
                                }
                                Text {
                                    text: "Every theme is contrast-checked as a whole (WCAG AA), so individual colors can't be overridden. The colorblind themes put success and errors on a blue/orange axis instead of green/red.";
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(11px);
                                    wrap: word-wrap;
                                }
                            }

                            HorizontalLayout {
                                spacing: 12px;
                                VerticalLayout {
                                    spacing: 6px;
                                    horizontal-stretch: 0;
                                    Text {
                                        text: "Base font size";
                                        color: Theme.c.text-mid;
                                        font-size: Theme.fs(12px);
                                        font-weight: 700;
                                    }
                                    ComboBox {
                                        width: 120px;
                                        model: root.font-size-names;
                                        current-index <=> root.font-size-index;
                                        selected => { root.font-size-picked(self.current-index); }
                                    }
                                }
                                VerticalLayout {
                                    spacing: 6px;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: "Font";
                                        color: Theme.c.text-mid;
                                        font-size: Theme.fs(12px);
                                        font-weight: 700;
                                    }
                                    ComboBox {
                                        model: root.font-names;
                                        current-index <=> root.font-index;
                                        selected => { root.font-picked(self.current-index); }
                                    }
                                }
                            }
                            Text {
                                text: "The size scales the whole interface; code keeps its monospace font.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                Rectangle {
                                    width: 44px;
                                    height: Theme.fs(26px);
                                    background: root.reduce-motion ? Theme.c.accent-bg : Theme.c.control-bg;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: root.reduce-motion ? Theme.c.primary-border : Theme.c.border;
                                    TouchArea {
                                        clicked => {
                                            root.reduce-motion = !root.reduce-motion;
                                            root.reduce-motion-toggled(root.reduce-motion);
                                        }
                                    }
                                    Text {
                                        text: root.reduce-motion ? "On" : "Off";
                                        color: root.reduce-motion ? Theme.c.text-hi : Theme.c.text-soft;
                                        font-size: Theme.fs(12px);
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: "Reduce motion — replace spinners and other animation with static indicators.";
                                    color: Theme.c.text-mid;
                                    font-size: Theme.fs(12px);
                                    vertical-alignment: center;
                                    wrap: word-wrap;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        // ---------------- about ----------------
                        if root.section == 5: VerticalLayout {
                            spacing: 12px;

                            Text {
                                text: "About";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }
                            Text {
                                text: "trouve — a protocol-first AI coding harness.";
                                color: Theme.c.text-dim;
                                font-size: Theme.fs(12px);
                            }
                            AboutSlint { }
                        }
                    }
                }
                }
            }

            Rectangle { horizontal-stretch: 1; }
        }
    }
}
