// Settings screen: provider configuration (incl. vendor CLIs), default
// model, agent modes, and the About section (AboutSlint attribution lives
// here, reachable from the left-column footer — royalty-free license
// requirement). Rendered full-window over the main layout; a side nav
// switches between sections and the header's Close button returns to the
// previous screen.
//
// Like the main window, this is dumb: models in, callbacks out.

import {
    AboutSlint, Button, ComboBox, LineEdit, ListView, ScrollView
} from "std-widgets.slint";
import { ScrollKeys } from "scroll-keys.slint";
import { Theme } from "theme.slint";

export struct ProviderItem {
    id: string,
    kind: string,
    base-url: string,
    has-credentials: bool,
    auth: string,
    experimental: bool,
}

// A vendor CLI (cursor-agent, claude, codex) trouve can download and manage.
export struct CliItem {
    id: string,
    display-name: string,
    // "not installed" / "1.2.3 (system)" / "1.2.3 (managed)" ...
    version-label: string,
    // "Install" / "Update" / "" (hidden when up to date and managed)
    action-label: string,
    // In-flight install feedback ("downloading…", "failed: …").
    status: string,
    busy: bool,
}

// A well-known provider preset served by the backend; picking one prefills
// the add/edit form so nothing has to be typed by hand.
export struct KnownProviderItem {
    id: string,
    display-name: string,
    kind: string,
    base-url: string,
    api-key-env: string,
    // "api-key", "oauth" (subscription login), "cli" (vendor CLI holds the
    // subscription auth), or "none" (keyless local).
    auth: string,
    // Undocumented vendor endpoint; may break or be restricted at any time.
    experimental: bool,
}

export component SettingsScreen inherits Rectangle {
    background: Theme.c.win-bg;

    in property <[ProviderItem]> providers;
    in property <[CliItem]> clis;
    in property <[KnownProviderItem]> known-providers;
    // Preset display names (alphabetical; index i maps to
    // known-providers[i]) followed by "Custom" as the last entry.
    in property <[string]> known-provider-names;
    in property <[string]> models;
    in property <int> default-model-index: -1;
    in property <[string]> modes;
    in property <string> settings-status: "";

    // Provider form state (prefilled by "Edit" or a preset).
    in-out property <string> form-id: "";
    in-out property <string> form-base-url: "";
    in-out property <int> form-kind-index: 0;
    // Wire kind actually saved; presets can carry kinds beyond the custom
    // combo's two entries (codex-app-server, cursor-cli, claude-cli, ...).
    in-out property <string> form-kind: "openai-compat";
    in-out property <string> form-hint: "";
    in-out property <bool> form-warning: false;
    // Index into known-provider-names: a preset (fields hidden, prefilled
    // from known-providers[index]) or the trailing "Custom" entry (id/kind/
    // url fields shown). The controller points it at Custom on load.
    in-out property <int> preset-index: 0;
    property <bool> preset-is-custom: root.preset-index >= root.known-providers.length;
    property <string> preset-auth:
        !root.preset-is-custom && root.preset-index >= 0
            ? root.known-providers[root.preset-index].auth
            : "api-key";

    // Appearance: built-in theme names, font sizes, and font families come
    // from Rust; the pickers report index selections back.
    in property <[string]> theme-names;
    in-out property <int> theme-index: 0;
    in property <[string]> font-size-names;
    in-out property <int> font-size-index: 0;
    in property <[string]> font-names;
    in-out property <int> font-index: 0;
    in-out property <bool> reduce-motion: false;

    callback provider-saved(/* id */ string, /* kind */ string,
                            /* base-url */ string, /* api-key */ string);
    callback provider-deleted(string);
    callback provider-login(string);
    callback default-model-picked(int);
    callback refresh-settings();
    callback cli-install(/* id */ string);
    callback theme-picked(int);
    callback font-size-picked(int);
    callback font-picked(int);
    callback reduce-motion-toggled(bool);
    callback close();

    // Integrations: GitHub token state comes from the server; saving an
    // empty token removes it.
    in property <bool> github-configured: false;
    // "environment" (GITHUB_TOKEN/GH_TOKEN) or "settings" (secret store).
    in property <string> github-source: "";
    callback github-token-saved(string);

    // Side-nav selection: 0 providers, 1 models, 2 modes, 3 integrations,
    // 4 appearance, 5 about. in-out so the app can open straight to a
    // section (e.g. the PR tab's "set up GitHub" button).
    in-out property <int> section: 0;
    property <[string]> section-names: ["Providers", "Models", "Modes", "Integrations", "Appearance", "About"];

    VerticalLayout {
        // Header: title + a way back to wherever the user came from.
        Rectangle {
            height: Theme.fs(44px);
            background: Theme.c.panel-bg;
            HorizontalLayout {
                padding-left: 16px;
                padding-right: 10px;
                spacing: 8px;
                Text {
                    text: "Settings";
                    color: Theme.c.text-hi;
                    font-size: Theme.fs(16px);
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                VerticalLayout {
                    alignment: center;
                    Button {
                        text: "✕ Close";
                        clicked => { root.close(); }
                    }
                }
            }
        }

        // Centered fixed-width block: section nav on the left, the active
        // section's content beside it.
        HorizontalLayout {
            vertical-stretch: 1;
            Rectangle { horizontal-stretch: 1; }

            // ---------------- section nav ----------------
            VerticalLayout {
                width: 170px;
                padding-top: 20px;
                padding-right: 12px;
                spacing: 2px;
                alignment: start;
                for name[i] in root.section-names: Rectangle {
                    height: Theme.fs(32px);
                    border-radius: 6px;
                    background: root.section == i ? Theme.c.accent-bg
                        : section-ta.has-hover ? Theme.c.raised-bg : transparent;
                    section-ta := TouchArea {
                        clicked => { root.section = i; }
                    }
                    Text {
                        x: 12px;
                        width: parent.width - 24px;
                        height: 100%;
                        text: name;
                        // accent-bg pairs with the normal text ramp (not
                        // on-accent, which is tuned for primary-bg).
                        color: root.section == i ? Theme.c.text-hi : Theme.c.text-mid;
                        font-size: Theme.fs(13px);
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            // ---------------- section content ----------------
            Rectangle {
                width: 640px;
                ScrollKeys {
                    target-y <=> body.viewport-y;
                    page: body.visible-height;
                    total: body.viewport-height;
                body := ScrollView {
                    width: 100%;
                    height: 100%;
                    VerticalLayout {
                        padding: 16px;
                        spacing: 12px;
                        alignment: start;

                        // ---------------- providers ----------------
                        if root.section == 0: VerticalLayout {
                            spacing: 12px;

                            HorizontalLayout {
                                Text {
                                    text: "Providers";
                                    color: Theme.c.text-hi;
                                    font-size: Theme.fs(16px);
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: "Refresh";
                                    clicked => { root.refresh-settings(); }
                                }
                            }

                            Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                height: 150px;
                                ListView {
                                    for provider in root.providers: Rectangle {
                                        height: Theme.fs(34px);
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 6px;
                                            spacing: 8px;
                                            Text {
                                                text: provider.id;
                                                color: Theme.c.text-hi;
                                                font-size: Theme.fs(13px);
                                                font-weight: 700;
                                                vertical-alignment: center;
                                                width: 110px;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: provider.kind
                                                    + (provider.base-url != "" ? "  ·  " + provider.base-url : "");
                                                color: Theme.c.text-dim;
                                                font-size: Theme.fs(12px);
                                                vertical-alignment: center;
                                                overflow: elide;
                                                horizontal-stretch: 1;
                                            }
                                            if provider.experimental: Text {
                                                text: "⚠ experimental";
                                                color: Theme.c.err;
                                                font-size: Theme.fs(11px);
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: provider.auth == "oauth"
                                                    ? (provider.has-credentials ? "✓ logged in" : "not logged in")
                                                    : (provider.auth == "cli"
                                                        ? (provider.has-credentials ? "✓ CLI ready" : "CLI not set up")
                                                        : (provider.has-credentials ? "✓ credentials" : "no credentials"));
                                                color: provider.has-credentials ? Theme.c.ok : Theme.c.warn;
                                                font-size: Theme.fs(11px);
                                                vertical-alignment: center;
                                            }
                                            if provider.auth == "oauth" || provider.auth == "cli": Button {
                                                text: provider.has-credentials ? "Re-login" : "Log in";
                                                clicked => { root.provider-login(provider.id); }
                                            }
                                            Button {
                                                text: "Edit";
                                                clicked => {
                                                    root.preset-index = root.known-providers.length;
                                                    root.form-id = provider.id;
                                                    root.form-base-url = provider.base-url;
                                                    root.form-kind-index = provider.kind == "anthropic" ? 1 : 0;
                                                    root.form-kind = provider.kind;
                                                    root.form-hint = "";
                                                    root.form-warning = false;
                                                }
                                            }
                                            Button {
                                                text: "Remove";
                                                clicked => { root.provider-deleted(provider.id); }
                                            }
                                        }
                                    }
                                }
                            }

                            // Provider add/edit form.
                            Text {
                                text: "Add or edit a provider";
                                color: Theme.c.text-mid;
                                font-size: Theme.fs(13px);
                                font-weight: 700;
                            }
                            // Provider picker: a known preset prefills (and
                            // hides) the id / protocol / URL details;
                            // "Custom" shows them for hand entry.
                            preset-box := ComboBox {
                                model: root.known-provider-names;
                                current-index <=> root.preset-index;
                                selected => {
                                    if (!root.preset-is-custom) {
                                        root.form-id = root.known-providers[root.preset-index].id;
                                        root.form-base-url = root.known-providers[root.preset-index].base-url;
                                        root.form-kind = root.known-providers[root.preset-index].kind;
                                        root.form-kind-index =
                                            root.known-providers[root.preset-index].kind == "anthropic" ? 1 : 0;
                                        root.form-warning = root.known-providers[root.preset-index].experimental;
                                        root.form-hint =
                                            root.known-providers[root.preset-index].experimental
                                            ? "Experimental: talks to an undocumented vendor endpoint using your `codex login` token. OpenAI may break or restrict it at any time — use at your own risk. Save, then log in via the Codex CLI."
                                            : (root.known-providers[root.preset-index].auth == "cli"
                                                ? "Subscription via the vendor's CLI: install it, save, then click \"Log in\" in the list above (or log in from a terminal)."
                                                : (root.known-providers[root.preset-index].auth == "oauth"
                                                    ? "Subscription login: save, then click \"Log in\" in the list above."
                                                    : (root.known-providers[root.preset-index].auth == "api-key"
                                                        ? "Paste your API key below and save. Also honors the "
                                                            + root.known-providers[root.preset-index].api-key-env
                                                            + " environment variable."
                                                        : "No API key needed — just save.")));
                                    } else {
                                        root.form-kind = root.form-kind-index == 1 ? "anthropic" : "openai-compat";
                                        root.form-hint = "";
                                        root.form-warning = false;
                                    }
                                }
                            }
                            if root.preset-is-custom: HorizontalLayout {
                                spacing: 8px;
                                LineEdit {
                                    width: 150px;
                                    placeholder-text: "id (e.g. openai)";
                                    text <=> root.form-id;
                                }
                                ComboBox {
                                    width: 150px;
                                    model: ["openai-compat", "anthropic"];
                                    current-index <=> root.form-kind-index;
                                    selected => {
                                        root.form-kind = root.form-kind-index == 1 ? "anthropic" : "openai-compat";
                                    }
                                }
                                LineEdit {
                                    horizontal-stretch: 1;
                                    placeholder-text: "base URL (optional)";
                                    text <=> root.form-base-url;
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                key-edit := LineEdit {
                                    horizontal-stretch: 1;
                                    visible: root.preset-auth == "api-key";
                                    placeholder-text: "API key (stored in the OS keychain; leave empty to keep)";
                                    input-type: password;
                                }
                                Button {
                                    text: "Save provider";
                                    primary: true;
                                    enabled: root.form-id != "";
                                    clicked => {
                                        root.provider-saved(
                                            root.form-id,
                                            root.form-kind,
                                            root.form-base-url,
                                            key-edit.text);
                                        key-edit.text = "";
                                        root.form-hint = "";
                                        root.form-warning = false;
                                    }
                                }
                            }
                            if root.form-hint != "": Text {
                                text: root.form-hint;
                                color: root.form-warning ? Theme.c.err : Theme.c.ok-dim;
                                font-size: Theme.fs(12px);
                                wrap: word-wrap;
                            }
                            if root.settings-status != "": Text {
                                text: root.settings-status;
                                color: Theme.c.accent-tint;
                                font-size: Theme.fs(12px);
                                wrap: word-wrap;
                            }

                            // ---------------- vendor CLIs ----------------
                            Text {
                                text: "Vendor CLIs";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }
                            Text {
                                text: "Agent backends (Cursor, Claude Code, Codex) run through the vendor's CLI. trouve can download and update these directly — managed installs live in trouve's data directory and take precedence over system packages.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }
                            Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                height: 118px;
                                ListView {
                                    for cli in root.clis: Rectangle {
                                        height: Theme.fs(38px);
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 6px;
                                            spacing: 8px;
                                            Text {
                                                text: cli.display-name;
                                                color: Theme.c.text-hi;
                                                font-size: Theme.fs(13px);
                                                font-weight: 700;
                                                vertical-alignment: center;
                                                width: 110px;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: cli.status != "" ? cli.status : cli.version-label;
                                                color: cli.status != "" ? Theme.c.accent-tint : Theme.c.text-dim;
                                                font-size: Theme.fs(12px);
                                                vertical-alignment: center;
                                                overflow: elide;
                                                horizontal-stretch: 1;
                                            }
                                            if cli.action-label != "": Button {
                                                text: cli.action-label;
                                                enabled: !cli.busy;
                                                clicked => { root.cli-install(cli.id); }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // ---------------- models ----------------
                        if root.section == 1: VerticalLayout {
                            spacing: 12px;

                            Text {
                                text: "Default model";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }
                            Text {
                                text: "Preselected for new sessions and threads; each thread can still pick its own model in the composer.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                model-box := ComboBox {
                                    horizontal-stretch: 1;
                                    model: root.models;
                                    current-index: root.default-model-index;
                                }
                                Button {
                                    text: "Set default";
                                    enabled: model-box.current-index >= 0;
                                    clicked => { root.default-model-picked(model-box.current-index); }
                                }
                            }
                        }

                        // ---------------- agent modes ----------------
                        if root.section == 2: VerticalLayout {
                            spacing: 12px;

                            Text {
                                text: "Agent modes";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }
                            Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                height: 220px;
                                ListView {
                                    for mode in root.modes: Text {
                                        height: Theme.fs(24px);
                                        x: 10px;
                                        text: mode;
                                        color: Theme.c.text-mid;
                                        font-size: Theme.fs(12px);
                                        vertical-alignment: center;
                                    }
                                }
                            }
                            Text {
                                text: "Custom modes and mode overrides live in ~/.config/trouve/modes/ and .agents/modes/.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }
                        }

                        // ---------------- integrations ----------------
                        if root.section == 3: VerticalLayout {
                            spacing: 12px;

                            Text {
                                text: "Integrations";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }

                            Rectangle {
                                background: Theme.c.surface;
                                border-radius: 6px;
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;

                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: "GitHub";
                                            color: Theme.c.text-hi;
                                            font-size: Theme.fs(14px);
                                            font-weight: 700;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                        Text {
                                            text: root.github-configured
                                                ? (root.github-source == "environment"
                                                    ? "● connected (environment)"
                                                    : "● connected")
                                                : "○ not configured";
                                            color: root.github-configured ? Theme.c.ok : Theme.c.text-soft;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: "Powers the Pull Requests tab and PR creation. Create a fine-grained personal access token with read/write access to Pull requests (and read access to Checks) on github.com → Settings → Developer settings.";
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(11px);
                                        wrap: word-wrap;
                                    }
                                    if root.github-source == "environment": Text {
                                        text: "The token currently comes from the GITHUB_TOKEN / GH_TOKEN environment variable, which takes precedence over one saved here.";
                                        color: Theme.c.warn;
                                        font-size: Theme.fs(11px);
                                        wrap: word-wrap;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        gh-token := LineEdit {
                                            placeholder-text: root.github-configured && root.github-source == "settings"
                                                ? "••••••••  (saved — enter a new token to replace)"
                                                : "ghp_… or github_pat_…";
                                            input-type: password;
                                            horizontal-stretch: 1;
                                        }
                                        Button {
                                            text: "Save";
                                            primary: true;
                                            enabled: gh-token.text != "";
                                            clicked => {
                                                root.github-token-saved(gh-token.text);
                                                gh-token.text = "";
                                            }
                                        }
                                        if root.github-configured && root.github-source == "settings": Button {
                                            text: "Remove";
                                            clicked => { root.github-token-saved(""); }
                                        }
                                    }
                                }
                            }
                        }

                        // ---------------- appearance ----------------
                        if root.section == 4: VerticalLayout {
                            spacing: 12px;

                            Text {
                                text: "Appearance";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }

                            VerticalLayout {
                                spacing: 6px;
                                Text {
                                    text: "Theme";
                                    color: Theme.c.text-mid;
                                    font-size: Theme.fs(12px);
                                    font-weight: 700;
                                }
                                ComboBox {
                                    model: root.theme-names;
                                    current-index <=> root.theme-index;
                                    selected => { root.theme-picked(self.current-index); }
                                }
                                Text {
                                    text: "Every theme is contrast-checked as a whole (WCAG AA), so individual colors can't be overridden. The colorblind themes put success and errors on a blue/orange axis instead of green/red.";
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(11px);
                                    wrap: word-wrap;
                                }
                            }

                            HorizontalLayout {
                                spacing: 12px;
                                VerticalLayout {
                                    spacing: 6px;
                                    horizontal-stretch: 0;
                                    Text {
                                        text: "Base font size";
                                        color: Theme.c.text-mid;
                                        font-size: Theme.fs(12px);
                                        font-weight: 700;
                                    }
                                    ComboBox {
                                        width: 120px;
                                        model: root.font-size-names;
                                        current-index <=> root.font-size-index;
                                        selected => { root.font-size-picked(self.current-index); }
                                    }
                                }
                                VerticalLayout {
                                    spacing: 6px;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: "Font";
                                        color: Theme.c.text-mid;
                                        font-size: Theme.fs(12px);
                                        font-weight: 700;
                                    }
                                    ComboBox {
                                        model: root.font-names;
                                        current-index <=> root.font-index;
                                        selected => { root.font-picked(self.current-index); }
                                    }
                                }
                            }
                            Text {
                                text: "The size scales the whole interface; code keeps its monospace font.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                Rectangle {
                                    width: 44px;
                                    height: Theme.fs(26px);
                                    background: root.reduce-motion ? Theme.c.accent-bg : Theme.c.control-bg;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: root.reduce-motion ? Theme.c.primary-border : Theme.c.border;
                                    TouchArea {
                                        clicked => {
                                            root.reduce-motion = !root.reduce-motion;
                                            root.reduce-motion-toggled(root.reduce-motion);
                                        }
                                    }
                                    Text {
                                        text: root.reduce-motion ? "On" : "Off";
                                        color: root.reduce-motion ? Theme.c.text-hi : Theme.c.text-soft;
                                        font-size: Theme.fs(12px);
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: "Reduce motion — replace spinners and other animation with static indicators.";
                                    color: Theme.c.text-mid;
                                    font-size: Theme.fs(12px);
                                    vertical-alignment: center;
                                    wrap: word-wrap;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        // ---------------- about ----------------
                        if root.section == 5: VerticalLayout {
                            spacing: 12px;

                            Text {
                                text: "About";
                                color: Theme.c.text-hi;
                                font-size: Theme.fs(16px);
                                font-weight: 700;
                            }
                            Text {
                                text: "trouve — a protocol-first AI coding harness.";
                                color: Theme.c.text-dim;
                                font-size: Theme.fs(12px);
                            }
                            AboutSlint { }
                        }
                    }
                }
                }
            }

            Rectangle { horizontal-stretch: 1; }
        }
    }
}
