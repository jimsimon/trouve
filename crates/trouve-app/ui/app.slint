// trouve desktop: three-column layout.
//   left   — sessions grouped by workspace, settings footer
//   center — thread tabs, chat stream, composer (or the new-chat screen)
//   right  — inspection tabs (Diff / Files)
//
// The window is intentionally dumb: models in, callbacks out. All state
// folding happens in Rust (client-core view models + the app controller).

import {
    Button, ComboBox, LineEdit, ListView, Spinner, TabWidget
} from "std-widgets.slint";
import { DiffView, DiffRow } from "diff-view.slint";
import { CodeView, TextSegment } from "code-view.slint";
import { SettingsWindow, ProviderItem } from "settings-window.slint";

export { DiffRow, TextSegment, SettingsWindow, ProviderItem }

// One row of the left nav: workspace headers, sessions, archived toggles.
export struct NavRow {
    // 0 workspace header, 1 session, 2 archived-group toggle
    kind: int,
    title: string,
    subtitle: string,
    // For kind 1: stable index the controller maps back to a session.
    session-index: int,
    selected: bool,
    archived: bool,
    expanded: bool,
}

export struct ThreadTabItem {
    id: string,
    label: string,
}

export struct ChatRow {
    // 0 user, 1 markdown block, 2 tool card, 3 turn status,
    // 4 thinking, 5 activity (spinner + label),
    // 6 raw response text (selectable markdown source)
    kind: int,
    // For kind 1: 0 paragraph, 1 h1, 2 h2, 3 h3, 4 bullet, 5 code fence,
    // 6 numbered list item.
    md-kind: int,
    // List nesting level for md-kind 4/6 (0 = top level).
    md-indent: int,
    // Language tag for code fences ("rust"; empty when untagged).
    md-lang: string,
    text: string,
    // For kind 1, non-code blocks: `text` with inline markup resolved
    // (bold/italic/inline code/links), built via StyledText::from_markdown.
    styled: styled-text,
    // Tool-card fields (kind 2).
    tool-name: string,
    // 0 awaiting approval, 1 running, 2 ok, 3 error, 4 denied, 5 aborted
    tool-status: int,
    detail: string,
    expanded: bool,
    // Turn-status fields (kind 3): 0 running, 1 completed, 2 failed.
    turn-state: int,
    // Turn number (kind 3), for per-turn actions like the raw-view toggle.
    turn: int,
    // Kind 3: this turn's response is currently shown as raw text.
    raw: bool,
}

export struct FileItem {
    name: string,
    is-dir: bool,
}

// A ComboBox stand-in whose option list opens *above* the control, for use
// at the bottom edge of the window where a downward popup would be clipped.
component DropUpPicker inherits Rectangle {
    in property <[string]> options;
    in-out property <int> current-index: -1;
    in property <bool> enabled: true;
    in property <string> placeholder: "select…";
    callback changed(int);

    height: 30px;
    background: #222222;
    border-radius: 6px;

    popup := PopupWindow {
        x: 0;
        y: -min(root.options.length, 10) * 28px - 8px;
        width: max(root.width, 260px);
        height: min(root.options.length, 10) * 28px + 2px;

        Rectangle {
            background: #262626;
            border-radius: 6px;
            border-width: 1px;
            border-color: #3a3a3a;
            ListView {
                for option[idx] in root.options: Rectangle {
                    height: 28px;
                    background: idx == root.current-index ? #2b3d55 : transparent;
                    TouchArea {
                        clicked => {
                            root.current-index = idx;
                            root.changed(idx);
                        }
                    }
                    Text {
                        x: 8px;
                        width: parent.width - 16px;
                        text: option;
                        color: #d8d8d8;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }
    }

    TouchArea {
        enabled: root.enabled;
        clicked => { popup.show(); }
    }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.current-index >= 0 && root.current-index < root.options.length
                ? root.options[root.current-index]
                : root.placeholder;
            color: root.enabled ? #d8d8d8 : #6a6a6a;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        Text {
            text: "▴";
            color: #8a8a8a;
            font-size: 10px;
            vertical-alignment: center;
        }
    }
}

// Clipboard button: copies `payload` on click and flashes a checkmark.
// Self-contained — the hidden TextInput reaches the system clipboard through
// its built-in select-all/copy functions, so no native plumbing is needed.
component CopyButton inherits Rectangle {
    in property <string> payload;
    // Optional label rendered next to the icon ("copy response").
    in property <string> label: "";
    property <bool> copied: false;

    height: 22px;
    width: content.preferred-width + 8px;
    border-radius: 4px;
    background: ta.has-hover ? #333333 : transparent;

    clip-src := TextInput {
        visible: false;
        width: 0;
        height: 0;
        single-line: false;
    }
    Timer {
        interval: 1.2s;
        running: root.copied;
        triggered => { root.copied = false; }
    }
    content := HorizontalLayout {
        padding-left: 4px;
        padding-right: 4px;
        spacing: 4px;
        Text {
            text: root.copied ? "✓" : "⧉";
            color: root.copied ? #7fd18a
                : ta.has-hover ? #d8d8d8
                : #8a8a8a;
            font-size: 12px;
            vertical-alignment: center;
        }
        if root.label != "": Text {
            text: root.copied ? "copied" : root.label;
            color: root.copied ? #7fd18a
                : ta.has-hover ? #d8d8d8
                : #8a8a8a;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
    ta := TouchArea {
        clicked => {
            clip-src.text = root.payload;
            clip-src.select-all();
            clip-src.copy();
            clip-src.text = "";
            root.copied = true;
        }
    }
}

// Multiline prompt input. Grows with content up to `max-input-height`
// (then scrolls, keeping the cursor visible); Enter submits, Shift+Enter
// inserts a newline. Built on a raw TextInput because the TextEdit widget
// offers no way to intercept Enter.
component PromptBox inherits Rectangle {
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> text <=> input.text;
    callback submitted(string);

    property <length> pad: 8px;
    property <length> line-height: 18px;
    property <length> max-input-height: 162px; // ~8 lines
    // Desired scroll offset (<= 0); the binding on `input.y` clamps it so
    // shrinking content snaps back into view.
    property <length> scroll-y: 0px;

    height: clamp(input.preferred-height + 2 * root.pad,
        34px, root.max-input-height);
    background: #1d1d1d;
    border-radius: 6px;
    border-width: 1px;
    border-color: input.has-focus ? #3d5a80 : #3a3a3a;

    // Focus the input when the padding area is clicked.
    TouchArea {
        clicked => { input.focus(); }
        mouse-cursor: MouseCursor.text;
    }

    clipper := Rectangle {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        height: parent.height - 2 * root.pad;
        clip: true;

        input := TextInput {
            x: 0;
            y: min(0px, max(root.scroll-y, clipper.height - self.preferred-height));
            width: parent.width;
            height: max(self.preferred-height, clipper.height);
            single-line: false;
            wrap: word-wrap;
            enabled: root.enabled;
            color: root.enabled ? #e0e0e0 : #6a6a6a;
            font-size: 13px;
            selection-background-color: #3d5a80;

            key-pressed(event) => {
                if (event.text == Key.Return && !event.modifiers.shift) {
                    if (self.text != "") {
                        root.submitted(self.text);
                    }
                    return accept;
                }
                return reject;
            }
            cursor-position-changed(pos) => {
                if (pos.y + root.scroll-y < 0) {
                    root.scroll-y = -pos.y;
                } else if (pos.y + root.scroll-y + root.line-height > clipper.height) {
                    root.scroll-y = clipper.height - pos.y - root.line-height;
                }
            }
        }
    }

    if input.text == "": Text {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        text: root.placeholder;
        color: #6a6a6a;
        font-size: 13px;
        overflow: elide;
    }
}

// Drag handle between columns. Dragging integrates mouse deltas into the
// bound width; `direction` is +1 when dragging right grows the column.
component SplitterHandle inherits Rectangle {
    in-out property <length> value;
    in property <int> direction: 1;
    in property <length> min-value: 180px;
    in property <length> max-value: 700px;

    width: 5px;
    background: ta.has-hover || ta.pressed ? #3d5a80 : #242424;

    ta := TouchArea {
        mouse-cursor: col-resize;
        moved => {
            root.value = clamp(
                root.value + (self.mouse-x - self.pressed-x) * root.direction,
                root.min-value, root.max-value);
        }
    }
}

export component AppWindow inherits Window {
    preferred-width: 1400px;
    preferred-height: 900px;
    min-width: 900px;
    min-height: 560px;
    title: "trouve";
    background: #141414;

    // --- layout -------------------------------------------------------------
    in-out property <length> left-width: 260px;
    in-out property <length> right-width: 460px;

    // --- left column ---------------------------------------------------------
    in property <[NavRow]> nav-rows;
    callback nav-row-clicked(int);
    callback new-session();
    /// Open a workspace folder from the file system (native picker).
    callback open-workspace();
    // A markdown link in the chat was clicked; opens in the system browser.
    callback open-link(string);
    /// Start a new session in the workspace at this nav row.
    callback workspace-new-session(int);
    callback open-settings();
    callback session-renamed(/* nav row */ int, /* new title */ string);
    callback session-archived(/* nav row */ int, /* archived */ bool);
    callback session-deleted(/* nav row */ int);

    // Rename/delete modal state (UI-local; -1 = closed).
    in-out property <int> rename-row: -1;
    in-out property <int> delete-row: -1;
    in-out property <string> modal-title: "";

    // --- center column ---------------------------------------------------------
    // 0 chat, 1 new-session screen, 2 new-thread screen
    in property <int> center-screen: 0;

    in property <[ThreadTabItem]> threads;
    in property <int> current-thread: -1;
    callback thread-selected(int);
    callback new-thread();

    in property <[ChatRow]> chat-rows;
    callback approval-resolved(/* row index */ int, /* approved */ bool);
    callback tool-toggled(/* row index */ int);
    callback raw-toggled(/* turn */ int);
    callback send-message(string);
    in property <bool> composer-enabled: false;
    in property <string> status-text: "starting…";
    in-out property <string> error-text: "";

    in property <[string]> modes;
    in property <[string]> models;
    in-out property <int> mode-index: -1;
    in-out property <int> model-index: -1;
    callback composer-mode-changed(int);
    callback composer-model-changed(int);

    // Model knobs, derived from the current model's options schema.
    // Empty thinking-options hides the dropdown; fast-visible gates the
    // fast/priority toggle (Cursor only).
    in property <[string]> thinking-options;
    in-out property <int> thinking-index: -1;
    in property <bool> fast-visible: false;
    in-out property <bool> fast-checked: false;
    // The model always runs in the vendor's Max Mode (extended context at a
    // usage premium); informational, the vendor CLI has no toggle.
    in property <bool> max-mode: false;
    callback composer-thinking-changed(int);
    callback composer-fast-toggled(bool);

    // Session usage + context indicator (composer bar).
    in property <string> usage-text: "";
    in property <float> context-fill: 0.0;
    in property <bool> context-compacting: false;
    in property <string> context-tooltip: "no usage yet";

    // --- new-chat screen -------------------------------------------------------
    in property <[string]> nc-workspaces;
    in property <[string]> nc-branches;
    in-out property <int> nc-workspace-index: -1;
    in-out property <int> nc-branch-index: -1;
    in-out property <int> nc-mode-index: 0;
    in-out property <int> nc-model-index: 0;
    callback nc-workspace-changed(int);
    callback register-workspace-path(string);
    callback start-new-chat(/* ws */ int, /* branch */ int, /* mode */ int,
                            /* model */ int, /* prompt */ string);
    callback cancel-new-chat();

    // --- right column -------------------------------------------------------
    in property <[DiffRow]> diff-rows;
    // Raw unified diff / raw file content backing the views, for copying.
    in property <string> diff-text: "";
    in property <string> open-file-text: "";
    callback diff-file-toggled(int);
    callback refresh-diff();
    callback undo-turn();
    callback redo-turn();

    in property <string> pr-status: "";
    callback create-pr();
    callback refresh-pr();

    in property <string> file-path: ".";
    in property <[FileItem]> file-entries;
    callback file-activated(int);
    callback file-up();
    in property <[[TextSegment]]> file-lines;
    in property <[int]> file-numbers;
    in property <string> open-file-name: "";

    public function scroll-chat-to-end() {
        chat-list.viewport-y = min(0px, chat-list.visible-height - chat-list.viewport-height);
    }

    HorizontalLayout {
        // ---------------- left: sessions ----------------
        Rectangle {
            width: root.left-width;
            background: #1a1a1a;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                HorizontalLayout {
                    Text {
                        text: "Workspaces";
                        color: #e8e8e8;
                        font-size: 15px;
                        font-weight: 700;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Button {
                        text: "+ Open";
                        clicked => { root.open-workspace(); }
                    }
                }

                ListView {
                    vertical-stretch: 1;
                    for row[idx] in root.nav-rows: Rectangle {
                        height: row.kind == 1 ? 52px : row.kind == 0 ? 34px : 30px;
                        background: row.kind == 0
                            ? (row-ta.has-hover ? #2b2b2b : #232323)
                            : row.kind == 1 && row.selected ? #2b3d55 : transparent;
                        border-radius: 6px;

                        row-menu := PopupWindow {
                            x: parent.width - 150px;
                            y: 28px;
                            width: 150px;
                            height: 100px;
                            Rectangle {
                                background: #262626;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: #3a3a3a;
                                VerticalLayout {
                                    padding: 4px;
                                    Rectangle {
                                        height: 30px;
                                        background: rename-ta.has-hover ? #2b3d55 : transparent;
                                        border-radius: 4px;
                                        rename-ta := TouchArea {
                                            clicked => {
                                                root.modal-title = row.title;
                                                root.rename-row = idx;
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            text: "Rename";
                                            color: #d8d8d8;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        height: 30px;
                                        background: archive-ta.has-hover ? #2b3d55 : transparent;
                                        border-radius: 4px;
                                        archive-ta := TouchArea {
                                            clicked => {
                                                root.session-archived(idx, !row.archived);
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            text: row.archived ? "Unarchive" : "Archive";
                                            color: #d8d8d8;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        height: 30px;
                                        background: delete-ta.has-hover ? #6b2b33 : transparent;
                                        border-radius: 4px;
                                        delete-ta := TouchArea {
                                            clicked => {
                                                root.modal-title = row.title;
                                                root.delete-row = idx;
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            text: "Delete…";
                                            color: #e39ea6;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }

                        row-ta := TouchArea {
                            clicked => { root.nav-row-clicked(idx); }
                        }

                        // Workspace header: chevron + name, "+" starts a
                        // session in this workspace. Clicking elsewhere
                        // collapses/expands the group.
                        if row.kind == 0: HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 4px;
                            spacing: 6px;
                            Text {
                                text: row.expanded ? "⌄" : "›";
                                color: #8a8a8a;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: row.title;
                                color: #d8d8d8;
                                font-size: 13px;
                                font-weight: 700;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                            Rectangle {
                                width: 26px;
                                height: 26px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 5px;
                                background: plus-ta.has-hover ? #3a3a3a : transparent;
                                plus-ta := TouchArea {
                                    clicked => { root.workspace-new-session(idx); }
                                }
                                Text {
                                    text: "+";
                                    color: plus-ta.has-hover ? #e8e8e8 : #8a8a8a;
                                    font-size: 15px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: 100%;
                                    height: 100%;
                                }
                            }
                        }

                        // Session row.
                        if row.kind == 1: HorizontalLayout {
                            padding-left: 22px;
                            padding-right: 4px;
                            VerticalLayout {
                                padding-top: 8px;
                                spacing: 2px;
                                horizontal-stretch: 1;
                                Text {
                                    text: row.title;
                                    color: row.archived ? #8a8a8a : #e0e0e0;
                                    font-size: 13px;
                                    overflow: elide;
                                }
                                Text {
                                    text: row.subtitle;
                                    color: #8a8a8a;
                                    font-size: 11px;
                                    overflow: elide;
                                }
                            }
                            Rectangle {
                                width: 26px;
                                menu-ta := TouchArea {
                                    clicked => { row-menu.show(); }
                                }
                                Text {
                                    text: "⋯";
                                    color: menu-ta.has-hover ? #e0e0e0 : #6a6a6a;
                                    font-size: 15px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: 100%;
                                    height: 100%;
                                }
                            }
                        }

                        // Archived-group toggle.
                        if row.kind == 2: Text {
                            x: 22px;
                            text: (row.expanded ? "▾ " : "▸ ") + row.title;
                            color: #7a7a7a;
                            font-size: 11px;
                            vertical-alignment: center;
                            height: 100%;
                        }
                    }
                }

                // Footer: settings + status.
                HorizontalLayout {
                    spacing: 6px;
                    Button {
                        text: "⚙ Settings";
                        clicked => { root.open-settings(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
                Text {
                    text: root.status-text;
                    color: #7a7a7a;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }
        }

        SplitterHandle {
            value <=> root.left-width;
            direction: 1;
            min-value: 190px;
            max-value: 460px;
        }

        // ---------------- center ----------------
        Rectangle {
            horizontal-stretch: 1;
            background: #141414;

            // ----- chat screen (kept in the tree so scroll-chat-to-end can
            // reach the list; hidden while a new-chat screen is up) -----
            VerticalLayout {
                visible: root.center-screen == 0;
                padding: 10px;
                spacing: 8px;

                // Error banner.
                if root.error-text != "": Rectangle {
                    background: #4a2328;
                    border-radius: 6px;
                    height: banner.preferred-height + 12px;
                    banner := HorizontalLayout {
                        padding: 6px;
                        padding-left: 10px;
                        spacing: 8px;
                        Text {
                            text: root.error-text;
                            color: #f2c4ca;
                            font-size: 12px;
                            wrap: word-wrap;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "✕";
                            clicked => { root.error-text = ""; }
                        }
                    }
                }

                // Thread tabs.
                HorizontalLayout {
                    spacing: 6px;
                    for thread[idx] in root.threads: Rectangle {
                        width: 130px;
                        height: 30px;
                        background: idx == root.current-thread ? #2b3d55 : #222222;
                        border-radius: 6px;
                        TouchArea {
                            clicked => { root.thread-selected(idx); }
                        }
                        Text {
                            text: thread.label;
                            color: #d8d8d8;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                            width: parent.width - 12px;
                            x: 6px;
                        }
                    }
                    Button {
                        text: "+";
                        enabled: root.threads.length > 0 || root.composer-enabled;
                        clicked => { root.new-thread(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }

                // Chat stream.
                chat-list := ListView {
                    vertical-stretch: 1;

                    for row[idx] in root.chat-rows: Rectangle {
                        // Markdown rows manage their own vertical rhythm via
                        // padding (lists tight, paragraphs spaced, headings
                        // set off); boxed rows keep a fixed gap.
                        height: row-content.preferred-height
                            + (row.kind == 1 && row.md-kind != 5 ? 0px : 10px);
                        background: row.kind == 0 ? #20293a
                            : row.kind == 2 ? #1d1d1d
                            // Lighter than the panel (#141414) so the block
                            // reads as a slab, not just an outline.
                            : row.kind == 1 && row.md-kind == 5 ? #1f2226
                            : row.kind == 6 ? #17191c
                            : transparent;
                        border-radius: 6px;
                        border-width: (row.kind == 1 && row.md-kind == 5)
                            || row.kind == 6 ? 1px : 0px;
                        border-color: row.kind == 6 ? #2a2d31 : #35393f;

                        property <bool> md-list: row.kind == 1
                            && (row.md-kind == 4 || row.md-kind == 6);
                        property <bool> md-heading: row.kind == 1
                            && row.md-kind >= 1 && row.md-kind <= 3;

                        row-content := VerticalLayout {
                            padding: 6px;
                            padding-top: md-list ? 2px : md-heading ? 14px : 6px;
                            padding-bottom: md-list ? 2px : md-heading ? 4px : 6px;
                            padding-left: md-list ? 22px + row.md-indent * 18px : 10px;
                            spacing: 4px;

                            // User message: selectable, copy button top-right.
                            if row.kind == 0: HorizontalLayout {
                                spacing: 6px;
                                TextInput {
                                    text: row.text;
                                    read-only: true;
                                    single-line: false;
                                    color: #dbe6f5;
                                    font-size: 14px;
                                    wrap: word-wrap;
                                    selection-background-color: #3d5a80;
                                    horizontal-stretch: 1;
                                }
                                VerticalLayout {
                                    alignment: start;
                                    CopyButton { payload: row.text; }
                                }
                            }

                            // Markdown block: code fences render as
                            // selectable monospace text under a header
                            // (language label + copy); everything else
                            // renders inline markup through StyledText.
                            if row.kind == 1 && row.md-kind == 5: HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    text: row.md-lang;
                                    color: #6f6f6f;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                CopyButton { payload: row.text; }
                            }
                            if row.kind == 1 && row.md-kind == 5: TextInput {
                                text: row.text;
                                read-only: true;
                                single-line: false;
                                color: #d8d8c8;
                                wrap: word-wrap;
                                font-size: 13px;
                                font-family: "monospace";
                                selection-background-color: #3d5a80;
                            }
                            if row.kind == 1 && row.md-kind != 5: StyledText {
                                text: row.styled;
                                default-color: #d4d4d4;
                                link-color: #6fa8dc;
                                default-font-size: row.md-kind == 1 ? 22px
                                    : row.md-kind == 2 ? 19px
                                    : row.md-kind == 3 ? 16px
                                    : 14px;
                                link-clicked(url) => { root.open-link(url); }
                            }

                            // Tool card header.
                            if row.kind == 2: HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: row.tool-status == 0 ? "⏸"
                                        : row.tool-status == 1 ? "▶"
                                        : row.tool-status == 2 ? "✓"
                                        : row.tool-status == 4 ? "⊘"
                                        : "✗";
                                    color: row.tool-status == 2 ? #7fd18a
                                        : row.tool-status == 0 ? #e5c07b
                                        : row.tool-status == 1 ? #9cbdde
                                        : #e39ea6;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.tool-name;
                                    color: #e0e0e0;
                                    font-size: 13px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.expanded ? "hide details" : "details";
                                    color: #6fa8dc;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    TouchArea {
                                        clicked => { root.tool-toggled(idx); }
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                                CopyButton { payload: row.detail; }
                                if row.tool-status == 0: Button {
                                    text: "Approve";
                                    primary: true;
                                    clicked => { root.approval-resolved(idx, true); }
                                }
                                if row.tool-status == 0: Button {
                                    text: "Deny";
                                    clicked => { root.approval-resolved(idx, false); }
                                }
                            }

                            // Tool card detail.
                            if row.kind == 2 && row.expanded: TextInput {
                                text: row.detail;
                                read-only: true;
                                single-line: false;
                                color: #a8a8a8;
                                font-size: 12px;
                                font-family: "monospace";
                                wrap: word-wrap;
                                selection-background-color: #3d5a80;
                            }

                            // Turn status; `detail` carries the turn's full
                            // assistant response for one-click copying.
                            if row.kind == 3: HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: row.text;
                                    color: row.turn-state == 2 ? #e39ea6 : #7a7a7a;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                                if row.detail != "": CopyButton {
                                    payload: row.detail;
                                    label: "copy response";
                                }
                                // Swap the turn's styled markdown for one
                                // selectable plain-text block and back.
                                if row.detail != "": Text {
                                    text: row.raw ? "styled view" : "select text";
                                    color: #6fa8dc;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    TouchArea {
                                        clicked => { root.raw-toggled(row.turn); }
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }

                            // Raw response text: the turn's markdown source
                            // as one fully selectable block.
                            if row.kind == 6: TextInput {
                                text: row.text;
                                read-only: true;
                                single-line: false;
                                color: #d4d4d4;
                                font-size: 13px;
                                wrap: word-wrap;
                                selection-background-color: #3d5a80;
                            }

                            // Model thinking (reasoning stream).
                            if row.kind == 4: TextInput {
                                text: row.text;
                                read-only: true;
                                single-line: false;
                                color: #8f8f8f;
                                font-size: 13px;
                                font-italic: true;
                                wrap: word-wrap;
                                selection-background-color: #3d5a80;
                            }

                            // Activity: indeterminate spinner + label while
                            // the agent works ("Processing…"/"Thinking…").
                            if row.kind == 5: HorizontalLayout {
                                spacing: 8px;
                                Rectangle {
                                    width: 16px;
                                    height: 16px;
                                    Spinner {
                                        width: 16px;
                                        height: 16px;
                                        indeterminate: true;
                                    }
                                }
                                Text {
                                    text: row.text;
                                    color: #9a9a9a;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }
                        }
                    }
                }

                // Composer: multiline prompt on top (grows with content),
                // then a controls row — pickers, model knobs, send, dial.
                VerticalLayout {
                    spacing: 6px;

                    composer := PromptBox {
                        placeholder: root.composer-enabled
                            ? "Message the agent…  (Shift+Enter for a new line)"
                            : "Select or create a thread first";
                        enabled: root.composer-enabled;
                        submitted(text) => {
                            root.send-message(text);
                            self.text = "";
                        }
                    }

                    HorizontalLayout {
                    spacing: 8px;
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "Mode"; color: #7a7a7a; font-size: 10px; }
                        DropUpPicker {
                            width: 130px;
                            options: root.modes;
                            current-index <=> root.mode-index;
                            enabled: root.composer-enabled;
                            placeholder: "mode";
                            changed(i) => { root.composer-mode-changed(i); }
                        }
                    }
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "Model"; color: #7a7a7a; font-size: 10px; }
                        DropUpPicker {
                            width: 210px;
                            options: root.models;
                            current-index <=> root.model-index;
                            enabled: root.composer-enabled;
                            placeholder: "model";
                            changed(i) => { root.composer-model-changed(i); }
                        }
                    }
                    if root.thinking-options.length > 0: VerticalLayout {
                        spacing: 2px;
                        Text { text: "Thinking"; color: #7a7a7a; font-size: 10px; }
                        DropUpPicker {
                            width: 110px;
                            options: root.thinking-options;
                            current-index <=> root.thinking-index;
                            enabled: root.composer-enabled;
                            placeholder: "thinking";
                            changed(i) => { root.composer-thinking-changed(i); }
                        }
                    }
                    if root.max-mode: VerticalLayout {
                        spacing: 2px;
                        Text { text: "Context"; color: #7a7a7a; font-size: 10px; }
                        Rectangle {
                            width: 92px;
                            height: 30px;
                            background: #3a2e1a;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #6a5426;
                            Text {
                                text: "Max · +20%";
                                color: #d9b96a;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    if root.fast-visible: VerticalLayout {
                        spacing: 2px;
                        Text { text: "Fast"; color: #7a7a7a; font-size: 10px; }
                        Rectangle {
                            width: 44px;
                            height: 30px;
                            background: root.fast-checked ? #2b3d55 : #222222;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: root.fast-checked ? #4a6a97 : #3a3a3a;
                            TouchArea {
                                enabled: root.composer-enabled;
                                clicked => {
                                    root.fast-checked = !root.fast-checked;
                                    root.composer-fast-toggled(root.fast-checked);
                                }
                            }
                            Text {
                                text: root.fast-checked ? "On" : "Off";
                                color: root.fast-checked ? #dbe6f5 : #8a8a8a;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: " "; font-size: 10px; }
                        Button {
                            text: "Send";
                            primary: true;
                            enabled: root.composer-enabled && composer.text != "";
                            clicked => {
                                root.send-message(composer.text);
                                composer.text = "";
                            }
                        }
                    }
                    // Context usage dial; indeterminate while compacting.
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: " "; font-size: 10px; }
                    dial := Rectangle {
                        width: 30px;
                        height: 30px;
                        Spinner {
                            width: 26px;
                            height: 26px;
                            x: 2px;
                            y: 2px;
                            progress: root.context-fill;
                            indeterminate: root.context-compacting;
                        }
                        dial-ta := TouchArea { }
                        if dial-ta.has-hover: Rectangle {
                            x: dial.width - self.width;
                            y: -self.height - 6px;
                            width: min(tooltip-text.preferred-width + 16px, 340px);
                            height: tooltip-text.preferred-height + 12px;
                            background: #262626;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #3a3a3a;
                            tooltip-text := Text {
                                x: 8px;
                                y: 6px;
                                width: parent.width - 16px;
                                text: root.context-compacting
                                    ? "compacting context…\n" + root.context-tooltip
                                    : root.context-tooltip;
                                color: #d8d8d8;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }
                    }
                    Text {
                        text: root.usage-text;
                        color: #8a8a8a;
                        font-size: 11px;
                        vertical-alignment: center;
                        max-width: 190px;
                        overflow: elide;
                    }
                    }
                }
            }

            // ----- new-chat screen (new session / new thread) -----
            if root.center-screen != 0: VerticalLayout {
                padding: 40px;
                spacing: 14px;
                alignment: center;

                Text {
                    text: root.center-screen == 1 ? "New session" : "New thread";
                    color: #e8e8e8;
                    font-size: 22px;
                    font-weight: 700;
                }
                Text {
                    text: root.center-screen == 1
                        ? "Pick where to work, what to branch from, and how the agent should run."
                        : "Threads share the session worktree; pick the agent setup for this one.";
                    color: #9a9a9a;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                if root.center-screen == 1: VerticalLayout {
                    spacing: 6px;
                    Text { text: "Workspace"; color: #c8c8c8; font-size: 12px; font-weight: 700; }
                    ComboBox {
                        model: root.nc-workspaces;
                        current-index <=> root.nc-workspace-index;
                        selected => { root.nc-workspace-changed(self.current-index); }
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        ws-path := LineEdit {
                            horizontal-stretch: 1;
                            placeholder-text: "…or register a git repo by absolute path";
                        }
                        Button {
                            text: "Add";
                            enabled: ws-path.text != "";
                            clicked => {
                                root.register-workspace-path(ws-path.text);
                                ws-path.text = "";
                            }
                        }
                    }
                }

                if root.center-screen == 1: VerticalLayout {
                    spacing: 6px;
                    Text { text: "Base branch"; color: #c8c8c8; font-size: 12px; font-weight: 700; }
                    ComboBox {
                        model: root.nc-branches;
                        current-index <=> root.nc-branch-index;
                    }
                }

                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        spacing: 6px;
                        horizontal-stretch: 1;
                        Text { text: "Agent mode"; color: #c8c8c8; font-size: 12px; font-weight: 700; }
                        ComboBox {
                            model: root.modes;
                            current-index <=> root.nc-mode-index;
                        }
                    }
                    VerticalLayout {
                        spacing: 6px;
                        horizontal-stretch: 1;
                        Text { text: "Model"; color: #c8c8c8; font-size: 12px; font-weight: 700; }
                        ComboBox {
                            model: root.models;
                            current-index <=> root.nc-model-index;
                        }
                    }
                }

                VerticalLayout {
                    spacing: 6px;
                    Text { text: "First message"; color: #c8c8c8; font-size: 12px; font-weight: 700; }
                    prompt-edit := PromptBox {
                        placeholder: "What should the agent do?  (Shift+Enter for a new line)";
                        submitted(text) => {
                            if (root.center-screen == 2 || root.nc-workspace-index >= 0) {
                                root.start-new-chat(
                                    root.nc-workspace-index, root.nc-branch-index,
                                    root.nc-mode-index, root.nc-model-index, text);
                                self.text = "";
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Button {
                        text: root.center-screen == 1 ? "Start session" : "Start thread";
                        primary: true;
                        enabled: prompt-edit.text != ""
                            && (root.center-screen == 2 || root.nc-workspace-index >= 0);
                        clicked => {
                            root.start-new-chat(
                                root.nc-workspace-index, root.nc-branch-index,
                                root.nc-mode-index, root.nc-model-index, prompt-edit.text);
                            prompt-edit.text = "";
                        }
                    }
                    Button {
                        text: "Cancel";
                        clicked => { root.cancel-new-chat(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
                if root.error-text != "" : Text {
                    text: root.error-text;
                    color: #e39ea6;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }

        SplitterHandle {
            value <=> root.right-width;
            direction: -1;
            min-value: 280px;
            max-value: 800px;
        }

        // ---------------- right: inspection ----------------
        Rectangle {
            width: root.right-width;
            background: #181818;

            TabWidget {
                Tab {
                    title: "Diff";
                    VerticalLayout {
                        padding: 6px;
                        spacing: 6px;
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: "Refresh diff";
                                clicked => { root.refresh-diff(); }
                            }
                            Button {
                                text: "↶ Undo turn";
                                clicked => { root.undo-turn(); }
                            }
                            Button {
                                text: "↷ Redo";
                                clicked => { root.redo-turn(); }
                            }
                            if root.diff-text != "": VerticalLayout {
                                alignment: center;
                                CopyButton {
                                    payload: root.diff-text;
                                    label: "copy diff";
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Button {
                                text: "Create PR";
                                clicked => { root.create-pr(); }
                            }
                            Button {
                                text: "PR status";
                                clicked => { root.refresh-pr(); }
                            }
                        }
                        if root.pr-status != "": Text {
                            text: root.pr-status;
                            color: #9cbdde;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                        DiffView {
                            vertical-stretch: 1;
                            rows: root.diff-rows;
                            file-toggled(i) => { root.diff-file-toggled(i); }
                        }
                    }
                }
                Tab {
                    title: "Files";
                    VerticalLayout {
                        padding: 6px;
                        spacing: 6px;
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: "↑ Up";
                                clicked => { root.file-up(); }
                            }
                            Text {
                                text: root.file-path;
                                color: #9a9a9a;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                        }
                        ListView {
                            height: 180px;
                            for entry[idx] in root.file-entries: Rectangle {
                                height: 24px;
                                TouchArea {
                                    clicked => { root.file-activated(idx); }
                                }
                                Text {
                                    x: 6px;
                                    text: (entry.is-dir ? "📁 " : "📄 ") + entry.name;
                                    color: #d0d0d0;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Text {
                                text: root.open-file-name;
                                color: #9a9a9a;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                            if root.open-file-text != "": CopyButton {
                                payload: root.open-file-text;
                                label: "copy file";
                            }
                        }
                        CodeView {
                            vertical-stretch: 1;
                            lines: root.file-lines;
                            line-numbers: root.file-numbers;
                        }
                    }
                }
            }
        }
    }

    // ---------------- modal overlays (rename / delete) ----------------
    if root.rename-row >= 0 || root.delete-row >= 0: Rectangle {
        width: 100%;
        height: 100%;
        background: #000000aa;
        TouchArea { } // swallow clicks behind the modal

        Rectangle {
            width: 380px;
            height: modal-layout.preferred-height + 32px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #232323;
            border-radius: 8px;
            border-width: 1px;
            border-color: #3a3a3a;

            modal-layout := VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: root.rename-row >= 0
                        ? "Rename session"
                        : "Delete session \"" + root.modal-title + "\"?";
                    color: #e8e8e8;
                    font-size: 15px;
                    font-weight: 700;
                    wrap: word-wrap;
                }

                if root.rename-row >= 0: LineEdit {
                    text <=> root.modal-title;
                    placeholder-text: "Session title";
                    accepted(text) => {
                        if (text != "") {
                            root.session-renamed(root.rename-row, text);
                            root.rename-row = -1;
                        }
                    }
                }

                if root.delete-row >= 0: Text {
                    text: "This removes the session's worktree, branch history in trouve, and its event log. The git branch itself is kept.";
                    color: #9a9a9a;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: "Cancel";
                        clicked => {
                            root.rename-row = -1;
                            root.delete-row = -1;
                        }
                    }
                    if root.rename-row >= 0: Button {
                        text: "Rename";
                        primary: true;
                        clicked => {
                            root.session-renamed(root.rename-row, root.modal-title);
                            root.rename-row = -1;
                        }
                    }
                    if root.delete-row >= 0: Button {
                        text: "Delete";
                        primary: true;
                        clicked => {
                            root.session-deleted(root.delete-row);
                            root.delete-row = -1;
                        }
                    }
                }
            }
        }
    }
}
