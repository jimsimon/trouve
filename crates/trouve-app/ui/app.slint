// trouve desktop: three-column layout.
//   left   — sessions grouped by workspace, settings footer
//   center — thread tabs, chat stream, composer (or the new-chat screen)
//   right  — inspection tabs (Diff / Files)
//
// The window is intentionally dumb: models in, callbacks out. All state
// folding happens in Rust (client-core view models + the app controller).

import {
    Button, ComboBox, LineEdit, ListView, Spinner, TabWidget
} from "std-widgets.slint";
import { DiffView, DiffRow } from "diff-view.slint";
import { CodeView, TextSegment } from "code-view.slint";
import {
    SettingsScreen, ProviderItem, CliItem, KnownProviderItem
} from "settings-window.slint";
import { ScrollKeys } from "scroll-keys.slint";
import { Theme, ThemePalette } from "theme.slint";
import { Palette } from "std-widgets.slint";

// Theme re-exported so Rust can push the selected palette.
export { DiffRow, TextSegment, ProviderItem, CliItem, KnownProviderItem }
export { Theme, ThemePalette }

// One row of the left nav: workspace headers, sessions, archived toggles.
export struct NavRow {
    // 0 workspace header, 1 session, 2 archived-group toggle
    kind: int,
    title: string,
    subtitle: string,
    // For kind 1: stable index the controller maps back to a session.
    session-index: int,
    selected: bool,
    archived: bool,
    expanded: bool,
}

export struct ThreadTabItem {
    id: string,
    label: string,
}

// One selectable option in a question-wizard page.
export struct QOption {
    label: string,
    selected: bool,
}

// One prompt/answer line on the wizard's review page or answered summary.
export struct QPair {
    prompt: string,
    answer: string,
}

export struct ChatRow {
    // 0 user, 1 markdown block, 2 tool card, 3 turn status,
    // 4 thinking, 5 activity (spinner + label),
    // 6 raw response text (selectable markdown source)
    kind: int,
    // For kind 1: 0 paragraph, 1 h1, 2 h2, 3 h3, 4 bullet, 5 code fence,
    // 6 numbered list item.
    md-kind: int,
    // List nesting level for md-kind 4/6 (0 = top level).
    md-indent: int,
    // Language tag for code fences ("rust"; empty when untagged).
    md-lang: string,
    text: string,
    // For kind 1, non-code blocks: `text` with inline markup resolved
    // (bold/italic/inline code/links), built via StyledText::from_markdown.
    styled: styled-text,
    // For kind 1 code fences: syntax-highlight segments, one entry per line.
    code-lines: [[TextSegment]],
    // Text tint for markdown rows: 0 agent (default), 1 user prompt,
    // 2 thinking.
    tone: int,
    // Tool-card fields (kind 2).
    tool-name: string,
    // Read-style tools: the file path argument; `text` holds the basename
    // shown (and clickable) in the header.
    tool-file: string,
    // Read-style tools: the 1-based line range read (0 = whole file);
    // shown as "L123-456" and preselected when the file is opened.
    tool-line-from: int,
    tool-line-to: int,
    // Edit-style tools: "+x"/"−y" header badges (empty hides them) and
    // the line diff shown as the expanded body instead of `detail`.
    tool-adds: string,
    tool-dels: string,
    tool-diff: [DiffRow],
    // Whether the diff carries file line numbers (shows the gutter).
    tool-diff-numbered: bool,
    // 0 awaiting approval, 1 running, 2 ok, 3 error, 4 denied, 5 aborted
    tool-status: int,
    detail: string,
    expanded: bool,
    // Turn-status fields (kind 3): 0 running, 1 completed, 2 failed.
    turn-state: int,
    // Turn number (kind 3), for per-turn actions like the raw-view toggle.
    turn: int,
    // Kind 3: this turn's response is currently shown as raw text.
    raw: bool,
    // Kind 7 (card header): stable collapse-toggle key.
    card-key: string,
    // Assistant headers: token/cost summary once the turn completed.
    meta: string,
    // Agent headers: dimmed model tag ("(cursor/claude-fable-5)").
    subtitle: string,
    // Position in a collapsible card outline: 0 none, 1 header (body
    // follows), 2 body, 3 last body row, 4 standalone header.
    card-pos: int,
    // First body row of its card (slab rows pad down from the header).
    card-first: bool,
    // Question wizard (kind 10). `text` holds the title, `meta` the page
    // label ("Question 1 of 3" / "Review your answers" / "Answered").
    q-prompt: string,
    q-options: [QOption],
    // Checkbox-style question (multiple selections allowed).
    q-multi: bool,
    // The trailing "Other" free-form choice: selected flag + its text.
    q-other: bool,
    q-other-text: string,
    // Review page (pending) or answered summary (done).
    q-review: bool,
    q-done: bool,
    q-summary: [QPair],
    q-can-back: bool,
    q-can-next: bool,
    // Last question page ("Review" button) vs earlier ones ("Next").
    q-last: bool,
}

// One visible row of the Files tree, pre-flattened by the controller:
// folders carry an expanded flag, depth drives the indent.
export struct FileItem {
    name: string,
    is-dir: bool,
    depth: int,
    expanded: bool,
}

// A ComboBox stand-in whose option list opens *above* the control, for use
// at the bottom edge of the window where a downward popup would be clipped.
component DropUpPicker inherits Rectangle {
    in property <[string]> options;
    in-out property <int> current-index: -1;
    in property <bool> enabled: true;
    in property <string> placeholder: "select…";
    callback changed(int);

    height: Theme.fs(30px);
    background: Theme.c.control-bg;
    border-radius: 6px;

    popup := PopupWindow {
        x: 0;
        y: -min(root.options.length, 10) * Theme.fs(28px) - 8px;
        width: max(root.width, 260px);
        height: min(root.options.length, 10) * Theme.fs(28px) + 2px;

        Rectangle {
            background: Theme.c.popup-bg;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.c.border;
            ListView {
                for option[idx] in root.options: Rectangle {
                    height: Theme.fs(28px);
                    background: idx == root.current-index ? Theme.c.accent-bg : transparent;
                    TouchArea {
                        clicked => {
                            root.current-index = idx;
                            root.changed(idx);
                        }
                    }
                    Text {
                        x: 8px;
                        width: parent.width - 16px;
                        text: option;
                        color: Theme.c.text;
                        font-size: Theme.fs(12px);
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }
    }

    TouchArea {
        enabled: root.enabled;
        clicked => { popup.show(); }
    }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.current-index >= 0 && root.current-index < root.options.length
                ? root.options[root.current-index]
                : root.placeholder;
            color: root.enabled ? Theme.c.text : Theme.c.text-disabled;
            font-size: Theme.fs(12px);
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        Text {
            text: "▴";
            color: Theme.c.text-soft;
            font-size: Theme.fs(10px);
            vertical-alignment: center;
        }
    }
}

// Model picker with a fuzzy-search box. The filtering itself runs in Rust
// (`filter-edited` out, `matches` back in: indices into `options`, best
// match first), so the popup just renders whatever the harness returns.
component SearchPicker inherits Rectangle {
    in property <[string]> options;
    in-out property <int> current-index: -1;
    in property <bool> enabled: true;
    in property <string> placeholder: "select…";
    // Open upward (composer) or downward (forms).
    in property <bool> up: true;
    in property <[int]> matches;
    callback changed(int);
    callback filter-edited(string);

    in-out property <string> query: "";
    property <length> list-h: max(min(root.matches.length, 10), 1) * Theme.fs(28px);
    property <length> popup-h: list-h + 40px;

    height: Theme.fs(30px);
    background: Theme.c.control-bg;
    border-radius: 6px;

    popup := PopupWindow {
        close-policy: close-on-click-outside;
        x: 0;
        y: root.up ? -root.popup-h - 8px : root.height + 4px;
        width: max(root.width, 260px);
        height: root.popup-h;

        Rectangle {
            background: Theme.c.popup-bg;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.c.border;
            VerticalLayout {
                padding: 4px;
                spacing: 4px;
                search := LineEdit {
                    height: Theme.fs(28px);
                    font-size: Theme.fs(12px);
                    placeholder-text: "Search models…";
                    text <=> root.query;
                    init => { self.focus(); }
                    edited => { root.filter-edited(self.text); }
                    // Enter picks the top match.
                    accepted => {
                        if (root.matches.length > 0) {
                            root.current-index = root.matches[0];
                            root.changed(root.matches[0]);
                            popup.close();
                        }
                    }
                }
                if root.matches.length == 0: Rectangle {
                    height: Theme.fs(28px);
                    Text {
                        x: 8px;
                        text: "no matches";
                        color: Theme.c.text-disabled;
                        font-size: Theme.fs(12px);
                        vertical-alignment: center;
                    }
                }
                ListView {
                    for oi[k] in root.matches: Rectangle {
                        height: Theme.fs(28px);
                        background: oi == root.current-index ? Theme.c.accent-bg
                            : opt-ta.has-hover ? Theme.c.hover-bg : transparent;
                        opt-ta := TouchArea {
                            clicked => {
                                root.current-index = oi;
                                root.changed(oi);
                                popup.close();
                            }
                        }
                        Text {
                            x: 8px;
                            width: parent.width - 16px;
                            text: root.options[oi];
                            color: Theme.c.text;
                            font-size: Theme.fs(12px);
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
            }
        }
    }

    TouchArea {
        enabled: root.enabled;
        clicked => {
            // Fresh filter on every open.
            root.query = "";
            root.filter-edited("");
            popup.show();
        }
    }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.current-index >= 0 && root.current-index < root.options.length
                ? root.options[root.current-index]
                : root.placeholder;
            color: root.enabled ? Theme.c.text : Theme.c.text-disabled;
            font-size: Theme.fs(12px);
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        Text {
            text: root.up ? "▴" : "▾";
            color: Theme.c.text-soft;
            font-size: Theme.fs(10px);
            vertical-alignment: center;
        }
    }
}

// Shared tooltip state. Icon buttons arm it on hover/focus with their
// window position; the AppWindow overlay shows it after a short delay.
// `show` hands the caller a token and `unshow` only clears while that
// token is current, so crossing from one button straight onto another
// can't hide the new tooltip. `hide-all` force-clears (list scrolling can
// move or recycle a hovered button without a hover-out event, which would
// otherwise strand the tooltip).
global Tip {
    in-out property <string> text;
    in-out property <length> tip-x;
    in-out property <length> tip-y;
    in-out property <bool> armed;
    in-out property <bool> shown;
    in-out property <int> seq: 0;
    public function show(x: length, y: length, t: string) -> int {
        self.text = t;
        self.tip-x = x;
        self.tip-y = y;
        self.armed = true;
        self.seq += 1;
        return self.seq;
    }
    public function unshow(token: int) {
        if (token == self.seq) {
            self.armed = false;
            self.shown = false;
        }
    }
    public function hide-all() {
        self.armed = false;
        self.shown = false;
    }
}

// Plain glyph button: hover highlight, tooltip on hover/focus, and
// keyboard activation (Tab to focus, Enter/Space to click).
component IconButton inherits Rectangle {
    in property <string> icon;
    in property <string> tip;
    in property <bool> enabled: true;
    in property <length> icon-size: Theme.fs(12px);
    in property <color> icon-color: Theme.c.text-soft;
    in property <color> hover-icon-color: Theme.c.text-hi;
    in property <color> idle-bg: transparent;
    in property <color> hover-bg: Theme.c.border;
    callback clicked;

    width: Theme.fs(22px);
    height: Theme.fs(18px);
    border-radius: 4px;
    background: ta.has-hover && root.enabled ? root.hover-bg : root.idle-bg;
    border-width: fs.has-focus ? 1px : 0px;
    border-color: Theme.c.accent;

    property <int> tip-token: -1;
    function tip-changed(on: bool) {
        if (on) {
            root.tip-token = Tip.show(root.absolute-position.x,
                root.absolute-position.y + root.height + 4px, root.tip);
        } else {
            Tip.unshow(root.tip-token);
        }
    }
    fs := FocusScope {
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == " ") {
                root.clicked();
                return accept;
            }
            return reject;
        }
        changed has-focus => { root.tip-changed(self.has-focus); }
    }
    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        changed has-hover => { root.tip-changed(self.has-hover); }
    }
    Text {
        width: 100%;
        height: 100%;
        text: root.icon;
        color: !root.enabled ? Theme.c.text-ghost
            : ta.has-hover ? root.hover-icon-color
            : root.icon-color;
        font-size: root.icon-size;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// Compact text pill button, sized to fit inside 18px-tall card headers
// (the standard Button towers over them).
component PillButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    callback clicked;

    width: pill-label.preferred-width + 16px;
    height: Theme.fs(18px);
    border-radius: 4px;
    background: !root.enabled ? Theme.c.popup-bg
        : root.primary
        ? (pill-ta.has-hover ? Theme.c.primary-hover : Theme.c.primary-bg)
        : (pill-ta.has-hover ? Theme.c.border : Theme.c.pill-bg);
    border-width: 1px;
    border-color: !root.enabled ? Theme.c.border : root.primary ? Theme.c.primary-border : Theme.c.border-strong;

    pill-label := Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: !root.enabled ? Theme.c.text-disabled : root.primary ? Theme.c.on-accent : Theme.c.text-mid;
        font-size: Theme.fs(11px);
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    pill-ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }
}

// Clipboard button: copies `payload` on click and flashes a checkmark.
// Self-contained — the hidden TextInput reaches the system clipboard through
// its built-in select-all/copy functions, so no native plumbing is needed.
component CopyButton inherits Rectangle {
    in property <string> payload;
    // Optional label rendered next to the icon ("copy response").
    in property <string> label: "";
    in property <string> tip: "Copy";
    property <bool> copied: false;

    height: Theme.fs(22px);
    width: content.preferred-width;
    border-radius: 4px;
    background: ta.has-hover ? Theme.c.hover-strong : transparent;
    border-width: fs.has-focus ? 1px : 0px;
    border-color: Theme.c.accent;

    function do-copy() {
        clip-src.text = root.payload;
        clip-src.select-all();
        clip-src.copy();
        clip-src.text = "";
        root.copied = true;
    }
    property <int> tip-token: -1;
    function tip-changed(on: bool) {
        if (on) {
            root.tip-token = Tip.show(root.absolute-position.x,
                root.absolute-position.y + root.height + 4px, root.tip);
        } else {
            Tip.unshow(root.tip-token);
        }
    }

    clip-src := TextInput {
        visible: false;
        width: 0;
        height: 0;
        single-line: false;
    }
    Timer {
        interval: 1.2s;
        running: root.copied;
        triggered => { root.copied = false; }
    }
    content := HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 4px;
        Text {
            text: root.copied ? "✓" : "⧉";
            color: root.copied ? Theme.c.ok
                : ta.has-hover ? Theme.c.text
                : Theme.c.text-soft;
            font-size: Theme.fs(12px);
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        if root.label != "": Text {
            text: root.copied ? "copied" : root.label;
            color: root.copied ? Theme.c.ok
                : ta.has-hover ? Theme.c.text
                : Theme.c.text-soft;
            font-size: Theme.fs(11px);
            vertical-alignment: center;
        }
    }
    fs := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == " ") {
                root.do-copy();
                return accept;
            }
            return reject;
        }
        changed has-focus => { root.tip-changed(self.has-focus); }
    }
    ta := TouchArea {
        clicked => { root.do-copy(); }
        changed has-hover => { root.tip-changed(self.has-hover); }
    }
}

// Multiline prompt input. Grows with content up to `max-input-height`
// (then scrolls, keeping the cursor visible); Enter submits, Shift+Enter
// inserts a newline. Built on a raw TextInput because the TextEdit widget
// offers no way to intercept Enter.
component PromptBox inherits Rectangle {
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> text <=> input.text;
    callback submitted(string);
    // Slash-command completion: while active, Tab completes the box to
    // `completion-text` plus a trailing space (arguments follow), Enter
    // submits `completion-text` directly, Escape dismisses the popup.
    in property <bool> completion-active: false;
    in property <string> completion-text;
    callback completion-dismissed();
    public function apply-completion(t: string) {
        input.text = t + " ";
        input.set-selection-offsets(
            input.text.character-count, input.text.character-count);
        input.focus();
    }

    property <length> pad: 8px;
    property <length> line-height: Theme.fs(18px);
    property <length> max-input-height: Theme.fs(162px); // ~8 lines
    // Desired scroll offset (<= 0); the binding on `input.y` clamps it so
    // shrinking content snaps back into view.
    property <length> scroll-y: 0px;

    height: clamp(input.preferred-height + 2 * root.pad,
        34px, root.max-input-height);
    background: Theme.c.surface;
    border-radius: 6px;
    border-width: 1px;
    border-color: input.has-focus ? Theme.c.selection : Theme.c.border;

    // Focus the input when the padding area is clicked; wheel-scroll the
    // overflowing content (the TextInput above doesn't consume wheel
    // events).
    TouchArea {
        clicked => { input.focus(); }
        mouse-cursor: MouseCursor.text;
        scroll-event(ev) => {
            if (ev.delta-y != 0 && input.preferred-height > clipper.height) {
                root.scroll-y = clamp(input.y + ev.delta-y,
                    clipper.height - input.preferred-height, 0px);
                return accept;
            }
            reject
        }
    }

    clipper := Rectangle {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        height: parent.height - 2 * root.pad;
        clip: true;

        input := TextInput {
            x: 0;
            y: min(0px, max(root.scroll-y, clipper.height - self.preferred-height));
            width: parent.width;
            height: max(self.preferred-height, clipper.height);
            single-line: false;
            wrap: word-wrap;
            enabled: root.enabled;
            color: root.enabled ? Theme.c.text-hi : Theme.c.text-disabled;
            font-size: Theme.fs(13px);
            selection-background-color: Theme.c.selection;

            key-pressed(event) => {
                if (root.completion-active && event.text == Key.Tab) {
                    root.apply-completion(root.completion-text);
                    return accept;
                }
                if (root.completion-active && event.text == Key.Escape) {
                    root.completion-dismissed();
                    return accept;
                }
                if (event.text == Key.Return && !event.modifiers.shift) {
                    if (root.completion-active && root.completion-text != "") {
                        root.submitted(root.completion-text);
                    } else if (self.text != "") {
                        root.submitted(self.text);
                    }
                    return accept;
                }
                return reject;
            }
            cursor-position-changed(pos) => {
                if (pos.y + root.scroll-y < 0) {
                    root.scroll-y = -pos.y;
                } else if (pos.y + root.scroll-y + root.line-height > clipper.height) {
                    root.scroll-y = clipper.height - pos.y - root.line-height;
                }
            }
        }
    }

    if input.text == "": Text {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        text: root.placeholder;
        color: Theme.c.text-disabled;
        font-size: Theme.fs(13px);
        overflow: elide;
    }

    // Slim scrollbar once the input stops growing and content overflows;
    // absolute cursor→position mapping like the chat scrollbar.
    pb-sb := Rectangle {
        property <length> total: input.preferred-height;
        property <length> page: clipper.height;
        property <length> track: root.height - 8px;
        property <length> thumb-h: max(18px,
            self.track * (self.page / max(1px, self.total)));
        property <bool> scrollable: self.total > self.page;

        visible: self.scrollable;
        x: root.width - self.width - 2px;
        y: 4px;
        width: 6px;
        height: self.track;

        function frac() -> float {
            return self.scrollable ? -input.y / (self.total - self.page) : 0;
        }
        function set-from-y(y: length, grab: length) {
            root.scroll-y = -clamp(
                ((y - grab) / max(1px, self.track - self.thumb-h))
                    * (self.total - self.page),
                0px, self.total - self.page);
        }

        pb-thumb := Rectangle {
            x: 0;
            width: parent.width;
            y: (parent.track - parent.thumb-h) * parent.frac();
            height: parent.thumb-h;
            border-radius: 3px;
            background: pb-sb-ta.pressed ? Theme.c.scroll-thumb-active
                : pb-sb-ta.has-hover ? Theme.c.scroll-thumb-hover
                : Theme.c.scroll-thumb;
        }
        pb-sb-ta := TouchArea {
            property <length> grab;
            pointer-event(ev) => {
                if (ev.button == PointerEventButton.left
                    && ev.kind == PointerEventKind.down) {
                    if (self.mouse-y >= pb-thumb.y
                        && self.mouse-y <= pb-thumb.y + pb-thumb.height) {
                        self.grab = self.mouse-y - pb-thumb.y;
                    } else {
                        self.grab = parent.thumb-h / 2;
                        parent.set-from-y(self.mouse-y, self.grab);
                    }
                }
            }
            moved => {
                if (self.pressed) {
                    parent.set-from-y(self.mouse-y, self.grab);
                }
            }
        }
    }
}

// Drag handle between columns. Dragging integrates mouse deltas into the
// bound width; `direction` is +1 when dragging right grows the column.
// New-session / new-thread form. Sessions pick a workspace and a base
// branch; threads only pick the agent setup (they share the session's
// worktree, so the form renders inside the session's tab strip).
component NewChatForm inherits VerticalLayout {
    in property <bool> session-form;
    in property <[string]> workspaces;
    in-out property <int> workspace-index;
    in property <[string]> branches;
    in-out property <int> branch-index;
    in property <[string]> modes;
    in-out property <int> mode-index;
    in property <[string]> models;
    in property <[int]> model-matches;
    in-out property <int> model-index;
    in property <string> error-text;
    callback start(int, int, int, int, string);
    callback cancel();
    callback workspace-changed(int);
    callback register-workspace(string);
    callback model-filter(string);

    padding: 40px;
    spacing: 14px;
    alignment: center;

    Text {
        text: root.session-form ? "New session" : "New thread";
        color: Theme.c.text-hi;
        font-size: Theme.fs(22px);
        font-weight: 700;
    }
    Text {
        text: root.session-form
            ? "Pick where to work, what to branch from, and how the agent should run."
            : "Threads share the session worktree; pick the agent setup for this one.";
        color: Theme.c.text-dim;
        font-size: Theme.fs(13px);
        wrap: word-wrap;
    }

    if root.session-form: VerticalLayout {
        spacing: 6px;
        Text { text: "Workspace"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
        ComboBox {
            model: root.workspaces;
            current-index <=> root.workspace-index;
            selected => { root.workspace-changed(self.current-index); }
        }
        HorizontalLayout {
            spacing: 6px;
            ws-path := LineEdit {
                horizontal-stretch: 1;
                placeholder-text: "…or register a git repo by absolute path";
            }
            Button {
                text: "Add";
                enabled: ws-path.text != "";
                clicked => {
                    root.register-workspace(ws-path.text);
                    ws-path.text = "";
                }
            }
        }
    }

    if root.session-form: VerticalLayout {
        spacing: 6px;
        Text { text: "Base branch"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
        ComboBox {
            model: root.branches;
            current-index <=> root.branch-index;
        }
    }

    HorizontalLayout {
        spacing: 12px;
        VerticalLayout {
            spacing: 6px;
            horizontal-stretch: 1;
            Text { text: "Agent mode"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
            ComboBox {
                model: root.modes;
                current-index <=> root.mode-index;
            }
        }
        VerticalLayout {
            spacing: 6px;
            horizontal-stretch: 1;
            Text { text: "Model"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
            SearchPicker {
                up: false;
                options: root.models;
                matches: root.model-matches;
                current-index <=> root.model-index;
                placeholder: "model";
                filter-edited(q) => { root.model-filter(q); }
            }
        }
    }

    VerticalLayout {
        spacing: 6px;
        Text { text: "First message"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
        prompt-edit := PromptBox {
            placeholder: "What should the agent do?  (Shift+Enter for a new line)";
            submitted(text) => {
                if (!root.session-form || root.workspace-index >= 0) {
                    root.start(root.workspace-index, root.branch-index,
                        root.mode-index, root.model-index, text);
                    self.text = "";
                }
            }
        }
    }

    HorizontalLayout {
        spacing: 8px;
        Button {
            text: root.session-form ? "Start session" : "Start thread";
            primary: true;
            enabled: prompt-edit.text != ""
                && (!root.session-form || root.workspace-index >= 0);
            clicked => {
                root.start(root.workspace-index, root.branch-index,
                    root.mode-index, root.model-index, prompt-edit.text);
                prompt-edit.text = "";
            }
        }
        Button {
            text: "Cancel";
            clicked => { root.cancel(); }
        }
        Rectangle { horizontal-stretch: 1; }
    }
    if root.error-text != "" : Text {
        text: root.error-text;
        color: Theme.c.err;
        font-size: Theme.fs(12px);
        wrap: word-wrap;
    }
}

component SplitterHandle inherits Rectangle {
    in-out property <length> value;
    in property <int> direction: 1;
    in property <length> min-value: 180px;
    in property <length> max-value: 700px;

    width: 5px;
    background: ta.has-hover || ta.pressed ? Theme.c.selection : Theme.c.raised-bg;

    ta := TouchArea {
        mouse-cursor: col-resize;
        moved => {
            root.value = clamp(
                root.value + (self.mouse-x - self.pressed-x) * root.direction,
                root.min-value, root.max-value);
        }
    }
}

export component AppWindow inherits Window {
    preferred-width: 1400px;
    preferred-height: 900px;
    min-width: 900px;
    min-height: 560px;
    title: "trouve";
    background: Theme.c.win-bg;
    // Texts without an explicit font-size inherit these; explicit sizes
    // route through Theme.fs() so everything follows the user's base size.
    default-font-family: Theme.font-family;
    default-font-size: Theme.fs(13px);

    // Built-in widgets (buttons, combo boxes, scrollbars) follow the theme
    // through the std-widgets Palette. Invoked from Rust on theme switch —
    // the ColorScheme enum isn't reachable from the Rust API, so the switch
    // lives here.
    public function set-widget-scheme(dark: bool) {
        Palette.color-scheme = dark ? ColorScheme.dark : ColorScheme.light;
    }

    // --- layout -------------------------------------------------------------
    in-out property <length> left-width: 260px;
    in-out property <length> right-width: 460px;

    // Keep the panels inside the window when it shrinks (or the left
    // column widens): squeeze the right panel, never the chat, down to
    // its 280px floor. Imperative (not a width binding) to avoid a
    // layout binding loop.
    function clamp-right-width() {
        right-width = clamp(right-width, 280px,
            max(280px, root.width - root.left-width - 340px));
    }
    changed width => { root.clamp-right-width(); }
    changed left-width => { root.clamp-right-width(); }

    // --- left column ---------------------------------------------------------
    in property <[NavRow]> nav-rows;
    callback nav-row-clicked(int);
    callback new-session();
    /// Open a workspace folder from the file system (native picker).
    callback open-workspace();
    // A markdown link in the chat was clicked; opens in the system browser.
    callback open-link(string);
    /// Start a new session in the workspace at this nav row.
    callback workspace-new-session(int);
    callback open-settings();
    callback session-renamed(/* nav row */ int, /* new title */ string);
    callback session-archived(/* nav row */ int, /* archived */ bool);
    callback session-deleted(/* nav row */ int);
    // Session-list filters (controller owns the state).
    in property <bool> show-archived: false;
    callback archived-filter-toggled();

    // Rename/delete modal state (UI-local; -1 = closed).
    in-out property <int> rename-row: -1;
    in-out property <int> delete-row: -1;
    in-out property <string> modal-title: "";

    // --- center column ---------------------------------------------------------
    // 0 chat, 1 new-session screen, 2 new-thread screen, 3 settings
    in property <int> center-screen: 0;

    // --- settings screen -------------------------------------------------------
    in property <[ProviderItem]> settings-providers;
    in property <[CliItem]> settings-clis;
    in property <[KnownProviderItem]> settings-known-providers;
    in property <[string]> settings-known-provider-names;
    in property <[string]> settings-models;
    in property <int> settings-default-model-index: -1;
    in property <[string]> settings-modes;
    in property <string> settings-status: "";
    in-out property <int> settings-preset-index: 0;
    callback provider-saved(/* id */ string, /* kind */ string,
                            /* base-url */ string, /* api-key */ string);
    callback provider-deleted(string);
    callback provider-login(string);
    callback default-model-picked(int);
    callback refresh-settings();
    callback cli-install(/* id */ string);
    callback close-settings();

    // Appearance (handled on the Rust UI thread; see src/theme.rs).
    in property <[string]> appearance-theme-names;
    in-out property <int> appearance-theme-index: 0;
    in property <[string]> appearance-font-size-names;
    in-out property <int> appearance-font-size-index: 0;
    in property <[string]> appearance-font-names;
    in-out property <int> appearance-font-index: 0;
    in-out property <bool> appearance-reduce-motion: false;
    callback appearance-theme-picked(int);
    callback appearance-font-size-picked(int);
    callback appearance-font-picked(int);
    callback appearance-reduce-motion-toggled(bool);

    in property <[ThreadTabItem]> threads;
    in property <int> current-thread: -1;
    callback thread-selected(int);
    callback new-thread();

    in property <[ChatRow]> chat-rows;
    callback approval-resolved(/* row index */ int, /* approved */ bool);
    // Question wizard (kind 10): option toggles (index == options.length is
    // the "Other" choice), free-form text edits, and page navigation.
    callback question-option-toggled(/* row index */ int, /* option */ int);
    callback question-other-edited(/* row index */ int, /* text */ string);
    callback question-back(/* row index */ int);
    callback question-next(/* row index */ int);
    callback question-skip(/* row index */ int);
    callback tool-toggled(/* row index */ int);
    callback raw-toggled(/* turn */ int);
    callback card-toggled(/* card key */ string);
    // Filename click on a Read/Edit tool card: open the file in the Files
    // tab; a nonzero 1-based line range gets preselected there.
    callback chat-file-opened(/* path */ string, /* from */ int, /* to */ int);
    // File-view selection (0-based inclusive lines; from < 0 clears),
    // applied by the CodeView whenever the seq is bumped.
    in property <int> file-sel-from: -1;
    in property <int> file-sel-to: -1;
    in property <int> file-sel-seq: 0;
    // Right-panel tab (0 diff, 1 files); the controller flips it when a
    // chat click opens a file.
    in-out property <int> right-tab: 0;
    callback send-message(string);
    in property <bool> composer-enabled: false;
    // Draft survives the composer being swapped out for the new-thread form.
    property <string> composer-draft;

    // "/" skill completion: the harness's slash commands (parallel name /
    // description lists), the fuzzy-ranked match indices (best first,
    // capped), and the best match as ready-to-send text ("/simplify").
    // Rust recomputes matches/active on every draft edit; Escape suppresses
    // the popup until the next edit.
    in property <[string]> slash-commands;
    in property <[string]> slash-details;
    in property <[int]> slash-matches;
    in-out property <bool> slash-active: false;
    in property <string> slash-completion;
    property <bool> slash-suppressed: false;
    callback slash-filter-changed(string);
    changed composer-draft => {
        root.slash-suppressed = false;
        root.slash-filter-changed(root.composer-draft);
    }
    in-out property <string> error-text: "";

    in property <[string]> modes;
    in property <[string]> models;
    // Fuzzy-filtered model indices for the search pickers (Rust computes;
    // only one picker popup is ever open, so the state is shared).
    in property <[int]> model-filter-matches;
    callback model-filter-changed(string);
    in-out property <int> mode-index: -1;
    in-out property <int> model-index: -1;
    callback composer-mode-changed(int);
    callback composer-model-changed(int);

    // Model knobs, derived from the current model's options schema.
    // Empty thinking-options / context-options hide their dropdowns;
    // fast-visible gates the fast/priority toggle (Cursor only).
    in property <[string]> thinking-options;
    in-out property <int> thinking-index: -1;
    in property <[string]> context-options;
    in-out property <int> context-index: -1;
    in property <bool> fast-visible: false;
    in-out property <bool> fast-checked: false;
    callback composer-thinking-changed(int);
    callback composer-context-changed(int);
    callback composer-fast-toggled(bool);

    // Session usage + context indicator (composer bar).
    in property <string> usage-text: "";
    in property <float> context-fill: 0.0;
    in property <bool> context-compacting: false;
    in property <string> context-tooltip: "no usage yet";

    // --- new-chat screen -------------------------------------------------------
    in property <[string]> nc-workspaces;
    in property <[string]> nc-branches;
    in-out property <int> nc-workspace-index: -1;
    in-out property <int> nc-branch-index: -1;
    in-out property <int> nc-mode-index: 0;
    in-out property <int> nc-model-index: 0;
    callback nc-workspace-changed(int);
    callback register-workspace-path(string);
    callback start-new-chat(/* ws */ int, /* branch */ int, /* mode */ int,
                            /* model */ int, /* prompt */ string);
    callback cancel-new-chat();

    // --- right column -------------------------------------------------------
    in property <[DiffRow]> diff-rows;
    // Raw unified diff / raw file content backing the views, for copying.
    in property <string> diff-text: "";
    in property <string> open-file-text: "";
    callback diff-file-toggled(int);
    callback undo-turn();
    callback redo-turn();

    in property <string> pr-status: "";
    callback create-pr();
    callback refresh-pr();

    in property <[FileItem]> file-entries;
    callback file-activated(int);
    // Files tab: whether the file-list drawer beside the viewer is open.
    in-out property <bool> files-drawer-open: true;
    in property <[[TextSegment]]> file-lines;
    in property <[int]> file-numbers;
    in property <string> open-file-name: "";
    // Markdown preview for the open file (toggle lives in the file header).
    in property <bool> file-is-markdown: false;
    in-out property <bool> file-preview: false;
    in property <[ChatRow]> file-preview-rows;
    // Open the file in the user's preferred (system default) editor.
    callback file-opened-externally(/* worktree-relative path */ string);

    // While true, the chat stays pinned to its tail as content grows.
    // scroll-chat-to-end alone isn't enough: it runs before the ListView
    // re-measures freshly grown rows, so the bottom (activity spinner)
    // would sit below the fold until the next event. The pin re-applies on
    // every viewport-height change; renders that must not move the view
    // (expand/collapse toggles, restored positions) clear it.
    in-out property <bool> chat-follow: false;
    // The viewport-y/viewport-height the tail pin last wrote. The
    // viewport-y watcher compares against them to tell user scrolls
    // (which end following) from pin writes and the ListView's own
    // layout adjustments (which don't). A jump from far away converges
    // over several frames: each one instantiates rows near the new
    // offset, re-measures them, and may re-derive viewport-y — only a
    // move with the content height unchanged is a real user scroll.
    property <length> chat-pin-y: 0px;
    property <length> chat-pin-h: 0px;
    public function scroll-chat-to-end() {
        root.chat-follow = true;
        chat-list.viewport-y = min(0px, chat-list.visible-height - chat-list.viewport-height);
        root.chat-pin-y = chat-list.viewport-y;
        root.chat-pin-h = chat-list.viewport-height;
    }
    // True while the view rests at the tail. In-place re-renders read it to
    // keep the bottom anchored: the ListView re-derives viewport-y from
    // estimated row heights, so collapsing a card at the bottom would
    // otherwise land the viewport at a visibly wrong spot.
    out property <bool> chat-at-bottom: chat-list.viewport-y
        <= chat-list.visible-height - chat-list.viewport-height + 12px;

    // Where-you-left-off bookkeeping: the shell polls the live scroll
    // offset into the controller's per-thread resume bookmark, and the
    // controller writes it back when a thread is reopened.
    in-out property <length> chat-scroll <=> chat-list.viewport-y;

    // Quit confirmation while agents run: closing the window with active
    // turns opens the modal instead of quitting.
    in property <int> agents-running: 0;
    in-out property <bool> quit-dialog: false;
    callback quit-now();
    callback quit-when-idle();

    HorizontalLayout {
        // Hidden (not removed — the chat list keeps its scroll state) while
        // the full-window settings screen is up.
        visible: root.center-screen != 3;

        // ---------------- left: sessions ----------------
        Rectangle {
            width: root.left-width;
            background: Theme.c.sidebar-bg;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                HorizontalLayout {
                    Text {
                        text: "Workspaces";
                        color: Theme.c.text-hi;
                        font-size: Theme.fs(15px);
                        font-weight: 700;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Button {
                        text: "+ Open";
                        clicked => { root.open-workspace(); }
                    }
                }

                ScrollKeys {
                    vertical-stretch: 1;
                    target-y <=> nav-list.viewport-y;
                    page: nav-list.visible-height;
                    total: nav-list.viewport-height;
                nav-list := ListView {
                    // Scrolling can move/recycle a hovered button without a
                    // hover-out; drop any tooltip it left behind.
                    changed viewport-y => { Tip.hide-all(); }
                    for row[idx] in root.nav-rows: Rectangle {
                        height: Theme.fs(row.kind == 1 ? 52px : row.kind == 0 ? 34px : 30px);
                        background: row.kind == 0
                            ? (row-ta.has-hover ? Theme.c.hover-bg : Theme.c.raised-bg)
                            : row.kind == 1 && row.selected ? Theme.c.accent-bg : transparent;
                        border-radius: 6px;

                        row-menu := PopupWindow {
                            x: parent.width - 150px;
                            y: 28px;
                            width: 150px;
                            height: 3 * Theme.fs(30px) + 10px;
                            Rectangle {
                                background: Theme.c.popup-bg;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.c.border;
                                VerticalLayout {
                                    padding: 4px;
                                    Rectangle {
                                        height: Theme.fs(30px);
                                        background: rename-ta.has-hover ? Theme.c.accent-bg : transparent;
                                        border-radius: 4px;
                                        rename-ta := TouchArea {
                                            clicked => {
                                                root.modal-title = row.title;
                                                root.rename-row = idx;
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            text: "Rename";
                                            color: Theme.c.text;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        height: Theme.fs(30px);
                                        background: archive-ta.has-hover ? Theme.c.accent-bg : transparent;
                                        border-radius: 4px;
                                        archive-ta := TouchArea {
                                            clicked => {
                                                root.session-archived(idx, !row.archived);
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            text: row.archived ? "Unarchive" : "Archive";
                                            color: Theme.c.text;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        height: Theme.fs(30px);
                                        background: delete-ta.has-hover ? Theme.c.err-hover : transparent;
                                        border-radius: 4px;
                                        delete-ta := TouchArea {
                                            clicked => {
                                                root.modal-title = row.title;
                                                root.delete-row = idx;
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            text: "Delete…";
                                            color: Theme.c.err;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }

                        row-ta := TouchArea {
                            clicked => { root.nav-row-clicked(idx); }
                        }

                        // Session-list filter menu (opened from the funnel
                        // button in the workspace header).
                        filter-menu := PopupWindow {
                            x: parent.width - 190px;
                            y: 32px;
                            width: 180px;
                            height: Theme.fs(24px) + Theme.fs(30px) + 16px;
                            Rectangle {
                                background: Theme.c.popup-bg;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.c.border;
                                VerticalLayout {
                                    padding: 4px;
                                    Rectangle {
                                        height: 24px;
                                        Text {
                                            x: 8px;
                                            text: "Filters";
                                            color: Theme.c.text-soft;
                                            font-size: Theme.fs(11px);
                                            vertical-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        height: Theme.fs(30px);
                                        background: archived-filter-ta.has-hover
                                            ? Theme.c.accent-bg : transparent;
                                        border-radius: 4px;
                                        archived-filter-ta := TouchArea {
                                            clicked => {
                                                root.archived-filter-toggled();
                                            }
                                        }
                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            Text {
                                                text: "Archived";
                                                color: Theme.c.text;
                                                font-size: Theme.fs(12px);
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                            }
                                            if root.show-archived: Text {
                                                text: "✓";
                                                color: Theme.c.text;
                                                font-size: Theme.fs(12px);
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Workspace header: chevron + name, filter menu, and
                        // "+" starts a session in this workspace. Clicking
                        // elsewhere collapses/expands the group.
                        if row.kind == 0: HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 4px;
                            spacing: 6px;
                            Text {
                                text: row.expanded ? "⌄" : "›";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                                vertical-alignment: center;
                            }
                            Text {
                                text: row.title;
                                color: Theme.c.text;
                                font-size: Theme.fs(13px);
                                font-weight: 700;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                            IconButton {
                                width: 26px;
                                height: 26px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 5px;
                                icon: "▽";
                                icon-size: Theme.fs(13px);
                                tip: "Filter sessions";
                                clicked => { filter-menu.show(); }
                            }
                            IconButton {
                                width: 26px;
                                height: 26px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 5px;
                                icon: "+";
                                icon-size: Theme.fs(15px);
                                tip: "New session in this workspace";
                                clicked => { root.workspace-new-session(idx); }
                            }
                        }

                        // Session row.
                        if row.kind == 1: HorizontalLayout {
                            padding-left: 22px;
                            padding-right: 4px;
                            VerticalLayout {
                                padding-top: 8px;
                                spacing: 2px;
                                horizontal-stretch: 1;
                                Text {
                                    text: row.title;
                                    color: row.archived ? Theme.c.text-soft : Theme.c.text-hi;
                                    font-size: Theme.fs(13px);
                                    overflow: elide;
                                }
                                Text {
                                    text: row.subtitle;
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(11px);
                                    overflow: elide;
                                }
                            }
                            IconButton {
                                width: 26px;
                                height: 100%;
                                icon: "⋯";
                                icon-size: Theme.fs(15px);
                                icon-color: Theme.c.text-disabled;
                                hover-icon-color: Theme.c.text-hi;
                                hover-bg: transparent;
                                tip: "Session actions";
                                clicked => { row-menu.show(); }
                            }
                        }

                        // Archived-group toggle.
                        if row.kind == 2: Text {
                            x: 22px;
                            text: (row.expanded ? "▾ " : "▸ ") + row.title;
                            color: Theme.c.text-faint;
                            font-size: Theme.fs(11px);
                            vertical-alignment: center;
                            height: 100%;
                        }
                    }
                }
                }

                // Footer: settings gear (bottom-left, app-level convention).
                HorizontalLayout {
                    IconButton {
                        icon: "⚙";
                        tip: "Settings";
                        width: 28px;
                        height: 28px;
                        icon-size: Theme.fs(18px);
                        clicked => { root.open-settings(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
            }
        }

        SplitterHandle {
            value <=> root.left-width;
            direction: 1;
            min-value: 190px;
            max-value: 460px;
        }

        // ---------------- center ----------------
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.c.win-bg;

            // ----- chat screen (kept in the tree so scroll-chat-to-end can
            // reach the list; hidden while the new-session or settings
            // screen is up). The new-thread form (center-screen 2) renders
            // *inside* this layout so the session's tab strip stays put —
            // the form lives in a provisional tab instead of replacing the
            // whole screen.
            // Wrapping the composer too means paging keys rejected by the
            // prompt's TextInput bubble here and scroll the chat.
            ScrollKeys {
            active: root.center-screen == 0;
            target-y <=> chat-list.viewport-y;
            page: chat-list.visible-height;
            total: chat-list.viewport-height;
            VerticalLayout {
                visible: root.center-screen == 0 || root.center-screen == 2;
                padding: 10px;
                spacing: 8px;

                // Error banner.
                if root.error-text != "": Rectangle {
                    background: Theme.c.err-bg;
                    border-radius: 6px;
                    height: banner.preferred-height + 12px;
                    banner := HorizontalLayout {
                        padding: 6px;
                        padding-left: 10px;
                        spacing: 8px;
                        Text {
                            text: root.error-text;
                            color: Theme.c.err-soft;
                            font-size: Theme.fs(12px);
                            wrap: word-wrap;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        IconButton {
                            width: 24px;
                            height: 24px;
                            icon: "✕";
                            icon-color: Theme.c.err-soft;
                            hover-bg: Theme.c.err-hover;
                            tip: "Dismiss";
                            clicked => { root.error-text = ""; }
                        }
                    }
                }

                // Thread tabs.
                HorizontalLayout {
                    spacing: 6px;
                    for thread[idx] in root.threads: Rectangle {
                        width: 130px;
                        height: Theme.fs(30px);
                        background: idx == root.current-thread ? Theme.c.accent-bg : Theme.c.control-bg;
                        border-radius: 6px;
                        TouchArea {
                            clicked => { root.thread-selected(idx); }
                        }
                        Text {
                            text: thread.label;
                            color: Theme.c.text;
                            font-size: Theme.fs(12px);
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                            width: parent.width - 12px;
                            x: 6px;
                        }
                    }
                    IconButton {
                        width: 30px;
                        height: Theme.fs(30px);
                        border-radius: 6px;
                        icon: "+";
                        icon-size: Theme.fs(15px);
                        idle-bg: Theme.c.control-bg;
                        tip: "New thread";
                        enabled: root.threads.length > 0 || root.composer-enabled;
                        clicked => { root.new-thread(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }

                // Chat stream. The std ListView's own scrollbar can't jump
                // on track clicks and drifts while dragging, so a custom
                // scrollbar overlays it: absolute thumb positioning plus
                // click-to-jump. It sits exactly over the built-in bar and
                // swallows its pointer input.
                Rectangle {
                    vertical-stretch: 1;

                // New-thread form in the provisional tab: replaces only the
                // chat stream, leaving the session's tab strip in place.
                if root.center-screen == 2: NewChatForm {
                    width: 100%;
                    height: 100%;
                    session-form: false;
                    modes: root.modes;
                    mode-index <=> root.nc-mode-index;
                    models: root.models;
                    model-matches: root.model-filter-matches;
                    model-index <=> root.nc-model-index;
                    start(ws, br, mode, model, prompt) => {
                        root.start-new-chat(ws, br, mode, model, prompt);
                    }
                    cancel => { root.cancel-new-chat(); }
                    model-filter(q) => { root.model-filter-changed(q); }
                }

                chat-list := ListView {
                    visible: root.center-screen == 0;
                    width: 100%;
                    height: 100%;
                    // Scrolling can move/recycle a hovered button without a
                    // hover-out; drop any tooltip it left behind.
                    changed viewport-y => {
                        Tip.hide-all();
                        // A user scroll that leaves the tail ends
                        // following — without this the tail pin keeps
                        // snapping the view back to the bottom, fighting
                        // the scrollbar (it looks stuck and wiggles)
                        // after any at-the-tail re-render. But only a
                        // move with the content height unchanged is a
                        // user scroll: the pin's own writes and the
                        // ListView's layout adjustments (it re-derives
                        // viewport-y while re-measuring freshly
                        // instantiated rows) coincide with a
                        // viewport-height change, and must re-pin
                        // instead so a jump from far away converges on
                        // the bottom over a few frames.
                        if (root.chat-follow && !root.chat-at-bottom
                                && self.viewport-y != root.chat-pin-y) {
                            if (self.viewport-height == root.chat-pin-h) {
                                root.chat-follow = false;
                            } else {
                                self.viewport-y = min(0px,
                                    self.visible-height - self.viewport-height);
                                root.chat-pin-y = self.viewport-y;
                                root.chat-pin-h = self.viewport-height;
                            }
                        }
                    }
                    // Keep the tail (activity spinner) on screen as rows
                    // grow during streaming; see chat-follow.
                    changed viewport-height => {
                        if (root.chat-follow) {
                            self.viewport-y = min(0px,
                                self.visible-height - self.viewport-height);
                            root.chat-pin-y = self.viewport-y;
                            root.chat-pin-h = self.viewport-height;
                        }
                    }

                    for row[idx] in root.chat-rows: Rectangle {
                        // Markdown rows manage their own vertical rhythm via
                        // padding (lists tight, paragraphs spaced, headings
                        // set off); boxed rows keep a fixed gap. Headers get
                        // extra room above so cards separate.
                        height: row-content.preferred-height
                            + (row.kind == 1 && row.md-kind != 5 ? 0px
                                : row.kind == 7 ? 14px
                                // Turn rules pad equally via row-content.
                                : row.kind == 8 ? 0px
                                // Plain text bodies (prompt) sit in a card
                                // outline; no trailing gap.
                                : row.kind == 0 ? 0px
                                : 10px)
                            // A slab opening a card body pads down from
                            // the header.
                            + (row.card-first && box.slab ? 8px : 0px);
                        // Card rows clip an oversized border rectangle so
                        // only the outline edges that belong to this row
                        // remain visible (sides for body, sides + rounded
                        // bottom for the last row).
                        clip: row.card-pos == 2 || row.card-pos == 3;

                        // Tool rows keep their label in tool-name, but only
                        // nest inside assistant cards, so hardcode green.
                        property <color> card-line: row.kind == 2 ? Theme.c.agent-border
                            : row.tool-name == "You" ? Theme.c.user-border
                            : row.tool-name == "Agent" ? Theme.c.agent-border
                            : Theme.c.card-border;

                        if row.card-pos == 2 || row.card-pos == 3: Rectangle {
                            x: 0;
                            y: -8px;
                            // Leave the scrollbar gutter on the right.
                            width: parent.width - 18px;
                            height: parent.height + (row.card-pos == 2 ? 16px : 8px);
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: parent.card-line;
                        }

                        // The visible box: card bodies (message text,
                        // markdown, thinking, raw, turn status) inset under
                        // their header so they read as the card's content;
                        // headers and tool cards span the full width.
                        box := Rectangle {
                            property <bool> hdr: row.kind == 7;
                            property <bool> body: row.kind == 0 || row.kind == 1
                                || row.kind == 3 || row.kind == 4 || row.kind == 6
                                || row.kind == 9 || row.kind == 10
                                // Tool cards nested in an assistant card
                                // indent with the rest of the body.
                                || (row.kind == 2 && row.card-pos >= 2);
                            property <bool> md-list: row.kind == 1
                                && (row.md-kind == 4 || row.md-kind == 6);
                            property <bool> md-heading: row.kind == 1
                                && row.md-kind >= 1 && row.md-kind <= 3;
                            // Rows drawn as filled slabs (tool cards,
                            // thinking, code fences, raw text) stop short
                            // of the row's trailing gap so stacked slabs
                            // get breathing room and never paint over the
                            // card outline.
                            property <bool> slab: row.kind == 2
                                || (row.kind == 1 && row.md-kind == 5)
                                || row.kind == 4
                                || row.kind == 6 || row.kind == 9
                                || row.kind == 10;

                            // Tool cards and thinking pills under an
                            // activity-group header (md-indent 1) and
                            // thinking content (tone 2) nest one level
                            // deeper.
                            property <length> indent: 16px
                                + (row.kind == 2 || row.kind == 4 ? row.md-indent * 16px : 0px)
                                + (row.kind == 1 && row.tone == 2 ? 16px : 0px);
                            x: self.body ? self.indent : 0px;
                            // The 18px keeps rows clear of the chat
                            // scrollbar.
                            width: parent.width - 18px
                                - (self.body ? self.indent + 8px : 0px);
                            // Headers leave the card-separating gap above;
                            // a slab that opens a card body drops below its
                            // header.
                            y: self.hdr || (self.slab && row.card-first) ? 8px : 0px;
                            height: parent.height - self.y
                                - (self.slab ? 10px : 0px);

                            // Card headers tint by source: prompt blue,
                            // assistant green; tool cards and thinking
                            // pills stay grey.
                            background: hdr && row.tool-name == "You" ? Theme.c.user-bg
                                : hdr && row.tool-name == "Agent" ? Theme.c.agent-bg
                                // Question wizard: amber while it wants an
                                // answer, settling to card grey once done.
                                : row.kind == 10 ? (row.q-done ? Theme.c.surface : Theme.c.warn-bg)
                                // Thinking pills share the tool-card grey.
                                : row.kind == 2 || row.kind == 4
                                    || row.kind == 9 || hdr ? Theme.c.surface
                                // Lighter than the window background so the
                                // block reads as a slab, not an outline.
                                : row.kind == 1 && row.md-kind == 5 ? Theme.c.code-bg
                                : row.kind == 6 ? Theme.c.inset-bg
                                : transparent;
                            // Headers with a body keep square bottom corners
                            // so they merge into the card outline below.
                            border-top-left-radius: 6px;
                            border-top-right-radius: 6px;
                            border-bottom-left-radius: hdr && row.card-pos == 1 ? 0px : 6px;
                            border-bottom-right-radius: hdr && row.card-pos == 1 ? 0px : 6px;
                            border-width: (row.kind == 1 && row.md-kind == 5)
                                || row.kind == 6 || row.kind == 10 || hdr ? 1px : 0px;
                            border-color: hdr && row.tool-name == "You" ? Theme.c.user-border
                                : hdr && row.tool-name == "Agent" ? Theme.c.agent-border
                                : row.kind == 10 ? (row.q-done ? Theme.c.card-border : Theme.c.warn-border)
                                : row.kind == 6 ? Theme.c.hover-bg
                                : hdr ? Theme.c.card-border
                                : Theme.c.card-border;

                            // Card and tool-group headers toggle their body
                            // on click anywhere that isn't a nested control
                            // (copy button sits on top and wins).
                            if row.kind == 7 || row.kind == 9: TouchArea {
                                clicked => { root.card-toggled(row.card-key); }
                            }

                            row-content := VerticalLayout {
                            padding: 6px;
                            padding-top: row.kind == 7 ? 2px
                                : row.kind == 8 ? 8px
                                : row.kind == 2 || row.kind == 4 || row.kind == 9 ? 3px
                                : md-list ? 2px : md-heading ? 14px : 6px;
                            padding-bottom: row.kind == 7 ? 2px
                                // The next card header brings its own 8px
                                // gap; adding more here would double the
                                // space below the rule.
                                : row.kind == 8 ? 0px
                                : row.kind == 2 || row.kind == 4 || row.kind == 9 ? 3px
                                : md-list ? 2px : md-heading ? 4px : 6px;
                            padding-left: md-list ? 22px + row.md-indent * 18px : 10px;
                            spacing: 4px;

                            // Card header: disclosure, title, collapsed
                            // preview, copy for the whole item.
                            if row.kind == 7: HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: row.expanded ? "▾" : "▸";
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(10px);
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.tool-name;
                                    color: Theme.c.text;
                                    font-size: Theme.fs(11px);
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                // Agent headers: the model that ran the turn.
                                if row.subtitle != "": Text {
                                    text: row.subtitle;
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(11px);
                                    vertical-alignment: center;
                                }
                                if !row.expanded: Text {
                                    text: row.text;
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(11px);
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                if row.expanded: Rectangle { horizontal-stretch: 1; }
                                // Assistant turns: token/cost summary and the
                                // styled-vs-raw view switch live in the header.
                                if row.meta != "": Text {
                                    text: row.meta;
                                    color: Theme.c.text-faint;
                                    font-size: Theme.fs(10px);
                                    vertical-alignment: center;
                                }
                                // Fixed-height icon buttons center on the
                                // header's cross axis instead of pinning to
                                // its top.
                                VerticalLayout {
                                    alignment: center;
                                    HorizontalLayout {
                                    spacing: 2px;
                                    // Styled-view toggle: eye lit = rendered
                                    // markdown, dimmed = raw selectable
                                    // source.
                                    if row.tool-name == "Agent": IconButton {
                                        width: 20px;
                                        height: Theme.fs(18px);
                                        icon: "👁";
                                        icon-color: row.raw ? Theme.c.text-disabled : Theme.c.accent;
                                        hover-icon-color: row.raw ? Theme.c.text-soft : Theme.c.accent-hover;
                                        idle-bg: row.raw ? transparent : Theme.c.accent-veil;
                                        hover-bg: Theme.c.hover-strong;
                                        tip: row.raw ? "Show styled view"
                                            : "Show raw markdown";
                                        clicked => { root.raw-toggled(row.turn); }
                                    }
                                    CopyButton {
                                        payload: row.detail;
                                        height: Theme.fs(18px);
                                        tip: row.tool-name == "You" ? "Copy message"
                                            : row.tool-name == "Agent" ? "Copy response"
                                            : "Copy thinking";
                                    }
                                    }
                                }
                            }

                            // User message: selectable body under its card
                            // header.
                            // Markdown block: code fences render as
                            // selectable monospace text under a header
                            // (language label + copy); everything else
                            // renders inline markup through StyledText.
                            if row.kind == 1 && row.md-kind == 5: HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    text: row.md-lang == "" ? "code" : row.md-lang;
                                    color: Theme.c.text-disabled;
                                    font-size: Theme.fs(11px);
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                CopyButton { payload: row.text; tip: "Copy code"; }
                            }
                            // Syntax-highlighted code lines. Fixed line
                            // height keeps the block's size deterministic
                            // (empty lines would otherwise collapse).
                            if row.kind == 1 && row.md-kind == 5: VerticalLayout {
                                for line in row.code-lines: Rectangle {
                                    height: Theme.fs(19px);
                                    clip: true;
                                    HorizontalLayout {
                                        alignment: start;
                                        for seg in line: Text {
                                            text: seg.text;
                                            // Plain-text fallback segments
                                            // carry black; use the default
                                            // code foreground instead.
                                            color: seg.color == #000000
                                                ? Theme.c.code-fg : seg.color;
                                            font-family: "monospace";
                                            font-size: Theme.fs(13px);
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                            if row.kind == 1 && row.md-kind != 5: StyledText {
                                text: row.styled;
                                default-color: row.tone == 1 ? Theme.c.text-accent-soft
                                    : row.tone == 2 ? Theme.c.text-dim
                                    : Theme.c.text;
                                link-color: Theme.c.accent;
                                default-font-size: Theme.fs(row.md-kind == 1 ? 22px
                                    : row.md-kind == 2 ? 19px
                                    : row.md-kind == 3 ? 16px
                                    : 14px);
                                link-clicked(url) => { root.open-link(url); }
                            }

                            // Tool card header: click anywhere to toggle
                            // the detail panel (nested controls sit on top
                            // and win).
                            if row.kind == 2: Rectangle {
                                height: tool-hdr.preferred-height;
                                TouchArea {
                                    clicked => { root.tool-toggled(idx); }
                                }
                                tool-hdr := HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: row.expanded ? "▾" : "▸";
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(10px);
                                        vertical-alignment: center;
                                    }
                                    // Running tools show an indeterminate
                                    // spinner; settled ones a status glyph.
                                    // Reduce motion: a static glyph instead.
                                    if row.tool-status == 1 && !Theme.reduce-motion: VerticalLayout {
                                        alignment: center;
                                        Spinner {
                                            width: 12px;
                                            height: 12px;
                                            indeterminate: true;
                                        }
                                    }
                                    if row.tool-status == 1 && Theme.reduce-motion: Text {
                                        text: "◌";
                                        color: Theme.c.text-dim;
                                        font-size: Theme.fs(12px);
                                        vertical-alignment: center;
                                    }
                                    if row.tool-status != 1: Text {
                                        text: row.tool-status == 0 ? "⏸"
                                            : row.tool-status == 2 ? "✓"
                                            : row.tool-status == 4 ? "⊘"
                                            : "✗";
                                        color: row.tool-status == 2 ? Theme.c.ok
                                            : row.tool-status == 0 ? Theme.c.warn
                                            : Theme.c.err;
                                        font-size: Theme.fs(12px);
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: row.tool-name;
                                        color: Theme.c.text;
                                        font-size: Theme.fs(11px);
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                    // Read/edit tools: the filename opens
                                    // the file in the Files tab (reads
                                    // preselect the line range there).
                                    if row.tool-file != "": Text {
                                        text: row.text;
                                        color: Theme.c.accent;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                        TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.chat-file-opened(
                                                    row.tool-file,
                                                    row.tool-line-from,
                                                    row.tool-line-to);
                                            }
                                        }
                                    }
                                    // Read tools: the line range read
                                    // ("L123-456", built in Rust).
                                    if row.meta != "": Text {
                                        text: row.meta;
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    // Edit tools: added/removed line counts.
                                    if row.tool-adds != "": Text {
                                        text: row.tool-adds;
                                        color: Theme.c.ok;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    if row.tool-dels != "": Text {
                                        text: row.tool-dels;
                                        color: Theme.c.err;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    CopyButton {
                                        payload: row.detail;
                                        height: Theme.fs(18px);
                                        tip: "Copy tool call";
                                    }
                                    if row.tool-status == 0: VerticalLayout {
                                        alignment: center;
                                        HorizontalLayout {
                                            spacing: 4px;
                                            PillButton {
                                                label: "Approve";
                                                primary: true;
                                                clicked => { root.approval-resolved(idx, true); }
                                            }
                                            PillButton {
                                                label: "Deny";
                                                clicked => { root.approval-resolved(idx, false); }
                                            }
                                        }
                                    }
                                }
                            }

                            // Tool card detail: edits show their line
                            // diff, everything else the humanized
                            // args/result text.
                            if row.kind == 2 && row.expanded && row.tool-diff.length > 0: VerticalLayout {
                                for dline in row.tool-diff: Rectangle {
                                    height: Theme.fs(18px);
                                    background: dline.kind == 3 ? Theme.c.diff-add-bg
                                        : dline.kind == 4 ? Theme.c.diff-del-bg
                                        : transparent;
                                    HorizontalLayout {
                                        spacing: 0;
                                        // Old/new line-number gutter, when
                                        // the diff resolved file positions.
                                        if row.tool-diff-numbered: Text {
                                            width: 34px;
                                            text: dline.old-no;
                                            color: Theme.c.gutter;
                                            horizontal-alignment: right;
                                            font-family: "monospace";
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                        if row.tool-diff-numbered: Text {
                                            width: 34px;
                                            text: dline.new-no;
                                            color: Theme.c.gutter;
                                            horizontal-alignment: right;
                                            font-family: "monospace";
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                        if row.tool-diff-numbered: Rectangle { width: 6px; }
                                        Text {
                                            width: 16px;
                                            text: dline.kind == 3 ? "+"
                                                : dline.kind == 4 ? "-" : " ";
                                            color: dline.kind == 3 ? Theme.c.ok
                                                : dline.kind == 4 ? Theme.c.err
                                                : Theme.c.gutter;
                                            font-family: "monospace";
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: dline.text;
                                            color: dline.kind == 1 ? Theme.c.accent-tint : Theme.c.text;
                                            font-family: "monospace";
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                            if row.kind == 2 && row.expanded && row.tool-diff.length == 0: TextInput {
                                text: row.detail;
                                read-only: true;
                                single-line: false;
                                color: Theme.c.text-dim;
                                font-size: Theme.fs(12px);
                                font-family: "monospace";
                                wrap: word-wrap;
                                selection-background-color: Theme.c.selection;
                            }

                            // Turn status: failures only (completed turns
                            // summarize in their assistant card header).
                            if row.kind == 3: Text {
                                text: row.text;
                                color: Theme.c.err;
                                font-size: Theme.fs(11px);
                            }

                            // Horizontal rule separating turns.
                            if row.kind == 8: Rectangle {
                                height: 1px;
                                background: Theme.c.rule;
                            }

                            // Grouped tool-run header: "Called n tools",
                            // click to show/hide the individual calls.
                            if row.kind == 9: HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: row.expanded ? "▾" : "▸";
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(10px);
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.text;
                                    color: Theme.c.text-mid;
                                    font-size: Theme.fs(11px);
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }

                            // Raw response text: the turn's markdown source
                            // as one fully selectable block.
                            if row.kind == 6: TextInput {
                                text: row.text;
                                read-only: true;
                                single-line: false;
                                color: Theme.c.text;
                                font-size: Theme.fs(13px);
                                wrap: word-wrap;
                                selection-background-color: Theme.c.selection;
                            }

                            // Model thinking (reasoning stream): a header
                            // pill styled like a tool card; the content
                            // follows as markdown rows (tone 2) that this
                            // toggles.
                            if row.kind == 4: Rectangle {
                                height: think-hdr.preferred-height;
                                TouchArea {
                                    clicked => { root.card-toggled(row.card-key); }
                                }
                                think-hdr := HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: row.expanded ? "▾" : "▸";
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(10px);
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        // "Thinking" while streaming,
                                        // "Thought" once complete.
                                        text: row.text;
                                        color: Theme.c.text;
                                        font-size: Theme.fs(11px);
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                    if !row.expanded: Text {
                                        text: row.meta;
                                        color: Theme.c.text-dim;
                                        font-size: Theme.fs(11px);
                                        font-italic: true;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                    if row.expanded: Rectangle {
                                        horizontal-stretch: 1;
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        CopyButton {
                                            payload: row.detail;
                                            height: Theme.fs(18px);
                                            tip: "Copy thinking";
                                        }
                                    }
                                }
                            }

                            // Activity: indeterminate spinner + label while
                            // the agent works ("Processing…"/"Thinking…").
                            if row.kind == 5: HorizontalLayout {
                                spacing: 8px;
                                Rectangle {
                                    width: 16px;
                                    height: 16px;
                                    // Reduce motion: static glyph, no spin.
                                    if !Theme.reduce-motion: Spinner {
                                        width: 16px;
                                        height: 16px;
                                        indeterminate: true;
                                    }
                                    if Theme.reduce-motion: Text {
                                        width: 16px;
                                        height: 16px;
                                        text: "◌";
                                        color: Theme.c.text-dim;
                                        font-size: Theme.fs(13px);
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: row.text;
                                    color: Theme.c.text-dim;
                                    font-size: Theme.fs(13px);
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }

                            // Question wizard: the agent's questions,
                            // answered one page at a time (radio/checkbox
                            // options plus a free-form "Other"), with a
                            // review page before submitting. Once resolved
                            // it settles into a compact answer summary.
                            if row.kind == 10: VerticalLayout {
                                spacing: 8px;
                                padding: 4px;
                                // Title bar: form title, page indicator,
                                // and a skip escape hatch while pending.
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: row.text;
                                        color: row.q-done ? Theme.c.text : Theme.c.warn;
                                        font-size: Theme.fs(11px);
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: row.meta;
                                        color: Theme.c.text-dim;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    if !row.q-done: Text {
                                        text: "Skip";
                                        color: skip-ta.has-hover ? Theme.c.text-mid : Theme.c.text-faint;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                        skip-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.question-skip(idx); }
                                        }
                                    }
                                }
                                // Question page: prompt + options.
                                if !row.q-review: Text {
                                    text: row.q-prompt;
                                    color: Theme.c.text-hi;
                                    font-size: Theme.fs(13px);
                                    font-weight: 600;
                                    wrap: word-wrap;
                                }
                                if !row.q-review: VerticalLayout {
                                    spacing: 4px;
                                    for opt[oi] in row.q-options: Rectangle {
                                        border-radius: 5px;
                                        border-width: 1px;
                                        border-color: opt.selected ? Theme.c.accent : Theme.c.card-border;
                                        background: opt.selected ? Theme.c.accent-dim
                                            : opt-ta.has-hover ? Theme.c.hover-bg : Theme.c.code-bg;
                                        height: opt-line.preferred-height + 10px;
                                        opt-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.question-option-toggled(idx, oi);
                                            }
                                        }
                                        opt-line := HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 10px;
                                            spacing: 8px;
                                            Text {
                                                text: row.q-multi
                                                    ? (opt.selected ? "☑" : "☐")
                                                    : (opt.selected ? "◉" : "○");
                                                color: opt.selected ? Theme.c.accent : Theme.c.text-soft;
                                                font-size: Theme.fs(13px);
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: opt.label;
                                                color: Theme.c.text;
                                                font-size: Theme.fs(13px);
                                                vertical-alignment: center;
                                                wrap: word-wrap;
                                                horizontal-stretch: 1;
                                            }
                                        }
                                    }
                                    // The trailing free-form choice.
                                    Rectangle {
                                        border-radius: 5px;
                                        border-width: 1px;
                                        border-color: row.q-other ? Theme.c.accent : Theme.c.card-border;
                                        background: row.q-other ? Theme.c.accent-dim
                                            : other-ta.has-hover ? Theme.c.hover-bg : Theme.c.code-bg;
                                        height: other-line.preferred-height + 10px;
                                        other-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.question-option-toggled(
                                                    idx, row.q-options.length);
                                            }
                                        }
                                        other-line := HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 10px;
                                            spacing: 8px;
                                            Text {
                                                text: row.q-multi
                                                    ? (row.q-other ? "☑" : "☐")
                                                    : (row.q-other ? "◉" : "○");
                                                color: row.q-other ? Theme.c.accent : Theme.c.text-soft;
                                                font-size: Theme.fs(13px);
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: "Other";
                                                color: Theme.c.text;
                                                font-size: Theme.fs(13px);
                                                font-italic: true;
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                            }
                                        }
                                    }
                                    if row.q-other: Rectangle {
                                        border-radius: 5px;
                                        border-width: 1px;
                                        border-color: Theme.c.card-border;
                                        background: Theme.c.inset-bg;
                                        height: other-input.preferred-height + 12px;
                                        other-input := TextInput {
                                            x: 10px;
                                            y: 6px;
                                            width: parent.width - 20px;
                                            text: row.q-other-text;
                                            single-line: false;
                                            wrap: word-wrap;
                                            color: Theme.c.text;
                                            font-size: Theme.fs(13px);
                                            selection-background-color: Theme.c.selection;
                                            edited => {
                                                root.question-other-edited(idx, self.text);
                                            }
                                        }
                                    }
                                }
                                // Review page (pending) / answered summary.
                                if row.q-review: VerticalLayout {
                                    spacing: 6px;
                                    for pair in row.q-summary: VerticalLayout {
                                        spacing: 1px;
                                        Text {
                                            text: pair.prompt;
                                            color: Theme.c.text-dim;
                                            font-size: Theme.fs(12px);
                                            wrap: word-wrap;
                                        }
                                        Text {
                                            text: pair.answer;
                                            color: Theme.c.text;
                                            font-size: Theme.fs(13px);
                                            wrap: word-wrap;
                                        }
                                    }
                                    if row.q-done && row.q-summary.length == 0: Text {
                                        text: "The questions were skipped.";
                                        color: Theme.c.text-dim;
                                        font-size: Theme.fs(12px);
                                        font-italic: true;
                                    }
                                }
                                // Navigation: Back / Next (last question
                                // page says Review; the review page Submit).
                                if !row.q-done: HorizontalLayout {
                                    alignment: end;
                                    spacing: 6px;
                                    if row.q-can-back: PillButton {
                                        label: "Back";
                                        clicked => { root.question-back(idx); }
                                    }
                                    PillButton {
                                        label: row.q-review ? "Submit"
                                            : row.q-last ? "Review" : "Next";
                                        primary: true;
                                        enabled: row.q-can-next;
                                        clicked => { root.question-next(idx); }
                                    }
                                }
                            }
                            }
                        }
                    }
                }

                // Custom scrollbar: absolute cursor→position mapping (no
                // drift while dragging) and click-to-jump on the track.
                // Solid background hides the built-in bar underneath.
                sb := Rectangle {
                    property <length> total: chat-list.viewport-height;
                    property <length> page: chat-list.visible-height;
                    property <length> margin: 2px;
                    property <length> track: self.height - 2 * self.margin;
                    property <length> thumb-h: max(24px,
                        self.track * (self.page / max(1px, self.total)));
                    property <bool> scrollable: self.total > self.page;

                    visible: self.scrollable && root.center-screen == 0;
                    x: parent.width - self.width;
                    y: 0;
                    width: 14px;
                    height: parent.height;
                    background: Theme.c.win-bg;

                    function frac() -> float {
                        return self.scrollable
                            ? -chat-list.viewport-y / (self.total - self.page)
                            : 0;
                    }
                    function set-from-y(y: length, grab: length) {
                        // An explicit scrollbar move is always a user
                        // scroll: end tail-following outright (the
                        // viewport-y watcher's height heuristic could
                        // mistake a drag for layout noise while rows are
                        // still re-measuring).
                        root.chat-follow = false;
                        chat-list.viewport-y = -clamp(
                            ((y - self.margin - grab)
                                / max(1px, self.track - self.thumb-h))
                                * (self.total - self.page),
                            0px, self.total - self.page);
                    }

                    sb-thumb := Rectangle {
                        x: 4px;
                        width: parent.width - 7px;
                        y: parent.margin
                            + (parent.track - parent.thumb-h) * parent.frac();
                        height: parent.thumb-h;
                        border-radius: 3px;
                        background: sb-ta.pressed ? Theme.c.scroll-thumb-active
                            : sb-ta.has-hover ? Theme.c.scroll-thumb-hover
                            : Theme.c.scroll-thumb;
                    }
                    sb-ta := TouchArea {
                        property <length> grab;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                if (self.mouse-y >= sb-thumb.y
                                    && self.mouse-y <= sb-thumb.y + sb-thumb.height) {
                                    // Grab the thumb where it was clicked.
                                    self.grab = self.mouse-y - sb-thumb.y;
                                } else {
                                    // Track click: jump, centering the
                                    // thumb on the cursor.
                                    self.grab = parent.thumb-h / 2;
                                    parent.set-from-y(self.mouse-y, self.grab);
                                }
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                parent.set-from-y(self.mouse-y, self.grab);
                            }
                        }
                        scroll-event(ev) => {
                            if (ev.delta-y != 0) {
                                chat-list.viewport-y = clamp(
                                    chat-list.viewport-y + ev.delta-y,
                                    -(parent.total - parent.page), 0px);
                                return accept;
                            }
                            reject
                        }
                    }
                }
                }

                // Composer: multiline prompt on top (grows with content),
                // then a controls row — pickers, model knobs, send, dial.
                // Only the chat list above stretches; the composer sticks
                // to its preferred height. Removed (not just hidden) while
                // the new-thread form is up so it doesn't reserve space.
                if root.center-screen == 0: VerticalLayout {
                    spacing: 6px;
                    vertical-stretch: 0;

                    // "/" completion popup, floated above the composer via a
                    // zero-height anchor (rows can then reach `composer`
                    // directly, which lives in this same conditional scope).
                    Rectangle {
                        height: 0;
                        visible: root.slash-active && !root.slash-suppressed;
                        Rectangle {
                            x: 0;
                            y: -self.height - 6px;
                            width: min(parent.width, 480px);
                            height: slash-list.preferred-height;
                            background: Theme.c.popup-bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.c.border;
                            slash-list := VerticalLayout {
                                padding: 6px;
                                for cmd[rank] in root.slash-matches: Rectangle {
                                    height: Theme.fs(26px);
                                    border-radius: 5px;
                                    background: rank == 0 ? Theme.c.accent-bg
                                        : slash-ta.has-hover ? Theme.c.hover-strong : transparent;
                                    slash-ta := TouchArea {
                                        clicked => {
                                            composer.apply-completion(
                                                "/" + root.slash-commands[cmd]);
                                        }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 10px;
                                        Text {
                                            text: "/" + root.slash-commands[cmd];
                                            color: Theme.c.text-hi;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: root.slash-details[cmd];
                                            color: Theme.c.text-soft;
                                            font-size: Theme.fs(11px);
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    composer := PromptBox {
                        text <=> root.composer-draft;
                        placeholder: root.composer-enabled
                            ? "Message the agent…  (Shift+Enter for a new line)"
                            : "Select or create a thread first";
                        enabled: root.composer-enabled;
                        completion-active: root.slash-active && !root.slash-suppressed;
                        completion-text: root.slash-completion;
                        completion-dismissed => { root.slash-suppressed = true; }
                        submitted(text) => {
                            root.send-message(text);
                            self.text = "";
                        }
                    }

                    HorizontalLayout {
                    spacing: 8px;
                    vertical-stretch: 0;
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "Mode"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        DropUpPicker {
                            width: 130px;
                            options: root.modes;
                            current-index <=> root.mode-index;
                            enabled: root.composer-enabled;
                            placeholder: "mode";
                            changed(i) => { root.composer-mode-changed(i); }
                        }
                    }
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "Model"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        SearchPicker {
                            width: 210px;
                            options: root.models;
                            matches: root.model-filter-matches;
                            current-index <=> root.model-index;
                            enabled: root.composer-enabled;
                            placeholder: "model";
                            changed(i) => { root.composer-model-changed(i); }
                            filter-edited(q) => { root.model-filter-changed(q); }
                        }
                    }
                    if root.thinking-options.length > 0: VerticalLayout {
                        spacing: 2px;
                        Text { text: "Thinking"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        DropUpPicker {
                            width: 110px;
                            options: root.thinking-options;
                            current-index <=> root.thinking-index;
                            enabled: root.composer-enabled;
                            placeholder: "thinking";
                            changed(i) => { root.composer-thinking-changed(i); }
                        }
                    }
                    if root.context-options.length > 0: VerticalLayout {
                        spacing: 2px;
                        Text { text: "Context"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        DropUpPicker {
                            width: 90px;
                            options: root.context-options;
                            current-index <=> root.context-index;
                            enabled: root.composer-enabled;
                            placeholder: "context";
                            changed(i) => { root.composer-context-changed(i); }
                        }
                    }
                    if root.fast-visible: VerticalLayout {
                        spacing: 2px;
                        Text { text: "Fast"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        Rectangle {
                            width: 44px;
                            height: Theme.fs(30px);
                            background: root.fast-checked ? Theme.c.accent-bg : Theme.c.control-bg;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: root.fast-checked ? Theme.c.primary-border : Theme.c.border;
                            TouchArea {
                                enabled: root.composer-enabled;
                                clicked => {
                                    root.fast-checked = !root.fast-checked;
                                    root.composer-fast-toggled(root.fast-checked);
                                }
                            }
                            Text {
                                text: root.fast-checked ? "On" : "Off";
                                color: root.fast-checked ? Theme.c.text-accent-soft : Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: " "; font-size: Theme.fs(10px); }
                        Button {
                            text: "Send";
                            primary: true;
                            enabled: root.composer-enabled && composer.text != "";
                            clicked => {
                                root.send-message(composer.text);
                                composer.text = "";
                            }
                        }
                    }
                    // Context usage dial; indeterminate while compacting.
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: " "; font-size: Theme.fs(10px); }
                    dial := Rectangle {
                        width: 30px;
                        height: 30px;
                        // Reduce motion: freeze the compacting animation at a
                        // full ring (the tooltip still says "compacting…").
                        Spinner {
                            width: 26px;
                            height: 26px;
                            x: 2px;
                            y: 2px;
                            progress: root.context-compacting && Theme.reduce-motion
                                ? 1.0 : root.context-fill;
                            indeterminate: root.context-compacting && !Theme.reduce-motion;
                        }
                        dial-ta := TouchArea { }
                        if dial-ta.has-hover: Rectangle {
                            x: dial.width - self.width;
                            y: -self.height - 6px;
                            width: min(tooltip-text.preferred-width + 16px, 340px);
                            height: tooltip-text.preferred-height + 12px;
                            background: Theme.c.popup-bg;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.c.border;
                            tooltip-text := Text {
                                x: 8px;
                                y: 6px;
                                width: parent.width - 16px;
                                text: root.context-compacting
                                    ? "compacting context…\n" + root.context-tooltip
                                    : root.context-tooltip;
                                color: Theme.c.text;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }
                        }
                    }
                    }
                    Text {
                        text: root.usage-text;
                        color: Theme.c.text-soft;
                        font-size: Theme.fs(11px);
                        vertical-alignment: center;
                        max-width: 190px;
                        overflow: elide;
                    }
                    }
                }
            }
            }

            // ----- new-session screen (no session context to keep) -----
            if root.center-screen == 1: NewChatForm {
                session-form: true;
                workspaces: root.nc-workspaces;
                workspace-index <=> root.nc-workspace-index;
                branches: root.nc-branches;
                branch-index <=> root.nc-branch-index;
                modes: root.modes;
                mode-index <=> root.nc-mode-index;
                models: root.models;
                model-matches: root.model-filter-matches;
                model-index <=> root.nc-model-index;
                error-text: root.error-text;
                start(ws, br, mode, model, prompt) => {
                    root.start-new-chat(ws, br, mode, model, prompt);
                }
                cancel => { root.cancel-new-chat(); }
                workspace-changed(i) => { root.nc-workspace-changed(i); }
                register-workspace(path) => { root.register-workspace-path(path); }
                model-filter(q) => { root.model-filter-changed(q); }
            }

        }

        SplitterHandle {
            value <=> root.right-width;
            direction: -1;
            min-value: 280px;
            // The panel may take everything but a readable chat column.
            max-value: max(280px, root.width - root.left-width - 340px);
        }

        // ---------------- right: inspection ----------------
        Rectangle {
            width: root.right-width;
            background: Theme.c.panel-bg;

            TabWidget {
                current-index <=> root.right-tab;
                Tab {
                    title: "Diff";
                    VerticalLayout {
                        padding: 6px;
                        spacing: 6px;
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: "↶ Undo turn";
                                clicked => { root.undo-turn(); }
                            }
                            Button {
                                text: "↷ Redo";
                                clicked => { root.redo-turn(); }
                            }
                            if root.diff-text != "": VerticalLayout {
                                alignment: center;
                                CopyButton {
                                    payload: root.diff-text;
                                    label: "copy diff";
                                    tip: "Copy diff";
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Button {
                                text: "Create PR";
                                clicked => { root.create-pr(); }
                            }
                            Button {
                                text: "PR status";
                                clicked => { root.refresh-pr(); }
                            }
                        }
                        if root.pr-status != "": Text {
                            text: root.pr-status;
                            color: Theme.c.accent-tint;
                            font-size: Theme.fs(12px);
                            wrap: word-wrap;
                        }
                        DiffView {
                            vertical-stretch: 1;
                            rows: root.diff-rows;
                            background: Theme.c.surface;
                            code-font-size: Theme.fs(13px);
                            file-header-bg: Theme.c.hover-bg;
                            file-header-fg: Theme.c.text-hi;
                            hunk-bg: Theme.c.accent-dim;
                            hunk-fg: Theme.c.accent-tint;
                            add-bg: Theme.c.diff-add-bg;
                            add-fg: Theme.c.ok;
                            del-bg: Theme.c.diff-del-bg;
                            del-fg: Theme.c.err;
                            gutter-fg: Theme.c.gutter;
                            text-fg: Theme.c.text;
                            file-toggled(i) => { root.diff-file-toggled(i); }
                        }
                    }
                }
                Tab {
                    title: "Files";
                    HorizontalLayout {
                        padding: 6px;
                        spacing: 6px;

                        // Collapsible drawer: the worktree tree sits beside
                        // the viewer; folders expand in place, children
                        // indented underneath (IDE-style explorer).
                        if root.files-drawer-open: Rectangle {
                            width: 210px;
                            background: Theme.c.sidebar-bg;
                            border-radius: 6px;
                            ScrollKeys {
                                target-y <=> file-tree.viewport-y;
                                page: file-tree.visible-height;
                                total: file-tree.viewport-height;
                            file-tree := ListView {
                                for entry[idx] in root.file-entries: Rectangle {
                                    height: Theme.fs(22px);
                                    background: entry-ta.has-hover ? Theme.c.popup-bg : transparent;
                                    border-radius: 4px;
                                    entry-ta := TouchArea {
                                        clicked => { root.file-activated(idx); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 4px + entry.depth * 16px;
                                        spacing: 4px;
                                        // Chevron gutter: twists open for
                                        // expanded folders, blank for files so
                                        // names in one folder line up.
                                        Text {
                                            width: 12px;
                                            text: !entry.is-dir ? ""
                                                : entry.expanded ? "▾" : "▸";
                                            color: Theme.c.text-soft;
                                            font-size: Theme.fs(11px);
                                            vertical-alignment: center;
                                            horizontal-alignment: center;
                                        }
                                        Text {
                                            text: (entry.is-dir
                                                ? (entry.expanded ? "📂 " : "📁 ")
                                                : "📄 ") + entry.name;
                                            color: Theme.c.text;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                            }
                        }

                        // Viewer column: header (drawer toggle, open file
                        // name, actions) above the file contents.
                        VerticalLayout {
                        spacing: 6px;
                        horizontal-stretch: 1;
                        HorizontalLayout {
                            spacing: 6px;
                            VerticalLayout {
                                alignment: center;
                                IconButton {
                                    icon: "▤";
                                    icon-size: Theme.fs(13px);
                                    icon-color: root.files-drawer-open ? Theme.c.accent : Theme.c.text-soft;
                                    tip: root.files-drawer-open
                                        ? "Hide file list" : "Show file list";
                                    clicked => {
                                        root.files-drawer-open = !root.files-drawer-open;
                                    }
                                }
                            }
                            Text {
                                text: root.open-file-name;
                                color: Theme.c.text-dim;
                                font-size: Theme.fs(12px);
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                            if root.open-file-name != "": VerticalLayout {
                                alignment: center;
                                IconButton {
                                    icon: "↗";
                                    icon-size: Theme.fs(13px);
                                    tip: "Open in editor";
                                    clicked => {
                                        root.file-opened-externally(root.open-file-name);
                                    }
                                }
                            }
                            if root.file-is-markdown: VerticalLayout {
                                alignment: center;
                                IconButton {
                                    icon: "👁";
                                    icon-size: Theme.fs(13px);
                                    icon-color: root.file-preview ? Theme.c.accent : Theme.c.text-soft;
                                    tip: root.file-preview
                                        ? "Show source" : "Preview markdown";
                                    clicked => {
                                        root.file-preview = !root.file-preview;
                                    }
                                }
                            }
                            if root.open-file-text != "": CopyButton {
                                payload: root.open-file-text;
                                label: "copy file";
                                tip: "Copy file contents";
                            }
                        }
                        if !root.file-preview: CodeView {
                            vertical-stretch: 1;
                            lines: root.file-lines;
                            line-numbers: root.file-numbers;
                            background: Theme.c.surface;
                            code-font-size: Theme.fs(13px);
                            foreground: Theme.c.code-fg;
                            gutter-color: Theme.c.gutter;
                            selection-color: Theme.c.selection.with-alpha(0.35);
                            select-from: root.file-sel-from;
                            select-to: root.file-sel-to;
                            select-seq: root.file-sel-seq;
                        }
                        // Rendered markdown preview: the chat's block rows
                        // (headings, lists, fenced code with highlighting).
                        if root.file-preview: ScrollKeys {
                            vertical-stretch: 1;
                            target-y <=> md-preview.viewport-y;
                            page: md-preview.visible-height;
                            total: md-preview.viewport-height;
                        md-preview := ListView {
                            changed viewport-y => { Tip.hide-all(); }
                            for row in root.file-preview-rows: VerticalLayout {
                                padding-top: 3px;
                                padding-bottom: 3px;
                                padding-left: (row.md-kind == 4 || row.md-kind == 6)
                                    ? 10px + row.md-indent * 18px : 0px;
                                padding-right: 6px;
                                if row.md-kind == 5: Rectangle {
                                    background: Theme.c.code-bg;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: Theme.c.card-border;
                                    VerticalLayout {
                                        padding: 8px;
                                        spacing: 4px;
                                        HorizontalLayout {
                                            spacing: 6px;
                                            Text {
                                                text: row.md-lang == ""
                                                    ? "code" : row.md-lang;
                                                color: Theme.c.text-disabled;
                                                font-size: Theme.fs(11px);
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                            }
                                            CopyButton {
                                                payload: row.text;
                                                tip: "Copy code";
                                            }
                                        }
                                        VerticalLayout {
                                            for line in row.code-lines: Rectangle {
                                                height: Theme.fs(19px);
                                                clip: true;
                                                HorizontalLayout {
                                                    alignment: start;
                                                    for seg in line: Text {
                                                        text: seg.text;
                                                        color: seg.color == #000000
                                                            ? Theme.c.code-fg : seg.color;
                                                        font-family: "monospace";
                                                        font-size: Theme.fs(13px);
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                                if row.md-kind != 5: StyledText {
                                    text: row.styled;
                                    default-color: Theme.c.text;
                                    link-color: Theme.c.accent;
                                    default-font-size: Theme.fs(row.md-kind == 1 ? 22px
                                        : row.md-kind == 2 ? 19px
                                        : row.md-kind == 3 ? 16px
                                        : 14px);
                                    link-clicked(url) => { root.open-link(url); }
                                }
                            }
                        }
                        }
                        }
                    }
                }
            }
        }
    }

    // ---------------- settings screen (full-window) ----------------
    if root.center-screen == 3: SettingsScreen {
        width: 100%;
        height: 100%;
        providers: root.settings-providers;
        clis: root.settings-clis;
        known-providers: root.settings-known-providers;
        known-provider-names: root.settings-known-provider-names;
        models: root.settings-models;
        default-model-index: root.settings-default-model-index;
        modes: root.settings-modes;
        settings-status: root.settings-status;
        preset-index <=> root.settings-preset-index;
        theme-names: root.appearance-theme-names;
        theme-index <=> root.appearance-theme-index;
        font-size-names: root.appearance-font-size-names;
        font-size-index <=> root.appearance-font-size-index;
        font-names: root.appearance-font-names;
        font-index <=> root.appearance-font-index;
        reduce-motion <=> root.appearance-reduce-motion;
        provider-saved(id, kind, url, key) => {
            root.provider-saved(id, kind, url, key);
        }
        provider-deleted(id) => { root.provider-deleted(id); }
        provider-login(id) => { root.provider-login(id); }
        default-model-picked(i) => { root.default-model-picked(i); }
        refresh-settings => { root.refresh-settings(); }
        cli-install(id) => { root.cli-install(id); }
        theme-picked(i) => { root.appearance-theme-picked(i); }
        font-size-picked(i) => { root.appearance-font-size-picked(i); }
        font-picked(i) => { root.appearance-font-picked(i); }
        reduce-motion-toggled(on) => { root.appearance-reduce-motion-toggled(on); }
        close => { root.close-settings(); }
    }

    // ---------------- modal overlays (rename / delete) ----------------
    if root.rename-row >= 0 || root.delete-row >= 0: Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.c.scrim;
        TouchArea { } // swallow clicks behind the modal

        Rectangle {
            width: 380px;
            height: modal-layout.preferred-height + 32px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.c.raised-bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.c.border;

            modal-layout := VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: root.rename-row >= 0
                        ? "Rename session"
                        : "Delete session \"" + root.modal-title + "\"?";
                    color: Theme.c.text-hi;
                    font-size: Theme.fs(15px);
                    font-weight: 700;
                    wrap: word-wrap;
                }

                if root.rename-row >= 0: LineEdit {
                    text <=> root.modal-title;
                    placeholder-text: "Session title";
                    accepted(text) => {
                        if (text != "") {
                            root.session-renamed(root.rename-row, text);
                            root.rename-row = -1;
                        }
                    }
                }

                if root.delete-row >= 0: Text {
                    text: "This removes the session's worktree, branch history in trouve, and its event log. The git branch itself is kept.";
                    color: Theme.c.text-dim;
                    font-size: Theme.fs(12px);
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: "Cancel";
                        clicked => {
                            root.rename-row = -1;
                            root.delete-row = -1;
                        }
                    }
                    if root.rename-row >= 0: Button {
                        text: "Rename";
                        primary: true;
                        clicked => {
                            root.session-renamed(root.rename-row, root.modal-title);
                            root.rename-row = -1;
                        }
                    }
                    if root.delete-row >= 0: Button {
                        text: "Delete";
                        primary: true;
                        clicked => {
                            root.session-deleted(root.delete-row);
                            root.delete-row = -1;
                        }
                    }
                }
            }
        }
    }

    // ---------------- quit confirmation (agents still running) ----------------
    if root.quit-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.c.scrim;
        TouchArea { } // swallow clicks behind the modal

        Rectangle {
            width: 440px;
            height: quit-layout.preferred-height + 32px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.c.raised-bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.c.border;

            quit-layout := VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: root.agents-running == 1
                        ? "An agent is still running"
                        : root.agents-running + " agents are still running";
                    color: Theme.c.text-hi;
                    font-size: Theme.fs(15px);
                    font-weight: 700;
                    wrap: word-wrap;
                }
                Text {
                    text: "Quitting now stops the running work mid-turn. You can also let the agents finish and quit automatically.";
                    color: Theme.c.text-dim;
                    font-size: Theme.fs(12px);
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: "Cancel";
                        clicked => { root.quit-dialog = false; }
                    }
                    Button {
                        text: "Quit when agents finish";
                        clicked => {
                            root.quit-dialog = false;
                            root.quit-when-idle();
                        }
                    }
                    Button {
                        text: "Quit";
                        primary: true;
                        clicked => { root.quit-now(); }
                    }
                }
            }
        }
    }

    // ---------------- tooltip overlay ----------------
    // Armed by icon buttons (hover/focus); shows after a short delay,
    // clamped to the window.
    Timer {
        interval: 350ms;
        running: Tip.armed && !Tip.shown;
        triggered => { Tip.shown = true; }
    }
    if Tip.shown && Tip.text != "": Rectangle {
        x: clamp(Tip.tip-x, 4px, root.width - self.width - 4px);
        y: clamp(Tip.tip-y, 4px, root.height - self.height - 4px);
        width: tip-label.preferred-width + 12px;
        height: tip-label.preferred-height + 8px;
        background: Theme.c.hover-bg;
        border-radius: 4px;
        border-width: 1px;
        border-color: Theme.c.border-strong;
        tip-label := Text {
            x: 6px;
            y: 4px;
            text: Tip.text;
            color: Theme.c.text;
            font-size: Theme.fs(11px);
        }
    }
}
