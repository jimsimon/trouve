// trouve desktop: three-column layout.
//   left   — sessions grouped by workspace, settings footer
//   center — thread tabs, chat stream, composer (or the new-chat screen)
//   right  — inspection tabs (Diff / Files)
//
// The window is intentionally dumb: models in, callbacks out. All state
// folding happens in Rust (client-core view models + the app controller).

import {
    Button, CheckBox, ComboBox, LineEdit, ListView, ScrollView, Spinner, TabWidget, TextEdit
} from "std-widgets.slint";
import { DiffView, DiffRow } from "diff-view.slint";
import { CodeView, TextSegment } from "code-view.slint";
import { TerminalGrid, TermSpan } from "terminal-grid.slint";
import {
    SettingsScreen, ProviderItem, CliItem, KnownProviderItem, McpServerItem,
    SubscriptionItem, ModeItem, ThinkingItem, LocalModelItem, LocalSearchItem, GithubHostItem
} from "settings-window.slint";
import { AutomationsScreen, AutomationItem, AutomationTemplateItem } from "automations-screen.slint";
import { PullRequestsScreen, PrGroupItem, PrRowItem } from "pull-requests-screen.slint";
import { ConnectivityBanner } from "connectivity-banner.slint";
import { ScrollKeys } from "scroll-keys.slint";
import { Theme, ThemePalette } from "theme.slint";
import { Palette } from "std-widgets.slint";

// Theme re-exported so Rust can push the selected palette.
export {
    DiffRow, TextSegment, TermSpan, ProviderItem, CliItem, KnownProviderItem, McpServerItem,
    SubscriptionItem, ModeItem, LocalModelItem, LocalSearchItem, AutomationItem, GithubHostItem,
    PrGroupItem, PrRowItem
}
export { ThinkingItem }
export { Theme, ThemePalette }

// One row of the left nav: workspace headers, sessions, archived toggles.
export struct NavRow {
    // 0 workspace header, 1 session, 2 archived-group toggle
    kind: int,
    title: string,
    subtitle: string,
    // Stable workspace identity and position (kind 0 only).
    workspace-id: string,
    workspace-position: int,
    workspace-count: int,
    // For kind 1: stable index the controller maps back to a session.
    session-index: int,
    selected: bool,
    archived: bool,
    expanded: bool,
    // Session is processing a prompt right now (pulsing indicator).
    busy: bool,
    // Completed/failed work landed while the session was not being viewed.
    unread: bool,
    // 0 none, 1 open, 2 draft, 3 merged, 4 closed, 5 multiple.
    pr-kind: int,
    pr-tooltip: string,
    // 0 none, 1 approval, 2 question, 3 both.
    attention-kind: int,
    attention-tooltip: string,
    // Workspace headers: this workspace shows its archived sessions.
    show-archived: bool,
}

export struct ThreadTabItem {
    id: string,
    label: string,
}

// One pull request in the Pull Requests tab. Checks and reviews come
// pre-rendered as multi-line text (one entry per line).
export struct PrItem {
    title: string,
    // "open" / "merged" / "closed" (+ " · draft").
    state: string,
    // "#42 · feature-branch → main".
    meta: string,
    url: string,
    checks: string,
    reviews: string,
}

// One selectable option in a question-wizard page.
export struct QOption {
    label: string,
    selected: bool,
}

// One prompt/answer line on the wizard's review page or answered summary.
export struct QPair {
    prompt: string,
    answer: string,
}

export struct ChatTableCell {
    text: styled-text,
    // 0 default, 1 left, 2 center, 3 right.
    alignment: int,
}

export struct ChatRow {
    // 0 user, 1 markdown block, 2 tool card, 3 turn status,
    // 4 thinking, 5 activity (spinner + label),
    // 6 raw response text (selectable markdown source)
    kind: int,
    // For kind 1: 0 paragraph, 1 h1, 2 h2, 3 h3, 4 bullet, 5 code fence,
    // 6 numbered list item, 7 table.
    md-kind: int,
    // List nesting level for md-kind 4/6 (0 = top level).
    md-indent: int,
    // Language tag for code fences ("rust"; empty when untagged).
    md-lang: string,
    text: string,
    // For kind 1, non-code blocks: `text` with inline markup resolved
    // (bold/italic/inline code/links), built via StyledText::from_markdown.
    styled: styled-text,
    // For kind 1 code fences: syntax-highlight segments, one entry per line.
    code-lines: [[TextSegment]],
    // For kind 1 tables: header followed by body rows.
    table-rows: [[ChatTableCell]],
    // Text tint for markdown rows: 0 agent (default), 1 user prompt,
    // 2 thinking.
    tone: int,
    // Tool-card fields (kind 2).
    tool-name: string,
    // Read-style tools: the file path argument; `text` holds the basename
    // shown (and clickable) in the header.
    tool-file: string,
    // Read-style tools: the 1-based line range read (0 = whole file);
    // shown as "L123-456" and preselected when the file is opened.
    tool-line-from: int,
    tool-line-to: int,
    // Edit-style tools: "+x"/"−y" header badges (empty hides them) and
    // the line diff shown as the expanded body instead of `detail`.
    tool-adds: string,
    tool-dels: string,
    tool-diff: [DiffRow],
    // Whether the diff carries file line numbers (shows the gutter).
    tool-diff-numbered: bool,
    // 0 awaiting approval, 1 running, 2 ok, 3 error, 4 denied, 5 aborted
    tool-status: int,
    detail: string,
    expanded: bool,
    // Turn-status fields (kind 3): 0 running, 1 completed, 2 failed.
    turn-state: int,
    // Turn number (kind 3), for per-turn actions like the raw-view toggle.
    turn: int,
    // Kind 3: this turn's response is currently shown as raw text.
    raw: bool,
    // Kind 7 (card header): stable collapse-toggle key.
    card-key: string,
    // Assistant headers: token/cost summary once the turn completed.
    meta: string,
    // Agent headers: dimmed model tag ("(cursor/claude-fable-5)").
    subtitle: string,
    // Position in a collapsible card outline: 0 none, 1 header (body
    // follows), 2 body, 3 last body row, 4 standalone header.
    card-pos: int,
    // First body row of its card (slab rows pad down from the header).
    card-first: bool,
    // Question wizard (kind 10). `text` holds the title, `meta` the page
    // label ("Question 1 of 3" / "Review your answers" / "Answered").
    q-prompt: string,
    q-options: [QOption],
    // Checkbox-style question (multiple selections allowed).
    q-multi: bool,
    // The trailing "Other" free-form choice: selected flag + its text.
    q-other: bool,
    q-other-text: string,
    // Review page (pending) or answered summary (done).
    q-review: bool,
    q-done: bool,
    q-summary: [QPair],
    q-can-back: bool,
    q-can-next: bool,
    // Last question page ("Review" button) vs earlier ones ("Next").
    q-last: bool,
}

// A file staged to ride with the next prompt (composer chips).
export struct AttachmentChip {
    name: string,
    // "image/png · 34 KB".
    meta: string,
}

// One visible row of the Files tree, pre-flattened by the controller:
// folders carry an expanded flag, depth drives the indent.
export struct FileItem {
    name: string,
    is-dir: bool,
    depth: int,
    expanded: bool,
}

// A ComboBox stand-in whose option list opens *above* the control, for use
// at the bottom edge of the window where a downward popup would be clipped.
component DropUpPicker inherits Rectangle {
    in property <[string]> options;
    in-out property <int> current-index: -1;
    in property <bool> enabled: true;
    in property <string> placeholder: "select…";
    callback changed(int);

    height: Theme.fs(30px);
    background: Theme.c.control-bg;
    border-radius: 6px;

    // An already-open popup must not keep taking clicks after the picker
    // is disabled (e.g. the connection drops mid-interaction).
    changed enabled => {
        if (!root.enabled) {
            popup.close();
        }
    }

    popup := PopupWindow {
        x: 0;
        y: -min(root.options.length, 10) * Theme.fs(28px) - 8px;
        width: max(root.width, 260px);
        height: min(root.options.length, 10) * Theme.fs(28px) + 2px;

        Rectangle {
            background: Theme.c.popup-bg;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.c.border;
            ListView {
                for option[idx] in root.options: Rectangle {
                    height: Theme.fs(28px);
                    background: idx == root.current-index ? Theme.c.accent-bg : transparent;
                    TouchArea {
                        enabled: root.enabled;
                        clicked => {
                            root.current-index = idx;
                            root.changed(idx);
                        }
                    }
                    Text {
                        x: 8px;
                        width: parent.width - 16px;
                        text: option;
                        color: Theme.c.text;
                        font-size: Theme.fs(12px);
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }
    }

    TouchArea {
        enabled: root.enabled;
        clicked => { popup.show(); }
    }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.current-index >= 0 && root.current-index < root.options.length
                ? root.options[root.current-index]
                : root.placeholder;
            color: root.enabled ? Theme.c.text : Theme.c.text-disabled;
            font-size: Theme.fs(12px);
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        Text {
            text: "▴";
            color: Theme.c.text-soft;
            font-size: Theme.fs(10px);
            vertical-alignment: center;
        }
    }
}

// Model picker with a fuzzy-search box. The filtering itself runs in Rust
// (`filter-edited` out, `matches` back in: indices into `options`, best
// match first), so the popup just renders whatever the harness returns.
component SearchPicker inherits Rectangle {
    in property <[string]> options;
    in-out property <int> current-index: -1;
    in property <bool> enabled: true;
    in property <string> placeholder: "select…";
    // Open upward (composer) or downward (forms).
    in property <bool> up: true;
    in property <[int]> matches;
    callback changed(int);
    callback filter-edited(string);

    in-out property <string> query: "";
    property <length> list-h: max(min(root.matches.length, 10), 1) * Theme.fs(28px);
    property <length> popup-h: list-h + 40px;

    height: Theme.fs(30px);
    background: Theme.c.control-bg;
    border-radius: 6px;

    // An already-open popup must not keep taking clicks or Enter after
    // the picker is disabled (e.g. the connection drops mid-interaction).
    changed enabled => {
        if (!root.enabled) {
            popup.close();
        }
    }

    popup := PopupWindow {
        close-policy: close-on-click-outside;
        x: 0;
        y: root.up ? -root.popup-h - 8px : root.height + 4px;
        width: max(root.width, 260px);
        height: root.popup-h;

        Rectangle {
            background: Theme.c.popup-bg;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.c.border;
            VerticalLayout {
                padding: 4px;
                spacing: 4px;
                search := LineEdit {
                    height: Theme.fs(28px);
                    font-size: Theme.fs(12px);
                    placeholder-text: "Search models…";
                    text <=> root.query;
                    enabled: root.enabled;
                    init => { self.focus(); }
                    edited => { root.filter-edited(self.text); }
                    // Enter picks the top match.
                    accepted => {
                        if (root.enabled && root.matches.length > 0) {
                            root.current-index = root.matches[0];
                            root.changed(root.matches[0]);
                            popup.close();
                        }
                    }
                }
                if root.matches.length == 0: Rectangle {
                    height: Theme.fs(28px);
                    Text {
                        x: 8px;
                        text: "no matches";
                        color: Theme.c.text-disabled;
                        font-size: Theme.fs(12px);
                        vertical-alignment: center;
                    }
                }
                ListView {
                    for oi[k] in root.matches: Rectangle {
                        height: Theme.fs(28px);
                        background: oi == root.current-index ? Theme.c.accent-bg
                            : opt-ta.has-hover ? Theme.c.hover-bg : transparent;
                        opt-ta := TouchArea {
                            enabled: root.enabled;
                            clicked => {
                                root.current-index = oi;
                                root.changed(oi);
                                popup.close();
                            }
                        }
                        Text {
                            x: 8px;
                            width: parent.width - 16px;
                            text: root.options[oi];
                            color: Theme.c.text;
                            font-size: Theme.fs(12px);
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
            }
        }
    }

    TouchArea {
        enabled: root.enabled;
        clicked => {
            // Fresh filter on every open.
            root.query = "";
            root.filter-edited("");
            popup.show();
        }
    }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.current-index >= 0 && root.current-index < root.options.length
                ? root.options[root.current-index]
                : root.placeholder;
            color: root.enabled ? Theme.c.text : Theme.c.text-disabled;
            font-size: Theme.fs(12px);
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        Text {
            text: root.up ? "▴" : "▾";
            color: Theme.c.text-soft;
            font-size: Theme.fs(10px);
            vertical-alignment: center;
        }
    }
}

// Shared tooltip state. Icon buttons arm it on hover/focus with their
// window position; the AppWindow overlay shows it after a short delay.
// `show` hands the caller a token and `unshow` only clears while that
// token is current, so crossing from one button straight onto another
// can't hide the new tooltip. `hide-all` force-clears (list scrolling can
// move or recycle a hovered button without a hover-out event, which would
// otherwise strand the tooltip).
global Tip {
    in-out property <string> text;
    in-out property <length> tip-x;
    in-out property <length> tip-y;
    in-out property <bool> armed;
    in-out property <bool> shown;
    in-out property <int> seq: 0;
    public function show(x: length, y: length, t: string) -> int {
        self.text = t;
        self.tip-x = x;
        self.tip-y = y;
        self.armed = true;
        self.seq += 1;
        return self.seq;
    }
    public function unshow(token: int) {
        if (token == self.seq) {
            self.armed = false;
            self.shown = false;
        }
    }
    public function hide-all() {
        self.armed = false;
        self.shown = false;
    }
}

// Plain glyph button: hover highlight, tooltip on hover/focus, and
// keyboard activation (Tab to focus, Enter/Space to click).
component IconButton inherits Rectangle {
    in property <string> icon;
    in property <string> tip;
    in property <bool> enabled: true;
    in property <length> icon-size: Theme.fs(12px);
    in property <color> icon-color: Theme.c.text-soft;
    in property <color> hover-icon-color: Theme.c.text-hi;
    in property <color> idle-bg: transparent;
    in property <color> hover-bg: Theme.c.border;
    callback clicked;

    width: Theme.fs(22px);
    height: Theme.fs(18px);
    border-radius: 4px;
    background: ta.has-hover && root.enabled ? root.hover-bg : root.idle-bg;
    border-width: fs.has-focus ? 1px : 0px;
    border-color: Theme.c.accent;

    property <int> tip-token: -1;
    function tip-changed(on: bool) {
        if (on) {
            root.tip-token = Tip.show(root.absolute-position.x,
                root.absolute-position.y + root.height + 4px, root.tip);
        } else {
            Tip.unshow(root.tip-token);
        }
    }
    fs := FocusScope {
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == " ") {
                root.clicked();
                return accept;
            }
            return reject;
        }
        changed has-focus => { root.tip-changed(self.has-focus); }
    }
    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        changed has-hover => { root.tip-changed(self.has-hover); }
    }
    Text {
        width: 100%;
        height: 100%;
        text: root.icon;
        color: !root.enabled ? Theme.c.text-ghost
            : ta.has-hover ? root.hover-icon-color
            : root.icon-color;
        font-size: root.icon-size;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// Compact text pill button, sized to fit inside 18px-tall card headers
// (the standard Button towers over them).
component PillButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    callback clicked;

    width: pill-label.preferred-width + 16px;
    height: Theme.fs(18px);
    border-radius: 4px;
    background: !root.enabled ? Theme.c.popup-bg
        : root.primary
        ? (pill-ta.has-hover ? Theme.c.primary-hover : Theme.c.primary-bg)
        : (pill-ta.has-hover ? Theme.c.border : Theme.c.pill-bg);
    border-width: 1px;
    border-color: !root.enabled ? Theme.c.border : root.primary ? Theme.c.primary-border : Theme.c.border-strong;

    pill-label := Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: !root.enabled ? Theme.c.text-disabled : root.primary ? Theme.c.on-accent : Theme.c.text-mid;
        font-size: Theme.fs(11px);
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    pill-ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }
}

// Clipboard button: copies `payload` on click and flashes a checkmark.
// Self-contained — the hidden TextInput reaches the system clipboard through
// its built-in select-all/copy functions, so no native plumbing is needed.
component CopyButton inherits Rectangle {
    in property <string> payload;
    // Optional label rendered next to the icon ("copy response").
    in property <string> label: "";
    in property <string> tip: "Copy";
    property <bool> copied: false;

    height: Theme.fs(22px);
    width: content.preferred-width;
    border-radius: 4px;
    background: ta.has-hover ? Theme.c.hover-strong : transparent;
    border-width: fs.has-focus ? 1px : 0px;
    border-color: Theme.c.accent;

    function do-copy() {
        clip-src.text = root.payload;
        clip-src.select-all();
        clip-src.copy();
        clip-src.text = "";
        root.copied = true;
    }
    property <int> tip-token: -1;
    function tip-changed(on: bool) {
        if (on) {
            root.tip-token = Tip.show(root.absolute-position.x,
                root.absolute-position.y + root.height + 4px, root.tip);
        } else {
            Tip.unshow(root.tip-token);
        }
    }

    clip-src := TextInput {
        visible: false;
        width: 0;
        height: 0;
        single-line: false;
    }
    Timer {
        interval: 1.2s;
        running: root.copied;
        triggered => { root.copied = false; }
    }
    content := HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 4px;
        Text {
            text: root.copied ? "✓" : "⧉";
            color: root.copied ? Theme.c.ok
                : ta.has-hover ? Theme.c.text
                : Theme.c.text-soft;
            font-size: Theme.fs(12px);
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        if root.label != "": Text {
            text: root.copied ? "copied" : root.label;
            color: root.copied ? Theme.c.ok
                : ta.has-hover ? Theme.c.text
                : Theme.c.text-soft;
            font-size: Theme.fs(11px);
            vertical-alignment: center;
        }
    }
    fs := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == " ") {
                root.do-copy();
                return accept;
            }
            return reject;
        }
        changed has-focus => { root.tip-changed(self.has-focus); }
    }
    ta := TouchArea {
        clicked => { root.do-copy(); }
        changed has-hover => { root.tip-changed(self.has-hover); }
    }
}

// Shared table grid for chat markdown and rendered file previews. Callers
// supply the text tint; grid structure and surface colors stay identical.
component TableGrid inherits Rectangle {
    in property <[[ChatTableCell]]> rows;
    in property <color> default-color: Theme.c.text;
    callback link-clicked(string);

    background: Theme.c.card-border;
    border-radius: 4px;
    clip: true;

    VerticalLayout {
        padding: 1px;
        spacing: 1px;

        for table-row[table-row-index] in root.rows: row-layout := HorizontalLayout {
            spacing: 1px;

            for cell in table-row: Rectangle {
                min-width: (row-layout.width - 1px * (table-row.length - 1)) / table-row.length;
                max-width: self.min-width;
                background: table-row-index == 0
                    ? Theme.c.surface : Theme.c.inset-bg;

                VerticalLayout {
                    padding: 6px;

                    StyledText {
                        text: cell.text;
                        default-color: root.default-color;
                        link-color: Theme.c.accent;
                        default-font-size: Theme.fs(13px);
                        horizontal-alignment: cell.alignment == 3 ? right
                            : cell.alignment == 2 ? center : left;
                        link-clicked(url) => { root.link-clicked(url); }
                    }
                }
            }
        }
    }
}

// Multiline prompt input. Grows with content up to `max-input-height`
// (then scrolls, keeping the cursor visible); Enter submits, Shift+Enter
// inserts a newline. Built on a raw TextInput because the TextEdit widget
// offers no way to intercept Enter.
component PromptBox inherits Rectangle {
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> text <=> input.text;
    callback submitted(string);
    // Slash-command completion: while active, Tab completes the box to
    // `completion-text` plus a trailing space (arguments follow), Enter
    // submits `completion-text` directly, Escape dismisses the popup.
    in property <bool> completion-active: false;
    in property <string> completion-text;
    callback completion-dismissed();
    // Ctrl/Cmd+V: give the app a chance to capture a clipboard image as an
    // attachment; returns true when it did (the text paste is skipped).
    callback paste-image-attempted() -> bool;
    public function apply-completion(t: string) {
        input.text = t + " ";
        input.set-selection-offsets(
            input.text.character-count, input.text.character-count);
        input.focus();
    }

    // "@" file-mention completion: while its popup is up, ↑/↓ move the
    // highlight, Tab/Enter insert the highlighted path, Escape dismisses.
    // Rust owns the token parsing and list filtering — the box just streams
    // cursor positions out (mentions can sit anywhere in the draft, so the
    // byte offset locates the token under edit).
    in property <bool> at-active: false;
    in property <int> at-count: 0;
    in-out property <int> at-selected: 0;
    callback at-accepted();
    callback at-dismissed();
    callback cursor-moved(/* UTF-8 byte offset */ int);
    // Rust-driven cursor placement after splicing a mention into the draft:
    // bump `cursor-seq` with the wanted offset in `cursor-target` (a plain
    // property write can't retrigger at the same offset; the seq can).
    in property <int> cursor-seq: 0;
    in property <int> cursor-target: 0;
    changed cursor-seq => {
        input.set-selection-offsets(root.cursor-target, root.cursor-target);
        input.focus();
    }

    property <length> pad: 8px;
    property <length> line-height: Theme.fs(18px);
    property <length> max-input-height: Theme.fs(162px); // ~8 lines
    // Desired scroll offset (<= 0); the binding on `input.y` clamps it so
    // shrinking content snaps back into view.
    property <length> scroll-y: 0px;

    height: clamp(input.preferred-height + 2 * root.pad,
        34px, root.max-input-height);
    background: Theme.c.surface;
    border-radius: 6px;
    border-width: 1px;
    border-color: input.has-focus ? Theme.c.selection : Theme.c.border;

    // Focus the input when the padding area is clicked; wheel-scroll the
    // overflowing content (the TextInput above doesn't consume wheel
    // events).
    TouchArea {
        clicked => { input.focus(); }
        mouse-cursor: MouseCursor.text;
        scroll-event(ev) => {
            if (ev.delta-y != 0 && input.preferred-height > clipper.height) {
                root.scroll-y = clamp(input.y + ev.delta-y,
                    clipper.height - input.preferred-height, 0px);
                return accept;
            }
            reject
        }
    }

    clipper := Rectangle {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        height: parent.height - 2 * root.pad;
        clip: true;

        input := TextInput {
            x: 0;
            y: min(0px, max(root.scroll-y, clipper.height - self.preferred-height));
            width: parent.width;
            height: max(self.preferred-height, clipper.height);
            single-line: false;
            wrap: word-wrap;
            enabled: root.enabled;
            color: root.enabled ? Theme.c.text-hi : Theme.c.text-disabled;
            font-size: Theme.fs(13px);
            selection-background-color: Theme.c.selection;

            key-pressed(event) => {
                if ((event.text == "v" || event.text == "V")
                    && (event.modifiers.control || event.modifiers.meta)
                    && !event.modifiers.shift
                    && root.paste-image-attempted()) {
                    return accept;
                }
                if (root.at-active) {
                    if (event.text == Key.UpArrow) {
                        root.at-selected = Math.max(0, root.at-selected - 1);
                        return accept;
                    }
                    if (event.text == Key.DownArrow) {
                        root.at-selected = Math.min(
                            root.at-count - 1, root.at-selected + 1);
                        return accept;
                    }
                    if (event.text == Key.Tab
                        || (event.text == Key.Return && !event.modifiers.shift)) {
                        root.at-accepted();
                        return accept;
                    }
                    if (event.text == Key.Escape) {
                        root.at-dismissed();
                        return accept;
                    }
                }
                if (root.completion-active && event.text == Key.Tab) {
                    root.apply-completion(root.completion-text);
                    return accept;
                }
                if (root.completion-active && event.text == Key.Escape) {
                    root.completion-dismissed();
                    return accept;
                }
                if (event.text == Key.Return && !event.modifiers.shift) {
                    if (root.completion-active && root.completion-text != "") {
                        root.submitted(root.completion-text);
                    } else if (self.text != "") {
                        root.submitted(self.text);
                    }
                    return accept;
                }
                return reject;
            }
            cursor-position-changed(pos) => {
                if (pos.y + root.scroll-y < 0) {
                    root.scroll-y = -pos.y;
                } else if (pos.y + root.scroll-y + root.line-height > clipper.height) {
                    root.scroll-y = clipper.height - pos.y - root.line-height;
                }
            }
            changed cursor-position-byte-offset => {
                root.cursor-moved(self.cursor-position-byte-offset);
            }
        }
    }

    if input.text == "": Text {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        text: root.placeholder;
        color: Theme.c.text-disabled;
        font-size: Theme.fs(13px);
        overflow: elide;
    }

    // Slim scrollbar once the input stops growing and content overflows;
    // absolute cursor→position mapping like the chat scrollbar.
    pb-sb := Rectangle {
        property <length> total: input.preferred-height;
        property <length> page: clipper.height;
        property <length> track: root.height - 8px;
        property <length> thumb-h: max(18px,
            self.track * (self.page / max(1px, self.total)));
        property <bool> scrollable: self.total > self.page;

        visible: self.scrollable;
        x: root.width - self.width - 2px;
        y: 4px;
        width: 6px;
        height: self.track;

        function frac() -> float {
            return self.scrollable ? -input.y / (self.total - self.page) : 0;
        }
        function set-from-y(y: length, grab: length) {
            root.scroll-y = -clamp(
                ((y - grab) / max(1px, self.track - self.thumb-h))
                    * (self.total - self.page),
                0px, self.total - self.page);
        }

        pb-thumb := Rectangle {
            x: 0;
            width: parent.width;
            y: (parent.track - parent.thumb-h) * parent.frac();
            height: parent.thumb-h;
            border-radius: 3px;
            background: pb-sb-ta.pressed ? Theme.c.scroll-thumb-active
                : pb-sb-ta.has-hover ? Theme.c.scroll-thumb-hover
                : Theme.c.scroll-thumb;
        }
        pb-sb-ta := TouchArea {
            property <length> grab;
            pointer-event(ev) => {
                if (ev.button == PointerEventButton.left
                    && ev.kind == PointerEventKind.down) {
                    if (self.mouse-y >= pb-thumb.y
                        && self.mouse-y <= pb-thumb.y + pb-thumb.height) {
                        self.grab = self.mouse-y - pb-thumb.y;
                    } else {
                        self.grab = parent.thumb-h / 2;
                        parent.set-from-y(self.mouse-y, self.grab);
                    }
                }
            }
            moved => {
                if (self.pressed) {
                    parent.set-from-y(self.mouse-y, self.grab);
                }
            }
        }
    }
}

// Drag handle between columns. Dragging integrates mouse deltas into the
// bound width; `direction` is +1 when dragging right grows the column.
// New-session / new-thread form. Sessions pick a workspace and a base
// branch; threads only pick the agent setup (they share the session's
// worktree, so the form renders inside the session's tab strip).
component NewChatForm inherits VerticalLayout {
    in property <bool> session-form;
    in property <[string]> workspaces;
    in-out property <int> workspace-index;
    in property <[string]> branches;
    in-out property <int> branch-index;
    in-out property <bool> use-latest-remote: true;
    in property <[string]> modes;
    in-out property <int> mode-index;
    // Per-mode default model as an index into models (-1 = none); picking
    // a mode jumps the model picker to its default.
    in property <[int]> mode-model-indices;
    in property <[string]> models;
    in property <[int]> model-matches;
    in-out property <int> model-index;
    in property <[string]> thinking-options;
    in-out property <int> thinking-index;
    in property <[string]> permission-options;
    in-out property <int> permission-index;
    in property <string> error-text;
    // Offline/disconnected with nothing usable: every input is disabled
    // and the banner explains why (see AppWindow.connectivity-*).
    in property <bool> blocked;
    in property <bool> blocked-severe;
    in property <string> offline-warning;
    in property <string> online-notice;
    callback start(int, int, bool, int, int, int, int, string);
    callback cancel();
    callback workspace-changed(int);
    callback register-workspace(string);
    callback model-filter(string);
    in property <[AttachmentChip]> attachments;
    callback attach-file();
    callback attachment-removed(int);
    callback paste-image-attempted() -> bool;
    property <bool> yolo-selected: root.permission-index >= 0
        && root.permission-index < root.permission-options.length
        && root.permission-options[root.permission-index] == "Yolo";

    padding: 40px;
    spacing: 14px;
    alignment: center;

    Text {
        text: root.session-form ? "New session" : "New thread";
        color: Theme.c.text-hi;
        font-size: Theme.fs(22px);
        font-weight: 700;
    }
    Text {
        text: root.session-form
            ? "Pick where to work, what to branch from, and how the agent should run."
            : "Threads share the session worktree; pick the agent setup for this one.";
        color: Theme.c.text-dim;
        font-size: Theme.fs(13px);
        wrap: word-wrap;
    }

    if root.offline-warning != "" || root.online-notice != "": ConnectivityBanner {
        warning: root.offline-warning;
        notice: root.online-notice;
        severe: root.blocked-severe;
    }

    if root.session-form: VerticalLayout {
        spacing: 6px;
        Text { text: "Workspace"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
        ComboBox {
            model: root.workspaces;
            current-index <=> root.workspace-index;
            enabled: !root.blocked;
            selected => { root.workspace-changed(self.current-index); }
        }
        HorizontalLayout {
            spacing: 6px;
            ws-path := LineEdit {
                horizontal-stretch: 1;
                placeholder-text: "…or register a git repo by absolute path";
                enabled: !root.blocked;
            }
            Button {
                text: "Add";
                enabled: ws-path.text != "" && !root.blocked;
                clicked => {
                    root.register-workspace(ws-path.text);
                    ws-path.text = "";
                }
            }
        }
    }

    if root.session-form: VerticalLayout {
        spacing: 6px;
        Text { text: "Base branch"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
        ComboBox {
            model: root.branches;
            current-index <=> root.branch-index;
            enabled: !root.blocked;
        }
        CheckBox {
            text: "Use latest remote branch";
            checked <=> root.use-latest-remote;
            enabled: !root.blocked;
        }
    }

    HorizontalLayout {
        spacing: 12px;
        VerticalLayout {
            spacing: 6px;
            horizontal-stretch: 1;
            Text { text: "Agent mode"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
            ComboBox {
                model: root.modes;
                current-index <=> root.mode-index;
                enabled: !root.blocked;
                selected => {
                    if (root.mode-index >= 0
                        && root.mode-index < root.mode-model-indices.length
                        && root.mode-model-indices[root.mode-index] >= 0) {
                        root.model-index = root.mode-model-indices[root.mode-index];
                    }
                }
            }
        }
        VerticalLayout {
            spacing: 6px;
            horizontal-stretch: 1;
            Text { text: "Model"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
            SearchPicker {
                up: false;
                options: root.models;
                matches: root.model-matches;
                current-index <=> root.model-index;
                enabled: !root.blocked;
                placeholder: "model";
                filter-edited(q) => { root.model-filter(q); }
            }
        }
    }
    HorizontalLayout {
        spacing: 12px;
        if root.thinking-options.length > 0: VerticalLayout {
            spacing: 6px; horizontal-stretch: 1;
            Text { text: "Thinking level"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
            ComboBox { model: root.thinking-options; current-index <=> root.thinking-index; enabled: !root.blocked; }
        }
        VerticalLayout {
            spacing: 6px; horizontal-stretch: 1;
            Text {
                text: root.yolo-selected ? "⚠ Permission mode" : "Permission mode";
                color: root.yolo-selected ? Theme.c.err : Theme.c.text-mid;
                font-size: Theme.fs(12px); font-weight: 700;
            }
            ComboBox { model: root.permission-options; current-index <=> root.permission-index; enabled: !root.blocked; }
        }
    }
    if root.yolo-selected: Rectangle {
        background: Theme.c.err-bg;
        border-width: 1px;
        border-color: Theme.c.err;
        border-radius: 6px;
        height: setup-yolo-warning.preferred-height + 20px;
        setup-yolo-warning := VerticalLayout {
            padding: 10px;
            spacing: 4px;
            Text {
                text: "⚠ Unattended execution (YOLO) is dangerous";
                color: Theme.c.err;
                font-size: Theme.fs(12px);
                font-weight: 700;
            }
            Text {
                text: "The agent can run commands and change or delete files without asking for approval.";
                color: Theme.c.err-soft;
                font-size: Theme.fs(11px);
                wrap: word-wrap;
            }
        }
    }

    VerticalLayout {
        spacing: 6px;
        Text { text: "First message"; color: Theme.c.text-mid; font-size: Theme.fs(12px); font-weight: 700; }
        prompt-edit := PromptBox {
            paste-image-attempted => { root.paste-image-attempted() }
            placeholder: root.blocked && root.blocked-severe
                ? "Server unavailable — prompts are disabled"
                : root.blocked
                ? "Offline — prompts are disabled"
                : "What should the agent do?  (Shift+Enter for a new line)";
            enabled: !root.blocked;
            submitted(text) => {
                if (!root.blocked && (!root.session-form || root.workspace-index >= 0)) {
                    root.start(root.workspace-index, root.branch-index,
                        root.use-latest-remote, root.mode-index, root.model-index, root.thinking-index,
                        root.permission-index, text);
                    self.text = "";
                }
            }
        }
    }

    if root.attachments.length > 0: HorizontalLayout {
        spacing: 6px;
        for chip[i] in root.attachments: Rectangle {
            height: Theme.fs(24px);
            background: Theme.c.accent-bg;
            border-radius: 6px;
            HorizontalLayout {
                padding-left: 8px; padding-right: 4px; spacing: 6px;
                Text { text: chip.name; color: Theme.c.text-hi; font-size: Theme.fs(11px); vertical-alignment: center; }
                Text { text: chip.meta; color: Theme.c.text-soft; font-size: Theme.fs(10px); vertical-alignment: center; }
                IconButton { icon: "✕"; tip: "Remove attachment"; clicked => { root.attachment-removed(i); } }
            }
        }
    }

    HorizontalLayout {
        spacing: 8px;
        IconButton {
            icon: "📎";
            tip: "Attach files (or paste an image with Ctrl+V)";
            enabled: !root.blocked;
            clicked => { root.attach-file(); }
        }
        Button {
            text: root.session-form ? "Start session" : "Start thread";
            primary: true;
            enabled: (prompt-edit.text != "" || root.attachments.length > 0) && !root.blocked
                && (!root.session-form || root.workspace-index >= 0);
            clicked => {
                root.start(root.workspace-index, root.branch-index,
                    root.use-latest-remote, root.mode-index, root.model-index, root.thinking-index,
                    root.permission-index, prompt-edit.text);
                prompt-edit.text = "";
            }
        }
        Button {
            text: "Cancel";
            clicked => { root.cancel(); }
        }
        Rectangle { horizontal-stretch: 1; }
    }
    if root.error-text != "" : Text {
        text: root.error-text;
        color: Theme.c.err;
        font-size: Theme.fs(12px);
        wrap: word-wrap;
    }
}

// Activity indicator: three accent dots doing a soft sine wave — each one
// rises and brightens in sequence, with a faint halo behind the crest.
// Quieter than a spinner ring but visibly "alive"; with animate off
// (reduce motion) the dots rest as static faint marks.
component PulseDots inherits Rectangle {
    in property <bool> animate: true;
    width: 38px;
    height: 16px;
    property <float> t: root.animate ? animation-tick() / 1.4s : 0.0;
    for i in [0, 1, 2]: Rectangle {
        // Half-wave per dot, staggered: sin clipped at 0 so each dot rests
        // between pulses instead of dipping below the baseline.
        property <float> wave: Math.max(0.0, Math.sin(360deg * (t - i * 0.15)));
        property <length> size: 6px + 2px * wave;
        width: self.size;
        height: self.size;
        border-radius: self.size / 2;
        x: 3px + i * 12px + (6px - self.size) / 2;
        y: parent.height - self.size - wave * 6px;
        background: Theme.c.accent;
        opacity: root.animate ? 0.25 + 0.75 * wave : 0.4;
        // Halo: a soft ring that swells with the dot's crest.
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: parent.width + 8px * wave;
            height: self.width;
            border-radius: self.width / 2;
            background: Theme.c.accent;
            opacity: 0.18 * wave;
        }
    }
}

component SplitterHandle inherits Rectangle {
    in-out property <length> value;
    in property <int> direction: 1;
    in property <length> min-value: 180px;
    in property <length> max-value: 700px;

    width: 5px;
    background: ta.has-hover || ta.pressed ? Theme.c.selection : Theme.c.raised-bg;

    ta := TouchArea {
        mouse-cursor: col-resize;
        moved => {
            root.value = clamp(
                root.value + (self.mouse-x - self.pressed-x) * root.direction,
                root.min-value, root.max-value);
        }
    }
}

export component AppWindow inherits Window {
    preferred-width: 1400px;
    preferred-height: 900px;
    min-width: 900px;
    min-height: 560px;
    title: "Trouve";
    // Branching-threads mark: one line of work splitting into parallel
    // sessions, the glowing dot being the one that found it ("trouvé").
    icon: @image-url("assets/trouve.png");
    background: Theme.c.win-bg;
    // Texts without an explicit font-size inherit these; explicit sizes
    // route through Theme.fs() so everything follows the user's base size.
    default-font-family: Theme.font-family;
    default-font-size: Theme.fs(13px);

    // Built-in widgets (buttons, combo boxes, scrollbars) follow the theme
    // through the std-widgets Palette. Invoked from Rust on theme switch —
    // the ColorScheme enum isn't reachable from the Rust API, so the switch
    // lives here.
    public function set-widget-scheme(dark: bool) {
        Palette.color-scheme = dark ? ColorScheme.dark : ColorScheme.light;
    }

    // --- layout -------------------------------------------------------------
    in-out property <length> left-width: 260px;
    in-out property <length> right-width: 460px;

    // Keep the panels inside the window when it shrinks (or the left
    // column widens): squeeze the right panel, never the chat, down to
    // its 280px floor. Imperative (not a width binding) to avoid a
    // layout binding loop.
    function clamp-right-width() {
        right-width = clamp(right-width, 280px,
            max(280px, root.width - root.left-width - 340px));
    }
    changed width => { root.clamp-right-width(); }
    changed left-width => { root.clamp-right-width(); }

    // --- left column ---------------------------------------------------------
    in property <[NavRow]> nav-rows;
    callback nav-row-clicked(int);
    callback new-session();
    /// Open a workspace folder from the file system (native picker).
    callback open-workspace();
    // A markdown link in the chat was clicked; opens in the system browser.
    callback open-link(string);
    /// Start a new session in the workspace at this nav row.
    callback workspace-new-session(int);
    // Workspace header ordering. Drag payloads stay opaque in Slint and are
    // created/validated by the Rust host.
    pure callback workspace-drag-data(string) -> data-transfer;
    pure callback workspace-drag-acceptable(data-transfer) -> bool;
    callback workspace-dropped(data-transfer, /* target id */ string, /* after */ bool) -> bool;
    callback workspace-moved(/* workspace id */ string, /* signed offset */ int);
    // Set immediately before a keyboard move so the nav update returns focus
    // to the moved handle at its new model position.
    in-out property <string> workspace-reorder-focus-id: "";
    property <int> workspace-reorder-focus-generation: 0;
    public function restore-workspace-reorder-focus() {
        root.workspace-reorder-focus-generation += 1;
    }
    callback open-settings();
    callback session-renamed(/* nav row */ int, /* new title */ string);
    callback session-archived(/* nav row */ int, /* archived */ bool);
    callback session-deleted(/* nav row */ int);
    // Session-list filters (controller owns the state).
    // Per-workspace: the row is the workspace header the funnel lives on.
    callback archived-filter-toggled(/* nav row */ int);

    // Rename/delete modal state (UI-local; -1 = closed).
    in-out property <int> rename-row: -1;
    in-out property <int> delete-row: -1;
    in-out property <string> modal-title: "";

    // --- center column ---------------------------------------------------------
    // 0 chat, 1 new-session screen, 2 new-thread screen, 3 settings,
    // 4 automations, 5 pull requests
    in property <int> center-screen: 0;

    // --- pull requests screen --------------------------------------------------
    in property <[PrGroupItem]> pr-dash-groups;
    in property <[string]> pr-dash-projects;
    in-out property <int> pr-dash-project-index: 0;
    in property <string> pr-dash-status: "";
    in property <bool> pr-dash-has-workspaces: true;
    // Set immediately before a keyboard move so the rebuilt repeater returns
    // focus to the moved group's handle.
    in-out property <string> pr-group-reorder-focus-key: "";
    callback open-pull-requests();
    callback close-pull-requests();
    callback pull-requests-refresh();
    callback pr-dash-filter-picked(/* project index; 0 = all */ int);
    callback pr-group-toggled(/* group key */ string);
    // Group ordering. Drag payloads stay opaque in Slint and are
    // created/validated by the Rust host.
    pure callback pr-group-drag-data(string) -> data-transfer;
    pure callback pr-group-drag-acceptable(data-transfer) -> bool;
    callback pr-group-dropped(data-transfer, /* target key */ string, /* after */ bool) -> bool;
    callback pr-group-moved(/* group key */ string, /* signed offset */ int);
    callback pr-chat-clicked(/* workspace id */ string, /* head branch */ string);

    // --- automations screen ----------------------------------------------------
    in property <[AutomationItem]> automations;
    in property <[AutomationTemplateItem]> automation-templates;
    in property <string> automations-status: "";
    in property <[string]> automation-workspace-names;
    in property <[string]> automation-workspace-ids;
    callback open-automations();
    callback close-automations();
    callback automations-refresh();
    callback automation-saved(/* id */ string, /* name */ string, /* prompt */ string,
                              /* workspace-id */ string, /* kind */ string,
                              /* minute */ string, /* time */ string, /* days */ string,
                              /* permission-index */ int,
                              /* enabled */ bool);
    callback automation-toggled(/* id */ string, /* enabled */ bool);
    callback automation-run(/* id */ string);
    callback automation-deleted(/* id */ string);
    // Lets the controller dismiss the form after a successful save.
    public function close-automation-form() {
        automations-screen-form-open = false;
    }
    in-out property <bool> automations-screen-form-open: false;

    // --- settings screen -------------------------------------------------------
    in property <[ProviderItem]> settings-providers;
    in property <[ProviderItem]> settings-subscription-providers;
    in property <[ProviderItem]> settings-api-providers;
    in property <[ProviderItem]> settings-local-providers;
    in property <[CliItem]> settings-clis;
    in property <[KnownProviderItem]> settings-known-providers;
    in property <[string]> settings-known-provider-names;
    in property <[KnownProviderItem]> settings-subscription-known-providers;
    in property <[string]> settings-subscription-known-provider-names;
    in property <[KnownProviderItem]> settings-api-known-providers;
    in property <[string]> settings-api-known-provider-names;
    in property <[KnownProviderItem]> settings-local-known-providers;
    in property <[string]> settings-local-known-provider-names;
    in property <[string]> settings-models;
    in property <int> settings-default-model-index: -1;
    in property <[ThinkingItem]> settings-model-thinking-items;
    in-out property <int> settings-default-thinking-index: -1;
    in property <int> settings-default-permission-index: 0;
    in property <[ModeItem]> settings-mode-items;
    in property <[string]> settings-mode-model-names;
    in property <string> settings-status: "";
    in-out property <int> settings-preset-index: 0;
    // Which settings section shows when the screen opens (0 providers …
    // 3 integrations); the controller sets it before flipping center-screen.
    in-out property <int> settings-section: 0;
    in property <[GithubHostItem]> settings-github-hosts;
    callback github-token-saved(/* host */ string, /* token */ string);
    callback github-host-added(/* host */ string, /* client-id */ string);
    callback github-host-removed(/* host */ string);
    in property <[SubscriptionItem]> settings-subscriptions;
    in property <string> settings-subscriptions-status: "";
    in property <[McpServerItem]> settings-mcp-servers;
    in property <string> settings-mcp-status: "";
    in property <string> settings-mcp-logs-name: "";
    in property <string> settings-mcp-logs-text: "";
    in property <[string]> settings-mcp-workspace-names;
    in property <[string]> settings-mcp-workspace-ids;
    // Effective MCP config for the open session (right-panel tab): merged
    // scopes with the winning layer in `scope` (app-wide/workspace/branch).
    in property <[McpServerItem]> session-mcp-servers;
    in property <string> session-mcp-status: "";
    callback refresh-session-mcp();
    callback mcp-refresh();
    callback mcp-saved(/* name */ string, /* scope */ string,
                       /* command-line */ string, /* env-lines */ string,
                       /* workspace-id */ string);
    callback mcp-deleted(/* name */ string, /* scope */ string,
                         /* workspace-id */ string);
    callback mcp-logs-requested(string);
    callback mcp-logs-closed();
    callback provider-saved(/* id */ string, /* kind */ string,
                            /* base-url */ string, /* api-key */ string);
    callback provider-deleted(string);
    callback provider-login(string);
    callback default-model-picked(int, string);
    callback default-permission-picked(int);
    callback mode-saved(string, string, string, string, bool, int, int, string);
    callback mode-deleted(string);
    callback mode-model-picked(string, int);
    callback mode-thinking-picked(string, string);
    callback refresh-settings();
    callback cli-install(/* id */ string);
    callback cli-cancel(/* id */ string);
    callback cli-uninstall(/* id */ string);
    callback close-settings();

    // Local (offline) models — state pushed by the controller, actions out.
    in property <[LocalModelItem]> local-models;
    in property <bool> local-enabled: true;
    in property <string> local-hw-line: "";
    in property <string> local-runtime-label: "";
    in property <string> local-runtime-action: "Install";
    in property <bool> local-runtime-busy: false;
    in property <int> local-runtime-progress: -1;
    in property <bool> local-runtime-managed: false;
    in property <bool> local-runtime-update: false;
    in property <string> local-runtime-status: "";
    in property <string> local-server-line: "";
    in property <bool> local-server-busy: false;
    in property <string> local-status: "";
    in-out property <string> local-search-query: "";
    in property <[LocalSearchItem]> local-search-results;
    in property <string> local-search-status: "";
    callback local-search(/* query */ string);
    callback local-search-filters-changed(/* gpu */ bool, /* cpu */ bool, /* too-large */ bool);
    callback local-refresh();
    callback local-enabled-toggled(bool);
    callback local-runtime-install();
    callback local-runtime-cancel();
    callback local-runtime-uninstall();
    callback local-download(string);
    callback local-cancel(string);
    callback local-delete(string);
    callback local-stop-server();
    callback local-restart-server();
    callback local-added(/* repo */ string, /* file */ string);

    // Appearance (handled on the Rust UI thread; see src/theme.rs).
    in property <[string]> appearance-theme-names;
    in-out property <int> appearance-theme-index: 0;
    in property <[string]> appearance-font-size-names;
    in-out property <int> appearance-font-size-index: 0;
    in property <[string]> appearance-font-names;
    in-out property <int> appearance-font-index: 0;
    in-out property <bool> appearance-reduce-motion: false;
    callback appearance-theme-picked(int);
    callback appearance-font-size-picked(int);
    callback appearance-font-picked(int);
    callback appearance-reduce-motion-toggled(bool);

    // Desktop notification preferences (handled on the Rust UI thread;
    // see src/notify.rs and winstate::Notifications).
    in-out property <bool> notify-enabled: true;
    in-out property <bool> notify-finish: true;
    in-out property <bool> notify-fail: true;
    in-out property <bool> notify-attention: true;
    in-out property <bool> notify-sound: false;
    callback notify-pref-toggled(/* which */ int, /* on */ bool);
    callback notify-test();

    in property <[ThreadTabItem]> threads;
    in property <int> current-thread: -1;
    callback thread-selected(int);
    callback new-thread();

    in property <[ChatRow]> chat-rows;
    callback approval-resolved(/* row index */ int, /* approved */ bool);
    // Question wizard (kind 10): option toggles (index == options.length is
    // the "Other" choice), free-form text edits, and page navigation.
    callback question-option-toggled(/* row index */ int, /* option */ int);
    callback question-other-edited(/* row index */ int, /* text */ string);
    callback question-back(/* row index */ int);
    callback question-next(/* row index */ int);
    callback question-skip(/* row index */ int);
    callback tool-toggled(/* row index */ int);
    callback raw-toggled(/* turn */ int);
    callback card-toggled(/* card key */ string);
    // Filename click on a Read/Edit tool card: open the file in the Files
    // tab; a nonzero 1-based line range gets preselected there.
    callback chat-file-opened(/* path */ string, /* from */ int, /* to */ int);
    // File-view selection (0-based inclusive lines; from < 0 clears),
    // applied by the CodeView whenever the seq is bumped.
    in property <int> file-sel-from: -1;
    in property <int> file-sel-to: -1;
    in property <int> file-sel-seq: 0;
    // Right-panel tab (0 diff, 1 files, 2 pull requests, 3 mcp,
    // 4 terminal); the controller flips it when a chat click opens a file,
    // and watches it to lazily attach the terminal.
    in-out property <int> right-tab: 0;
    callback right-tab-changed(int);
    changed right-tab => { root.right-tab-changed(root.right-tab); }
    callback send-message(string);
    callback cancel-turn();
    in property <bool> composer-enabled: false;
    in property <bool> composer-turn-running: false;
    // Draft survives the composer being swapped out for the new-thread form.
    // in-out: Rust splices "@path " mentions into it when one is picked.
    in-out property <string> composer-draft;
    // Files staged for the next prompt (screenshots, logs, …).
    in property <[AttachmentChip]> composer-attachments: [];
    callback attach-file();
    callback attachment-removed(int);
    // Ctrl/Cmd+V in the composer: returns true when the clipboard held an
    // image that was captured as an attachment (so the paste shouldn't
    // also insert text).
    callback paste-image-attempted() -> bool;

    // "/" skill completion: the harness's slash commands (parallel name /
    // description lists), the fuzzy-ranked match indices (best first,
    // capped), and the best match as ready-to-send text ("/simplify").
    // Rust recomputes matches/active on every draft edit; Escape suppresses
    // the popup until the next edit.
    in property <[string]> slash-commands;
    in property <[string]> slash-details;
    in property <[int]> slash-matches;
    in-out property <bool> slash-active: false;
    in property <string> slash-completion;
    property <bool> slash-suppressed: false;
    callback slash-filter-changed(string);
    changed composer-draft => {
        root.slash-suppressed = false;
        root.at-suppressed = false;
        root.slash-filter-changed(root.composer-draft);
        root.at-filter-changed(root.composer-draft, root.composer-cursor);
    }

    // "@" file mentions: the session worktree's paths (files, dirs with a
    // trailing '/'), the fuzzy-ranked match indices for the token under the
    // cursor, and the highlighted row. Rust parses the token and filters on
    // every edit or caret move; picking splices "@path " into the draft.
    in property <[string]> at-files;
    in property <[int]> at-matches;
    in-out property <bool> at-active: false;
    in-out property <int> at-selected: 0;
    property <bool> at-suppressed: false;
    // Caret byte offset, mirrored out of the composer so filters and the
    // splice both know which "@token" is under edit.
    in-out property <int> composer-cursor: 0;
    // Post-splice caret placement (see PromptBox.cursor-seq).
    in-out property <int> composer-cursor-seq: 0;
    in-out property <int> composer-cursor-target: 0;
    callback at-filter-changed(/* draft */ string, /* cursor */ int);
    callback at-picked(/* index into at-files */ int);
    changed at-files => {
        root.at-filter-changed(root.composer-draft, root.composer-cursor);
    }

    // --- queued prompts ---------------------------------------------------
    // Prompts waiting their turn on the current thread, in run order. Rows
    // support inline editing, reordering (drag the ⠿ handle, or the ↑/↓
    // buttons for single steps), and deletion. The "Send now" pill shows
    // when the thread is idle: prompts left queued by a restart/crash or
    // paused by a failed turn never auto-run — a crash may have cut the
    // previous turn short, so resuming is the user's call.
    in property <[string]> queue-prompts;
    // Per-row attachment badge ("📎2"; empty hides it). Parallel to
    // queue-prompts so the editable row text stays pristine.
    in property <[string]> queue-badges;
    in property <bool> queue-idle: false;
    callback queue-edited(/* index */ int, /* content */ string);
    callback queue-deleted(/* index */ int);
    callback queue-moved(/* index */ int, /* delta, -1 up / +1 down */ int);
    callback queue-reordered(/* from */ int, /* to */ int);
    callback queue-send-now();
    callback queue-send-now-at(int);
    // Row currently showing its inline editor (-1 = none). Any queue change
    // replaces the list model, which resets this — indices may have shifted.
    property <int> queue-editing: -1;
    // Drag-to-reorder state: the row being dragged and its pointer
    // displacement. Rows are uniform height while dragging (the drag closes
    // any open editor), so the drop slot falls out of the row pitch.
    property <int> queue-drag-from: -1;
    property <length> queue-drag-dy: 0px;
    property <length> queue-row-pitch: Theme.fs(24px) + 4px;
    pure function queue-drop-target() -> int {
        Math.max(0, Math.min(root.queue-prompts.length - 1,
            root.queue-drag-from + Math.round(root.queue-drag-dy / root.queue-row-pitch)))
    }
    changed queue-prompts => {
        root.queue-editing = -1;
        root.queue-drag-from = -1;
        root.queue-drag-dy = 0px;
    }
    // Connectivity loss mid-drag or mid-edit: the controls disable, so a
    // stuck drag or an orphaned editor must be dropped too.
    changed connectivity-blocked => {
        if (root.connectivity-blocked) {
            root.queue-editing = -1;
            root.queue-drag-from = -1;
            root.queue-drag-dy = 0px;
        }
    }

    in-out property <string> error-text: "";

    // Server connectivity. While `connectivity-text` is set a banner shows
    // on the composer, the new-chat form, and the automations screen;
    // `connectivity-blocked` additionally disables all prompt entry (server
    // unreachable, or offline with no local models to fall back on).
    // `connectivity-severe` renders it red: the connection to the server
    // itself is gone, not just the server's internet. The notice is the
    // transient recovery confirmation, cleared by the controller.
    in property <bool> connectivity-blocked: false;
    in property <bool> connectivity-severe: false;
    in property <string> connectivity-text: "";
    in property <string> connectivity-notice: "";

    in property <[string]> modes;
    // Aligned with modes: each mode's default model as an index into
    // models (-1 = none/global default).
    in property <[int]> mode-model-indices;
    in property <[string]> models;
    // Fuzzy-filtered model indices for the search pickers (Rust computes;
    // only one picker popup is ever open, so the state is shared).
    in property <[int]> model-filter-matches;
    callback model-filter-changed(string);
    in-out property <int> mode-index: -1;
    in-out property <int> model-index: -1;
    callback composer-mode-changed(int);
    callback composer-model-changed(int);

    // Model knobs, derived from the current model's options schema.
    // Empty thinking-options / context-options hide their dropdowns;
    // fast-visible gates the fast/priority toggle (Cursor only).
    in property <[string]> thinking-options;
    in-out property <int> thinking-index: -1;
    in property <[string]> context-options;
    in-out property <int> context-index: -1;
    in property <bool> fast-visible: false;
    in-out property <bool> fast-checked: false;
    callback composer-thinking-changed(int);
    in property <[string]> permission-options: ["Ask", "Allow list", "Yolo"];
    in-out property <int> permission-index: 0;
    property <bool> composer-yolo-selected: root.permission-index >= 0
        && root.permission-index < root.permission-options.length
        && root.permission-options[root.permission-index] == "Yolo";
    callback composer-permission-changed(int);
    callback composer-context-changed(int);
    callback composer-fast-toggled(bool);

    // Session usage + context indicator (composer bar).
    in property <string> usage-text: "";
    in property <float> context-fill: 0.0;
    in property <bool> context-compacting: false;
    in property <string> context-tooltip: "no usage yet";

    // --- new-chat screen -------------------------------------------------------
    in property <[string]> nc-workspaces;
    in property <[string]> nc-branches;
    in-out property <int> nc-workspace-index: -1;
    in-out property <int> nc-branch-index: -1;
    in-out property <bool> nc-fetch-latest: true;
    in-out property <int> nc-mode-index: 0;
    in-out property <int> nc-model-index: 0;
    in property <[string]> nc-thinking-options;
    in-out property <int> nc-thinking-index: -1;
    in-out property <int> nc-permission-index: 0;
    in property <[string]> nc-permission-options: ["Mode default", "Ask", "Allow list", "Yolo"];
    callback nc-model-changed(int);
    changed nc-model-index => { root.nc-model-changed(root.nc-model-index); }
    callback nc-workspace-changed(int);
    callback register-workspace-path(string);
    callback start-new-chat(/* ws */ int, /* branch */ int, /* fetch */ bool, /* mode */ int,
                            /* model */ int, /* thinking */ int,
                            /* permission */ int, /* prompt */ string);
    callback cancel-new-chat();

    // --- right column -------------------------------------------------------
    in property <[DiffRow]> diff-rows;
    in property <[string]> diff-file-texts;
    // Raw unified diff / raw file content backing the views, for copying.
    in property <string> diff-text: "";
    in property <string> open-file-text: "";
    callback diff-file-toggled(int);
    callback undo-turn();
    callback redo-turn();

    // --- pull requests tab -------------------------------------------------
    // Whether the GitHub integration can authenticate (setup prompt when
    // false), the PRs detected for the current session branch, and which
    // one the detail view shows.
    in property <bool> pr-configured: false;
    in property <[string]> pr-labels;
    in property <[PrItem]> pr-items;
    in-out property <int> pr-selected: 0;
    // Fetch failure or "loading…" note; empty when the list is live.
    in property <string> pr-error: "";
    callback create-pr();
    callback refresh-prs();
    callback pr-picked(int);
    callback open-pr-url(string);
    callback open-integrations-settings();

    // --- terminal tab --------------------------------------------------
    // Interactive shell in the current session's worktree. Rust owns the
    // screen model (vt100) and pushes styled rows; the grid reports keys,
    // pastes, wheel scrolls, and cell-size changes back.
    in property <[[TermSpan]]> term-lines;
    in property <int> term-cursor-row: -1;
    in property <int> term-cursor-col: -1;
    in property <int> term-scrollback: 0;
    // Non-empty while there's something to say ("shell exited", errors).
    in property <string> term-status: "";
    in property <bool> term-attached: false;
    callback term-key(/* text */ string, /* ctrl */ bool, /* alt */ bool, /* shift */ bool);
    callback term-paste(string);
    callback term-wheel(/* lines, + = history */ int);
    callback term-resized(/* cols */ int, /* rows */ int);
    callback term-restart();

    in property <[FileItem]> file-entries;
    callback file-activated(int);
    // Files tab: whether the file-list drawer beside the viewer is open.
    in-out property <bool> files-drawer-open: true;
    in property <[[TextSegment]]> file-lines;
    in property <[int]> file-numbers;
    in property <string> open-file-name: "";
    // Markdown preview for the open file (toggle lives in the file header).
    in property <bool> file-is-markdown: false;
    in-out property <bool> file-preview: false;
    in property <[ChatRow]> file-preview-rows;
    // Open the file in the user's preferred (system default) editor.
    callback file-opened-externally(/* worktree-relative path */ string);

    // Emitted for explicit user scrolling (and an invalid-anchor fallback).
    // Ordinary programmatic layout settling never reaches persistence.
    callback chat-position-changed(/* thread */ string, /* row */ int,
        /* offset within row */ length, /* at tail */ bool);

    // While true, the chat stays pinned to its tail as content grows.
    // scroll-chat-to-end alone isn't enough: it runs before the ListView
    // re-measures freshly grown rows, so the bottom (activity spinner)
    // would sit below the fold until the next event. The pin re-applies on
    // every viewport-height change; renders that must not move the view
    // (expand/collapse toggles, restored positions) clear it.
    in-out property <bool> chat-follow: false;
    // The viewport-y/viewport-height the tail pin last wrote. The
    // viewport-y watcher compares against them to tell user scrolls
    // (which end following) from pin writes and the ListView's own
    // layout adjustments (which don't). Corrections are deferred through
    // chat-pin-timer: writing viewport-y from a viewport change handler
    // makes ListView remeasure synchronously and can exceed Slint's
    // callback/instantiation stabilization limit.
    property <length> chat-pin-y: 0px;
    property <length> chat-pin-h: 0px;
    property <bool> chat-pin-pending: false;
    chat-pin-timer := Timer {
        interval: 1ms;
        running: root.chat-pin-pending;
        triggered => {
            root.chat-pin-pending = false;
            if (root.chat-follow) {
                chat-list.viewport-y = min(0px,
                    chat-list.visible-height - chat-list.viewport-height);
                root.chat-pin-y = chat-list.viewport-y;
                root.chat-pin-h = chat-list.viewport-height;
            }
        }
    }
    public function scroll-chat-to-end() {
        root.chat-restoring = false;
        root.chat-follow = true;
        chat-list.viewport-y = min(0px, chat-list.visible-height - chat-list.viewport-height);
        root.chat-pin-y = chat-list.viewport-y;
        root.chat-pin-h = chat-list.viewport-height;
        // ListView may remeasure rows after this callback returns. Coalesce
        // the final correction onto the next event-loop tick.
        root.chat-pin-pending = true;
    }
    // Intentional navigation (send/notification/running/queued) supersedes
    // any debounced user bookmark still waiting to be persisted.
    public function force-chat-to-end() {
        root.chat-scroll-dirty = false;
        root.chat-scroll-pending = false;
        chat-scroll-save-timer.stop();
        root.scroll-chat-to-end();
    }

    // Mid-history positions use a rendered-row anchor, not a raw pixel
    // offset. ListView virtualizes and estimates row heights, so restoring
    // is a convergence mode: whenever the top visible row is laid out, move
    // toward the saved row and keep the saved within-row offset stable.
    in-out property <bool> chat-restoring: false;
    property <int> chat-restore-row: 0;
    property <length> chat-restore-offset: 0px;
    property <bool> chat-live-anchor-valid: false;
    property <int> chat-live-anchor-row: 0;
    property <length> chat-live-anchor-offset: 0px;
    property <bool> chat-scroll-dirty: false;
    property <string> chat-scroll-dirty-key;
    property <bool> chat-scroll-pending: false;
    property <string> chat-scroll-pending-key;
    property <int> chat-scroll-pending-row: 0;
    property <length> chat-scroll-pending-offset: 0px;
    property <bool> chat-scroll-pending-at-bottom: false;

    chat-scroll-save-timer := Timer {
        interval: 150ms;
        running: false;
        triggered => {
            self.stop();
            if (root.chat-scroll-pending
                    && root.chat-scroll-pending-key != "") {
                root.chat-position-changed(root.chat-scroll-pending-key,
                    root.chat-scroll-pending-row,
                    root.chat-scroll-pending-offset,
                    root.chat-scroll-pending-at-bottom);
            }
            root.chat-scroll-pending = false;
        }
    }

    function converge-chat-anchor() {
        if (!root.chat-restoring || !root.chat-live-anchor-valid
                || root.chat-rows.length == 0) {
            return;
        }
        if (root.chat-restore-row >= root.chat-rows.length) {
            // The rendered transcript changed enough that the row no longer
            // exists. Persist the tail fallback so later opens do not retry
            // the same invalid anchor.
            root.chat-position-changed(root.chat-thread-key, 0, 0px, true);
            root.scroll-chat-to-end();
            return;
        }
        chat-list.viewport-y = clamp(
            chat-list.viewport-y
                + root.chat-live-anchor-offset - root.chat-restore-offset
                - (root.chat-restore-row - root.chat-live-anchor-row)
                    * (chat-list.viewport-height / root.chat-rows.length),
            min(0px, chat-list.visible-height - chat-list.viewport-height),
            0px);
    }

    function observe-chat-row(index: int, row-y: length, row-height: length) {
        if (row-height > 0px && row-y <= 0px && row-y + row-height > 0px) {
            root.chat-live-anchor-valid = true;
            root.chat-live-anchor-row = index;
            root.chat-live-anchor-offset = -row-y;
            if (root.chat-scroll-dirty) {
                root.chat-scroll-dirty = false;
                root.chat-scroll-pending = true;
                root.chat-scroll-pending-key = root.chat-scroll-dirty-key;
                root.chat-scroll-pending-row = index;
                root.chat-scroll-pending-offset = -row-y;
                root.chat-scroll-pending-at-bottom = root.chat-at-bottom;
                chat-scroll-save-timer.stop();
                chat-scroll-save-timer.start();
            }
            root.converge-chat-anchor();
        }
    }

    function begin-user-chat-scroll() {
        root.chat-follow = false;
        root.chat-restoring = false;
        if (!root.chat-scroll-dirty) {
            root.chat-scroll-dirty-key = root.chat-thread-key;
        }
        root.chat-scroll-dirty = true;
    }

    // Called before swapping transcripts. If a switch races the final
    // layout frame of a user scroll, flush the last known anchor under the
    // old thread key instead of ever booking it to the new thread.
    public function reset-chat-positioning() {
        if (root.chat-scroll-dirty && root.chat-scroll-dirty-key != ""
                && root.chat-live-anchor-valid) {
            root.chat-position-changed(root.chat-scroll-dirty-key,
                root.chat-live-anchor-row, root.chat-live-anchor-offset,
                root.chat-at-bottom);
        } else if (root.chat-scroll-pending
                && root.chat-scroll-pending-key != "") {
            root.chat-position-changed(root.chat-scroll-pending-key,
                root.chat-scroll-pending-row,
                root.chat-scroll-pending-offset,
                root.chat-scroll-pending-at-bottom);
        }
        chat-scroll-save-timer.stop();
        root.chat-scroll-dirty = false;
        root.chat-scroll-pending = false;
        root.chat-follow = false;
        root.chat-restoring = false;
        root.chat-live-anchor-valid = false;
    }

    public function restore-chat-position(row: int, offset: length) {
        root.chat-follow = false;
        root.chat-scroll-dirty = false;
        root.chat-scroll-pending = false;
        chat-scroll-save-timer.stop();
        root.chat-restoring = true;
        root.chat-restore-row = max(0, row);
        root.chat-restore-offset = max(0px, offset);
        root.chat-live-anchor-valid = false;
        // The first measured visible row drives the accurate seek. This
        // estimate gets it close enough for ListView to instantiate useful
        // delegates immediately on long transcripts.
        if (root.chat-rows.length > 0) {
            chat-list.viewport-y = clamp(
                -root.chat-restore-row
                    * (chat-list.viewport-height / root.chat-rows.length)
                    - root.chat-restore-offset,
                min(0px, chat-list.visible-height - chat-list.viewport-height),
                0px);
        }
    }
    // True while the view rests at the tail. In-place re-renders read it to
    // keep the bottom anchored: the ListView re-derives viewport-y from
    // estimated row heights, so collapsing a card at the bottom would
    // otherwise land the viewport at a visibly wrong spot.
    out property <bool> chat-at-bottom: chat-list.viewport-y
        <= chat-list.visible-height - chat-list.viewport-height + 12px;

    // Live pixel position is still exposed for diagnostics; persisted
    // where-you-left-off state uses the row anchor above.
    in-out property <length> chat-scroll <=> chat-list.viewport-y;
    // The thread whose transcript the list is currently showing, written in
    // the same event as the rows. The shell samples it together with
    // chat-scroll so an offset polled around a thread switch is booked to
    // the thread that was actually on screen, not whichever became current
    // by the time the sample reached the controller.
    in-out property <string> chat-thread-key;

    // Quit confirmation while agents run: closing the window with active
    // turns opens the modal instead of quitting.
    in property <int> agents-running: 0;
    in-out property <bool> quit-dialog: false;
    callback quit-now();
    callback quit-when-idle();

    HorizontalLayout {
        // Hidden (not removed — the chat list keeps its scroll state) while
        // a full-window screen (settings, automations, pull requests) is up.
        visible: root.center-screen != 3 && root.center-screen != 4
            && root.center-screen != 5;

        // ---------------- left: sessions ----------------
        Rectangle {
            width: root.left-width;
            background: Theme.c.sidebar-bg;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                // App-level nav (above the workspace/session tree).
                Rectangle {
                    height: Theme.fs(34px);
                    border-radius: 6px;
                    background: pull-requests-ta.has-hover ? Theme.c.hover-bg : Theme.c.raised-bg;
                    pull-requests-ta := TouchArea {
                        clicked => { root.open-pull-requests(); }
                    }
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;
                        Text {
                            text: "⎇";
                            color: Theme.c.text-mid;
                            font-size: Theme.fs(14px);
                            vertical-alignment: center;
                        }
                        Text {
                            text: "Pull Requests";
                            color: Theme.c.text-hi;
                            font-size: Theme.fs(13px);
                            font-weight: 700;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                }

                Rectangle {
                    height: Theme.fs(34px);
                    border-radius: 6px;
                    background: automations-ta.has-hover ? Theme.c.hover-bg : Theme.c.raised-bg;
                    automations-ta := TouchArea {
                        clicked => { root.open-automations(); }
                    }
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;
                        Text {
                            text: "⏱";
                            color: Theme.c.text-mid;
                            font-size: Theme.fs(14px);
                            vertical-alignment: center;
                        }
                        Text {
                            text: "Automations";
                            color: Theme.c.text-hi;
                            font-size: Theme.fs(13px);
                            font-weight: 700;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                }

                HorizontalLayout {
                    Text {
                        text: "Workspaces";
                        color: Theme.c.text-hi;
                        font-size: Theme.fs(15px);
                        font-weight: 700;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Button {
                        text: "+ Open";
                        clicked => { root.open-workspace(); }
                    }
                }

                ScrollKeys {
                    vertical-stretch: 1;
                    target-y <=> nav-list.viewport-y;
                    page: nav-list.visible-height;
                    total: nav-list.viewport-height;
                nav-list := ListView {
                    // Scrolling can move/recycle a hovered button without a
                    // hover-out; drop any tooltip it left behind.
                    changed viewport-y => {
                        Tip.hide-all();
                        // A virtual-list remeasurement must never strand the
                        // viewport beyond its content. Besides rendering an
                        // empty nav, that invalid offset leaves the scrollbar
                        // unable to return to the rows.
                        self.viewport-y = clamp(self.viewport-y,
                            min(0px, self.visible-height - self.viewport-height), 0px);
                    }
                    for row[idx] in root.nav-rows: Rectangle {
                        // Match the chat pane's right-side gutter so the
                        // scrollbar never covers trailing row controls.
                        width: parent.width - 18px;
                        height: Theme.fs(row.kind == 1 ? 52px : row.kind == 0 ? 34px : 30px);
                        background: row.kind == 0
                            ? (row-ta.has-hover ? Theme.c.hover-bg : Theme.c.raised-bg)
                            : row.kind == 1 && row.selected ? Theme.c.accent-bg : transparent;
                        border-radius: 6px;
                        border-width: row.kind == 0 && workspace-drop.has-drag ? 2px : 0px;
                        border-color: Theme.c.accent;

                        // A header accepts the dragged workspace before or
                        // after itself, depending on which half is released.
                        workspace-drop := DropArea {
                            enabled: row.kind == 0 && row.workspace-count > 1;
                            can-drop(event) => {
                                root.workspace-drag-acceptable(event.data)
                                    ? DragAction.move : DragAction.none
                            }
                            dropped(event) => {
                                if (root.workspace-dropped(
                                    event.data,
                                    row.workspace-id,
                                    event.position.y >= self.height / 2
                                )) {
                                    return DragAction.move;
                                }
                                return DragAction.none;
                            }
                        }

                        row-menu := PopupWindow {
                            x: parent.width - 150px;
                            y: 28px;
                            width: 150px;
                            height: 3 * Theme.fs(30px) + 10px;
                            Rectangle {
                                background: Theme.c.popup-bg;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.c.border;
                                VerticalLayout {
                                    padding: 4px;
                                    Rectangle {
                                        height: Theme.fs(30px);
                                        background: rename-ta.has-hover ? Theme.c.accent-bg : transparent;
                                        border-radius: 4px;
                                        rename-ta := TouchArea {
                                            clicked => {
                                                root.modal-title = row.title;
                                                root.rename-row = idx;
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            text: "Rename";
                                            color: Theme.c.text;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        height: Theme.fs(30px);
                                        background: archive-ta.has-hover ? Theme.c.accent-bg : transparent;
                                        border-radius: 4px;
                                        archive-ta := TouchArea {
                                            clicked => {
                                                root.session-archived(idx, !row.archived);
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            text: row.archived ? "Unarchive" : "Archive";
                                            color: Theme.c.text;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        height: Theme.fs(30px);
                                        background: delete-ta.has-hover ? Theme.c.err-hover : transparent;
                                        border-radius: 4px;
                                        delete-ta := TouchArea {
                                            clicked => {
                                                root.modal-title = row.title;
                                                root.delete-row = idx;
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            text: "Delete…";
                                            color: Theme.c.err;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }

                        row-ta := TouchArea {
                            clicked => { root.nav-row-clicked(idx); }
                        }

                        // Session-list filter menu (opened from the funnel
                        // button in the workspace header).
                        filter-menu := PopupWindow {
                            x: parent.width - 190px;
                            y: 32px;
                            width: 180px;
                            height: Theme.fs(24px) + Theme.fs(30px) + 16px;
                            Rectangle {
                                background: Theme.c.popup-bg;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.c.border;
                                VerticalLayout {
                                    padding: 4px;
                                    Rectangle {
                                        height: 24px;
                                        Text {
                                            x: 8px;
                                            text: "Filters";
                                            color: Theme.c.text-soft;
                                            font-size: Theme.fs(11px);
                                            vertical-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        height: Theme.fs(30px);
                                        background: archived-filter-ta.has-hover
                                            ? Theme.c.accent-bg : transparent;
                                        border-radius: 4px;
                                        archived-filter-ta := TouchArea {
                                            clicked => {
                                                root.archived-filter-toggled(idx);
                                            }
                                        }
                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            Text {
                                                text: "Archived";
                                                color: Theme.c.text;
                                                font-size: Theme.fs(12px);
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                            }
                                            if row.show-archived: Text {
                                                text: "✓";
                                                color: Theme.c.text;
                                                font-size: Theme.fs(12px);
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Workspace header: chevron + name, filter menu, and
                        // "+" starts a session in this workspace. Clicking
                        // elsewhere collapses/expands the group.
                        if row.kind == 0: HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 4px;
                            spacing: 6px;
                            Text {
                                text: row.expanded ? "⌄" : "›";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                                vertical-alignment: center;
                            }
                            Text {
                                text: row.title;
                                color: Theme.c.text;
                                font-size: Theme.fs(13px);
                                font-weight: 700;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                            // Pointer drag handle and keyboard/assistive-
                            // technology position control. Up/Down performs
                            // the same adjacent moves as a pointer drop.
                            reorder-grip := Rectangle {
                                width: 22px;
                                height: 26px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 5px;
                                background: reorder-ta.has-hover || reorder-focus.has-focus
                                    ? Theme.c.border : transparent;
                                border-width: reorder-focus.has-focus ? 1px : 0px;
                                border-color: Theme.c.accent;

                                reorder-focus := FocusScope {
                                    property <int> focus-generation: root.workspace-reorder-focus-generation;
                                    function apply-pending-focus() {
                                        if (root.workspace-reorder-focus-id == row.workspace-id) {
                                            self.focus();
                                            root.workspace-reorder-focus-id = "";
                                        }
                                    }
                                    enabled: row.workspace-count > 1;
                                    accessible-role: slider;
                                    accessible-label: "Position of " + row.title;
                                    accessible-description: "Drag or use Up and Down arrow keys to reorder";
                                    accessible-enabled: self.enabled;
                                    accessible-value: "" + (row.workspace-position + 1);
                                    accessible-value-minimum: 1;
                                    accessible-value-maximum: row.workspace-count;
                                    accessible-value-step: 1;
                                    accessible-action-decrement => {
                                        if (row.workspace-position > 0) {
                                            root.workspace-reorder-focus-id = row.workspace-id;
                                            root.workspace-moved(row.workspace-id, -1);
                                        }
                                    }
                                    accessible-action-increment => {
                                        if (row.workspace-position + 1 < row.workspace-count) {
                                            root.workspace-reorder-focus-id = row.workspace-id;
                                            root.workspace-moved(row.workspace-id, 1);
                                        }
                                    }
                                    key-pressed(event) => {
                                        if (event.text == Key.UpArrow) {
                                            if (row.workspace-position > 0) {
                                                root.workspace-reorder-focus-id = row.workspace-id;
                                                root.workspace-moved(row.workspace-id, -1);
                                            }
                                            return accept;
                                        }
                                        if (event.text == Key.DownArrow) {
                                            if (row.workspace-position + 1 < row.workspace-count) {
                                                root.workspace-reorder-focus-id = row.workspace-id;
                                                root.workspace-moved(row.workspace-id, 1);
                                            }
                                            return accept;
                                        }
                                        return reject;
                                    }
                                    init => {
                                        self.apply-pending-focus();
                                    }
                                    changed focus-generation => {
                                        self.apply-pending-focus();
                                    }

                                    drag-source := DragArea {
                                        data: root.workspace-drag-data(row.workspace-id);
                                        allow-move: true;
                                        reorder-ta := TouchArea {
                                            enabled: row.workspace-count > 1;
                                            mouse-cursor: drag-source.dragging ? grabbing : grab;
                                            clicked => { reorder-focus.focus(); }
                                        }
                                    }
                                }
                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: "⠿";
                                    color: row.workspace-count > 1
                                        ? Theme.c.text-soft : Theme.c.text-ghost;
                                    font-size: Theme.fs(13px);
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            IconButton {
                                width: 26px;
                                height: 26px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 5px;
                                icon: "▽";
                                icon-size: Theme.fs(13px);
                                tip: "Filter sessions";
                                clicked => { filter-menu.show(); }
                            }
                            IconButton {
                                width: 26px;
                                height: 26px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 5px;
                                icon: "+";
                                icon-size: Theme.fs(15px);
                                tip: "New session in this workspace";
                                clicked => { root.workspace-new-session(idx); }
                            }
                        }

                        // Session row.
                        if row.kind == 1: HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 4px;
                            // Fixed-width slot in the indent left of the
                            // name: a pulsing accent dot while any of the
                            // session's threads runs a turn. Always present
                            // so titles align whether busy or not.
                            activity-slot := Rectangle {
                                width: 16px;
                                if row.busy: Rectangle {
                                    width: 7px;
                                    height: 7px;
                                    // Refer to the fixed slot explicitly: an
                                    // `if` element has an implementation
                                    // wrapper, so `parent.width` is not a
                                    // reliable centering anchor here.
                                    x: (activity-slot.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 3.5px;
                                    background: Theme.c.accent;
                                    opacity: Theme.reduce-motion
                                        ? 1.0
                                        : 0.55 + 0.45 * Math.sin(360deg * (animation-tick() / 1.6s));
                                }
                            }
                            VerticalLayout {
                                padding-top: 8px;
                                spacing: 2px;
                                horizontal-stretch: 1;
                                Text {
                                    text: row.title;
                                    color: row.archived ? Theme.c.text-soft : Theme.c.text-hi;
                                    font-size: Theme.fs(13px);
                                    overflow: elide;
                                }
                                Text {
                                    text: row.subtitle;
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(11px);
                                    overflow: elide;
                                }
                            }
                            if row.attention-kind != 0: IconButton {
                                width: 22px;
                                height: 28px;
                                y: (parent.height - self.height) / 2;
                                icon: row.attention-kind == 2 ? "?" : "!";
                                icon-size: Theme.fs(13px);
                                icon-color: Theme.c.warn;
                                hover-icon-color: Theme.c.warn;
                                hover-bg: Theme.c.warn-bg;
                                tip: row.attention-tooltip;
                                clicked => { root.nav-row-clicked(idx); }
                            }
                            if row.unread: IconButton {
                                width: 18px;
                                height: 28px;
                                y: (parent.height - self.height) / 2;
                                icon: "●";
                                icon-size: Theme.fs(8px);
                                icon-color: Theme.c.accent;
                                hover-icon-color: Theme.c.accent-hover;
                                hover-bg: transparent;
                                tip: "Unviewed work";
                                clicked => { root.nav-row-clicked(idx); }
                            }
                            if row.pr-kind != 0: IconButton {
                                width: 22px;
                                height: 28px;
                                y: (parent.height - self.height) / 2;
                                // Unicode's OCR fork is a compact,
                                // font-portable approximation of the
                                // familiar pull-request branch icon.
                                icon: "⑂";
                                icon-size: Theme.fs(15px);
                                icon-color: row.pr-kind == 1 ? Theme.c.ok
                                    : row.pr-kind == 2 ? Theme.c.text-dim
                                    : row.pr-kind == 3 ? Theme.c.accent
                                    : row.pr-kind == 4 ? Theme.c.err
                                    : Theme.c.text-mid;
                                hover-icon-color: self.icon-color;
                                hover-bg: Theme.c.hover-bg;
                                tip: row.pr-tooltip;
                                clicked => { root.nav-row-clicked(idx); }
                            }
                            IconButton {
                                width: 30px;
                                height: 30px;
                                y: (parent.height - self.height) / 2;
                                icon: "•••";
                                icon-size: Theme.fs(9px);
                                icon-color: Theme.c.text-disabled;
                                hover-icon-color: Theme.c.text-hi;
                                hover-bg: Theme.c.hover-bg;
                                tip: "Session actions";
                                clicked => { row-menu.show(); }
                            }
                        }

                        // Archived-group toggle.
                        if row.kind == 2: Text {
                            x: 22px;
                            text: (row.expanded ? "▾ " : "▸ ") + row.title;
                            color: Theme.c.text-faint;
                            font-size: Theme.fs(11px);
                            vertical-alignment: center;
                            height: 100%;
                        }
                    }
                }
                }

                // Footer: settings gear (bottom-left, app-level convention).
                HorizontalLayout {
                    IconButton {
                        icon: "⚙";
                        tip: "Settings";
                        width: 28px;
                        height: 28px;
                        icon-size: Theme.fs(18px);
                        clicked => { root.open-settings(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
            }
        }

        SplitterHandle {
            value <=> root.left-width;
            direction: 1;
            min-value: 190px;
            max-value: 460px;
        }

        // ---------------- center ----------------
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.c.win-bg;

            // ----- chat screen (kept in the tree so scroll-chat-to-end can
            // reach the list; hidden while the new-session or settings
            // screen is up). The new-thread form (center-screen 2) renders
            // *inside* this layout so the session's tab strip stays put —
            // the form lives in a provisional tab instead of replacing the
            // whole screen.
            // Wrapping the composer too means paging keys rejected by the
            // prompt's TextInput bubble here and scroll the chat.
            ScrollKeys {
            active: root.center-screen == 0;
            target-y <=> chat-list.viewport-y;
            page: chat-list.visible-height;
            total: chat-list.viewport-height;
            VerticalLayout {
                visible: root.center-screen == 0 || root.center-screen == 2;
                spacing: 0;

                // Header bar: error banner + thread tabs on their own
                // elevated strip (hairline + shadow), so scrolling chat
                // content reads as a layer underneath instead of blending
                // into the tabs.
                Rectangle {
                    background: Theme.c.panel-bg;
                    height: chat-header.preferred-height;
                    drop-shadow-color: #00000059;
                    drop-shadow-blur: 5px;
                    drop-shadow-offset-y: 1px;
                    chat-header := VerticalLayout {
                    padding: 10px;
                    spacing: 8px;

                // Error banner.
                if root.error-text != "": Rectangle {
                    background: Theme.c.err-bg;
                    border-radius: 6px;
                    height: banner.preferred-height + 12px;
                    banner := HorizontalLayout {
                        padding: 6px;
                        padding-left: 10px;
                        spacing: 8px;
                        Text {
                            text: root.error-text;
                            color: Theme.c.err-soft;
                            font-size: Theme.fs(12px);
                            wrap: word-wrap;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        IconButton {
                            width: 24px;
                            height: 24px;
                            icon: "✕";
                            icon-color: Theme.c.err-soft;
                            hover-bg: Theme.c.err-hover;
                            tip: "Dismiss";
                            clicked => { root.error-text = ""; }
                        }
                    }
                }

                // Thread tabs.
                HorizontalLayout {
                    spacing: 6px;
                    for thread[idx] in root.threads: Rectangle {
                        width: 130px;
                        height: Theme.fs(30px);
                        background: idx == root.current-thread ? Theme.c.accent-bg : Theme.c.control-bg;
                        border-radius: 6px;
                        TouchArea {
                            clicked => { root.thread-selected(idx); }
                        }
                        Text {
                            text: thread.label;
                            color: Theme.c.text;
                            font-size: Theme.fs(12px);
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                            width: parent.width - 12px;
                            x: 6px;
                        }
                    }
                    IconButton {
                        width: 30px;
                        height: Theme.fs(30px);
                        border-radius: 6px;
                        icon: "+";
                        icon-size: Theme.fs(15px);
                        idle-bg: Theme.c.control-bg;
                        tip: "New thread";
                        enabled: root.threads.length > 0 || root.composer-enabled;
                        clicked => { root.new-thread(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
                    }
                    // Hairline under the header keeps the boundary visible
                    // even where the shadow is too subtle to notice.
                    Rectangle {
                        y: parent.height - 1px;
                        width: 100%;
                        height: 1px;
                        background: Theme.c.border;
                    }
                }

                // Body: chat stream + composer, padded as before.
                VerticalLayout {
                    padding: 10px;
                    spacing: 8px;
                    vertical-stretch: 1;

                // Chat stream. The std ListView's own scrollbar can't jump
                // on track clicks and drifts while dragging, so a custom
                // scrollbar overlays it: absolute thumb positioning plus
                // click-to-jump. It sits exactly over the built-in bar and
                // swallows its pointer input.
                Rectangle {
                    vertical-stretch: 1;

                // New-thread form in the provisional tab: replaces only the
                // chat stream, leaving the session's tab strip in place.
                if root.center-screen == 2: NewChatForm {
                    width: 100%;
                    height: 100%;
                    session-form: false;
                    modes: root.modes;
                    mode-model-indices: root.mode-model-indices;
                    mode-index <=> root.nc-mode-index;
                    models: root.models;
                    model-matches: root.model-filter-matches;
                    model-index <=> root.nc-model-index;
                    thinking-options: root.nc-thinking-options;
                    thinking-index <=> root.nc-thinking-index;
                    permission-options: root.nc-permission-options;
                    permission-index <=> root.nc-permission-index;
                    blocked: root.connectivity-blocked;
                    blocked-severe: root.connectivity-severe;
                    offline-warning: root.connectivity-text;
                    online-notice: root.connectivity-notice;
                    attachments: root.composer-attachments;
                    attach-file => { root.attach-file(); }
                    attachment-removed(i) => { root.attachment-removed(i); }
                    paste-image-attempted => { root.paste-image-attempted() }
                    start(ws, br, fetch, mode, model, thinking, permission, prompt) => {
                        root.start-new-chat(ws, br, fetch, mode, model, thinking, permission, prompt);
                    }
                    cancel => { root.cancel-new-chat(); }
                    model-filter(q) => { root.model-filter-changed(q); }
                }

                chat-list := ListView {
                    visible: root.center-screen == 0;
                    width: 100%;
                    height: 100%;
                    // Scrolling can move/recycle a hovered button without a
                    // hover-out; drop any tooltip it left behind.
                    changed viewport-y => {
                        Tip.hide-all();
                        // A user scroll that leaves the tail ends
                        // following — without this the tail pin keeps
                        // snapping the view back to the bottom, fighting
                        // the scrollbar (it looks stuck and wiggles)
                        // after any at-the-tail re-render. But only a
                        // move with the content height unchanged is a
                        // user scroll: the pin's own writes and the
                        // ListView's layout adjustments (it re-derives
                        // viewport-y while re-measuring freshly
                        // instantiated rows) coincide with a
                        // viewport-height change, and must schedule another
                        // pin instead so a jump from far away converges on
                        // the bottom over a few event-loop ticks.
                        if (root.chat-follow && !root.chat-at-bottom
                                && self.viewport-y != root.chat-pin-y) {
                            if (self.viewport-height == root.chat-pin-h) {
                                root.chat-follow = false;
                                root.chat-pin-pending = false;
                            } else {
                                root.chat-pin-pending = true;
                            }
                        }
                    }
                    scrolled => { root.begin-user-chat-scroll(); }
                    // Keep the tail (activity spinner) on screen as rows
                    // grow during streaming; see chat-follow.
                    changed viewport-height => {
                        if (root.chat-follow) {
                            root.chat-pin-pending = true;
                        } else {
                            root.converge-chat-anchor();
                        }
                    }
                    // The queued-prompt panel changes the composer's height,
                    // hence the list's visible page rather than its content
                    // height. Both tail and row anchors must survive that.
                    changed visible-height => {
                        if (root.chat-follow) {
                            root.chat-pin-pending = true;
                        } else {
                            root.converge-chat-anchor();
                        }
                    }

                    for row[idx] in root.chat-rows: Rectangle {
                        changed y => {
                            root.observe-chat-row(idx, self.y, self.height);
                        }
                        changed height => {
                            root.observe-chat-row(idx, self.y, self.height);
                        }
                        // Markdown rows manage their own vertical rhythm via
                        // padding (lists tight, paragraphs spaced, headings
                        // set off); boxed rows keep a fixed gap. Headers get
                        // extra room above so cards separate.
                        height: row-content.preferred-height
                            + (row.kind == 1 && row.md-kind != 5 ? 0px
                                : row.kind == 7 ? 14px
                                // Turn rules pad equally via row-content.
                                : row.kind == 8 ? 0px
                                // Plain text bodies (prompt) sit in a card
                                // outline; no trailing gap.
                                : row.kind == 0 ? 0px
                                : 10px)
                            // A slab opening a card body pads down from
                            // the header.
                            + (row.card-first && box.slab ? 8px : 0px);
                        // Card rows clip an oversized border rectangle so
                        // only the outline edges that belong to this row
                        // remain visible (sides for body, sides + rounded
                        // bottom for the last row).
                        clip: row.card-pos == 2 || row.card-pos == 3;

                        // Tool rows keep their label in tool-name, but only
                        // nest inside assistant cards, so hardcode green.
                        property <color> card-line: row.kind == 2 ? Theme.c.agent-border
                            : row.tool-name == "You" ? Theme.c.user-border
                            : row.tool-name == "Agent" ? Theme.c.agent-border
                            : Theme.c.card-border;

                        if row.card-pos == 2 || row.card-pos == 3: Rectangle {
                            x: 0;
                            y: -8px;
                            // Leave the scrollbar gutter on the right.
                            width: parent.width - 18px;
                            height: parent.height + (row.card-pos == 2 ? 16px : 8px);
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: parent.card-line;
                        }

                        // The visible box: card bodies (message text,
                        // markdown, thinking, raw, turn status) inset under
                        // their header so they read as the card's content;
                        // headers and tool cards span the full width.
                        box := Rectangle {
                            property <bool> hdr: row.kind == 7;
                            property <bool> body: row.kind == 0 || row.kind == 1
                                || row.kind == 3 || row.kind == 4 || row.kind == 6
                                || row.kind == 9 || row.kind == 10
                                // Tool cards nested in an assistant card
                                // indent with the rest of the body, as does
                                // a nested activity row.
                                || ((row.kind == 2 || row.kind == 5) && row.card-pos >= 2);
                            property <bool> md-list: row.kind == 1
                                && (row.md-kind == 4 || row.md-kind == 6);
                            property <bool> md-heading: row.kind == 1
                                && row.md-kind >= 1 && row.md-kind <= 3;
                            // Rows drawn as filled slabs (tool cards,
                            // thinking, code fences, raw text) stop short
                            // of the row's trailing gap so stacked slabs
                            // get breathing room and never paint over the
                            // card outline.
                            property <bool> slab: row.kind == 2
                                || (row.kind == 1 && row.md-kind == 5)
                                || row.kind == 4
                                || row.kind == 6 || row.kind == 9
                                || row.kind == 10;

                            // Tool cards and thinking pills under an
                            // activity-group header (md-indent 1) and
                            // thinking content (tone 2) nest one level
                            // deeper.
                            property <length> indent: 16px
                                + (row.kind == 2 || row.kind == 4 ? row.md-indent * 16px : 0px)
                                + (row.kind == 1 && row.tone == 2 ? 16px : 0px);
                            x: self.body ? self.indent : 0px;
                            // The 18px keeps rows clear of the chat
                            // scrollbar.
                            width: parent.width - 18px
                                - (self.body ? self.indent + 8px : 0px);
                            // Headers leave the card-separating gap above;
                            // a slab that opens a card body drops below its
                            // header.
                            y: self.hdr || (self.slab && row.card-first) ? 8px : 0px;
                            height: parent.height - self.y
                                - (self.slab ? 10px : 0px);

                            // Card headers tint by source: prompt blue,
                            // assistant green; tool cards and thinking
                            // pills stay grey.
                            background: hdr && row.tool-name == "You" ? Theme.c.user-bg
                                : hdr && row.tool-name == "Agent" ? Theme.c.agent-bg
                                // Question wizard: amber while it wants an
                                // answer, settling to card grey once done.
                                : row.kind == 10 ? (row.q-done ? Theme.c.surface : Theme.c.warn-bg)
                                // Thinking pills share the tool-card grey.
                                : row.kind == 2 || row.kind == 4
                                    || row.kind == 9 || hdr ? Theme.c.surface
                                // Lighter than the window background so the
                                // block reads as a slab, not an outline.
                                : row.kind == 1 && row.md-kind == 5 ? Theme.c.code-bg
                                : row.kind == 6 ? Theme.c.inset-bg
                                : transparent;
                            // Headers with a body keep square bottom corners
                            // so they merge into the card outline below.
                            border-top-left-radius: 6px;
                            border-top-right-radius: 6px;
                            border-bottom-left-radius: hdr && row.card-pos == 1 ? 0px : 6px;
                            border-bottom-right-radius: hdr && row.card-pos == 1 ? 0px : 6px;
                            border-width: (row.kind == 1 && row.md-kind == 5)
                                || row.kind == 6 || row.kind == 10 || hdr ? 1px : 0px;
                            border-color: hdr && row.tool-name == "You" ? Theme.c.user-border
                                : hdr && row.tool-name == "Agent" ? Theme.c.agent-border
                                : row.kind == 10 ? (row.q-done ? Theme.c.card-border : Theme.c.warn-border)
                                : row.kind == 6 ? Theme.c.hover-bg
                                : hdr ? Theme.c.card-border
                                : Theme.c.card-border;

                            // Card and tool-group headers toggle their body
                            // on click anywhere that isn't a nested control
                            // (copy button sits on top and wins).
                            if row.kind == 7 || row.kind == 9: TouchArea {
                                clicked => { root.card-toggled(row.card-key); }
                            }

                            row-content := VerticalLayout {
                            padding: 6px;
                            padding-top: row.kind == 7 ? 2px
                                : row.kind == 8 ? 8px
                                : row.kind == 2 || row.kind == 4 || row.kind == 9 ? 3px
                                : md-list ? 2px : md-heading ? 14px : 6px;
                            padding-bottom: row.kind == 7 ? 2px
                                // The next card header brings its own 8px
                                // gap; adding more here would double the
                                // space below the rule.
                                : row.kind == 8 ? 0px
                                : row.kind == 2 || row.kind == 4 || row.kind == 9 ? 3px
                                : md-list ? 2px : md-heading ? 4px : 6px;
                            padding-left: md-list ? 22px + row.md-indent * 18px : 10px;
                            spacing: 4px;

                            // Card header: disclosure, title, collapsed
                            // preview, copy for the whole item.
                            if row.kind == 7: HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: row.expanded ? "▾" : "▸";
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(10px);
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.tool-name;
                                    color: Theme.c.text;
                                    font-size: Theme.fs(11px);
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                // Agent headers: the model that ran the turn.
                                if row.subtitle != "": Text {
                                    text: row.subtitle;
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(11px);
                                    vertical-alignment: center;
                                }
                                if !row.expanded: Text {
                                    text: row.text;
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(11px);
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                if row.expanded: Rectangle { horizontal-stretch: 1; }
                                // Assistant turns: token/cost summary and the
                                // styled-vs-raw view switch live in the header.
                                if row.meta != "": Text {
                                    text: row.meta;
                                    color: Theme.c.text-faint;
                                    font-size: Theme.fs(10px);
                                    vertical-alignment: center;
                                }
                                // Fixed-height icon buttons center on the
                                // header's cross axis instead of pinning to
                                // its top.
                                VerticalLayout {
                                    alignment: center;
                                    HorizontalLayout {
                                    spacing: 2px;
                                    // Styled-view toggle: eye lit = rendered
                                    // markdown, dimmed = raw selectable
                                    // source.
                                    if row.tool-name == "Agent": IconButton {
                                        width: 20px;
                                        height: Theme.fs(18px);
                                        icon: "👁";
                                        icon-color: row.raw ? Theme.c.text-disabled : Theme.c.accent;
                                        hover-icon-color: row.raw ? Theme.c.text-soft : Theme.c.accent-hover;
                                        idle-bg: row.raw ? transparent : Theme.c.accent-veil;
                                        hover-bg: Theme.c.hover-strong;
                                        tip: row.raw ? "Show styled view"
                                            : "Show raw markdown";
                                        clicked => { root.raw-toggled(row.turn); }
                                    }
                                    CopyButton {
                                        payload: row.detail;
                                        height: Theme.fs(18px);
                                        tip: row.tool-name == "You" ? "Copy message"
                                            : row.tool-name == "Agent" ? "Copy response"
                                            : "Copy thinking";
                                    }
                                    }
                                }
                            }

                            // User message: selectable body under its card
                            // header.
                            // Markdown block: code fences render as
                            // selectable monospace text under a header
                            // (language label + copy); everything else
                            // renders inline markup through StyledText.
                            if row.kind == 1 && row.md-kind == 5: HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    text: row.md-lang == "" ? "code" : row.md-lang;
                                    color: Theme.c.text-disabled;
                                    font-size: Theme.fs(11px);
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                CopyButton { payload: row.text; tip: "Copy code"; }
                            }
                            // Syntax-highlighted code lines. Fixed line
                            // height keeps the block's size deterministic
                            // (empty lines would otherwise collapse).
                            if row.kind == 1 && row.md-kind == 5: VerticalLayout {
                                for line in row.code-lines: Rectangle {
                                    height: Theme.fs(19px);
                                    clip: true;
                                    HorizontalLayout {
                                        alignment: start;
                                        for seg in line: Text {
                                            text: seg.text;
                                            // Plain-text fallback segments
                                            // carry black; use the default
                                            // code foreground instead.
                                            color: seg.color == #000000
                                                ? Theme.c.code-fg : seg.color;
                                            font-family: "monospace";
                                            font-size: Theme.fs(13px);
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                            if row.kind == 1 && row.md-kind == 7: TableGrid {
                                rows: row.table-rows;
                                default-color: row.tone == 1 ? Theme.c.text-accent-soft
                                    : row.tone == 2 ? Theme.c.text-dim : Theme.c.text;
                                link-clicked(url) => { root.open-link(url); }
                            }
                            if row.kind == 1 && row.md-kind != 5 && row.md-kind != 7: StyledText {
                                text: row.styled;
                                default-color: row.tone == 1 ? Theme.c.text-accent-soft
                                    : row.tone == 2 ? Theme.c.text-dim
                                    : Theme.c.text;
                                link-color: Theme.c.accent;
                                default-font-size: Theme.fs(row.md-kind == 1 ? 22px
                                    : row.md-kind == 2 ? 19px
                                    : row.md-kind == 3 ? 16px
                                    : 14px);
                                link-clicked(url) => { root.open-link(url); }
                            }

                            // Tool card header: click anywhere to toggle
                            // the detail panel (nested controls sit on top
                            // and win).
                            if row.kind == 2: Rectangle {
                                height: tool-hdr.preferred-height;
                                TouchArea {
                                    clicked => { root.tool-toggled(idx); }
                                }
                                tool-hdr := HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: row.expanded ? "▾" : "▸";
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(10px);
                                        vertical-alignment: center;
                                    }
                                    // Running tools show an indeterminate
                                    // spinner; settled ones a status glyph.
                                    // Reduce motion: a static glyph instead.
                                    if row.tool-status == 1 && !Theme.reduce-motion: VerticalLayout {
                                        alignment: center;
                                        Spinner {
                                            width: 12px;
                                            height: 12px;
                                            indeterminate: true;
                                        }
                                    }
                                    if row.tool-status == 1 && Theme.reduce-motion: Text {
                                        text: "◌";
                                        color: Theme.c.text-dim;
                                        font-size: Theme.fs(12px);
                                        vertical-alignment: center;
                                    }
                                    if row.tool-status != 1: Text {
                                        text: row.tool-status == 0 ? "⏸"
                                            : row.tool-status == 2 ? "✓"
                                            : row.tool-status == 4 ? "⊘"
                                            : "✗";
                                        color: row.tool-status == 2 ? Theme.c.ok
                                            : row.tool-status == 0 ? Theme.c.warn
                                            : Theme.c.err;
                                        font-size: Theme.fs(12px);
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: row.tool-name;
                                        color: Theme.c.text;
                                        font-size: Theme.fs(11px);
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                    // Read/edit tools: the filename opens
                                    // the file in the Files tab (reads
                                    // preselect the line range there).
                                    if row.tool-file != "": Text {
                                        text: row.text;
                                        color: Theme.c.accent;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                        TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.chat-file-opened(
                                                    row.tool-file,
                                                    row.tool-line-from,
                                                    row.tool-line-to);
                                            }
                                        }
                                    }
                                    // Read tools: the line range read
                                    // ("L123-456", built in Rust).
                                    if row.meta != "": Text {
                                        text: row.meta;
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    // Edit tools: added/removed line counts.
                                    if row.tool-adds != "": Text {
                                        text: row.tool-adds;
                                        color: Theme.c.ok;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    if row.tool-dels != "": Text {
                                        text: row.tool-dels;
                                        color: Theme.c.err;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    CopyButton {
                                        payload: row.detail;
                                        height: Theme.fs(18px);
                                        tip: "Copy tool call";
                                    }
                                    if row.tool-status == 0: VerticalLayout {
                                        alignment: center;
                                        HorizontalLayout {
                                            spacing: 4px;
                                            PillButton {
                                                label: "Approve";
                                                primary: true;
                                                clicked => { root.approval-resolved(idx, true); }
                                            }
                                            PillButton {
                                                label: "Deny";
                                                clicked => { root.approval-resolved(idx, false); }
                                            }
                                        }
                                    }
                                }
                            }

                            // Tool card detail: edits show their line
                            // diff, everything else the humanized
                            // args/result text.
                            if row.kind == 2 && row.expanded && row.tool-diff.length > 0: VerticalLayout {
                                for dline in row.tool-diff: Rectangle {
                                    height: Theme.fs(18px);
                                    background: dline.kind == 3 ? Theme.c.diff-add-bg
                                        : dline.kind == 4 ? Theme.c.diff-del-bg
                                        : transparent;
                                    HorizontalLayout {
                                        spacing: 0;
                                        // Old/new line-number gutter, when
                                        // the diff resolved file positions.
                                        if row.tool-diff-numbered: Text {
                                            width: 34px;
                                            text: dline.old-no;
                                            color: Theme.c.gutter;
                                            horizontal-alignment: right;
                                            font-family: "monospace";
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                        if row.tool-diff-numbered: Text {
                                            width: 34px;
                                            text: dline.new-no;
                                            color: Theme.c.gutter;
                                            horizontal-alignment: right;
                                            font-family: "monospace";
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                        if row.tool-diff-numbered: Rectangle { width: 6px; }
                                        Text {
                                            width: 16px;
                                            text: dline.kind == 3 ? "+"
                                                : dline.kind == 4 ? "-" : " ";
                                            color: dline.kind == 3 ? Theme.c.ok
                                                : dline.kind == 4 ? Theme.c.err
                                                : Theme.c.gutter;
                                            font-family: "monospace";
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: dline.text;
                                            color: dline.kind == 1 ? Theme.c.accent-tint : Theme.c.text;
                                            font-family: "monospace";
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                            if row.kind == 2 && row.expanded && row.tool-diff.length == 0: TextInput {
                                text: row.detail;
                                read-only: true;
                                single-line: false;
                                color: Theme.c.text-dim;
                                font-size: Theme.fs(12px);
                                font-family: "monospace";
                                wrap: word-wrap;
                                selection-background-color: Theme.c.selection;
                            }

                            // Turn status: failures only (completed turns
                            // summarize in their assistant card header).
                            if row.kind == 3: Text {
                                text: row.text;
                                color: Theme.c.err;
                                font-size: Theme.fs(11px);
                            }

                            // Horizontal rule separating turns.
                            if row.kind == 8: Rectangle {
                                height: 1px;
                                background: Theme.c.rule;
                            }

                            // Grouped tool-run header: "Called n tools",
                            // click to show/hide the individual calls.
                            if row.kind == 9: HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: row.expanded ? "▾" : "▸";
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(10px);
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.text;
                                    color: Theme.c.text-mid;
                                    font-size: Theme.fs(11px);
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }

                            // Raw response text: the turn's markdown source
                            // as one fully selectable block.
                            if row.kind == 6: TextInput {
                                text: row.text;
                                read-only: true;
                                single-line: false;
                                color: Theme.c.text;
                                font-size: Theme.fs(13px);
                                wrap: word-wrap;
                                selection-background-color: Theme.c.selection;
                            }

                            // Model thinking (reasoning stream): a header
                            // pill styled like a tool card; the content
                            // follows as markdown rows (tone 2) that this
                            // toggles.
                            if row.kind == 4: Rectangle {
                                height: think-hdr.preferred-height;
                                TouchArea {
                                    clicked => { root.card-toggled(row.card-key); }
                                }
                                think-hdr := HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: row.expanded ? "▾" : "▸";
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(10px);
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        // "Thinking" while streaming,
                                        // "Thought" once complete.
                                        text: row.text;
                                        color: Theme.c.text;
                                        font-size: Theme.fs(11px);
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                    if !row.expanded: Text {
                                        text: row.meta;
                                        color: Theme.c.text-dim;
                                        font-size: Theme.fs(11px);
                                        font-italic: true;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                    if row.expanded: Rectangle {
                                        horizontal-stretch: 1;
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        CopyButton {
                                            payload: row.detail;
                                            height: Theme.fs(18px);
                                            tip: "Copy thinking";
                                        }
                                    }
                                }
                            }

                            // Activity: pulsing dots + label while the agent
                            // works ("Processing…"/"Thinking…"); nests at the
                            // bottom of the streaming Agent card when open.
                            if row.kind == 5: HorizontalLayout {
                                spacing: 8px;
                                PulseDots {
                                    // Reduce motion: dots rest as static marks.
                                    animate: !Theme.reduce-motion;
                                }
                                Text {
                                    text: row.text;
                                    color: Theme.c.text-dim;
                                    font-size: Theme.fs(13px);
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }

                            // Question wizard: the agent's questions,
                            // answered one page at a time (radio/checkbox
                            // options plus a free-form "Other"), with a
                            // review page before submitting. Once resolved
                            // it settles into a compact answer summary.
                            if row.kind == 10: VerticalLayout {
                                spacing: 8px;
                                padding: 4px;
                                // Title bar: form title, page indicator,
                                // and a skip escape hatch while pending.
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: row.text;
                                        color: row.q-done ? Theme.c.text : Theme.c.warn;
                                        font-size: Theme.fs(11px);
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: row.meta;
                                        color: Theme.c.text-dim;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    if !row.q-done: Text {
                                        text: "Skip";
                                        color: skip-ta.has-hover ? Theme.c.text-mid : Theme.c.text-faint;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                        skip-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.question-skip(idx); }
                                        }
                                    }
                                }
                                // Question page: prompt + options.
                                if !row.q-review: Text {
                                    text: row.q-prompt;
                                    color: Theme.c.text-hi;
                                    font-size: Theme.fs(13px);
                                    font-weight: 600;
                                    wrap: word-wrap;
                                }
                                if !row.q-review: VerticalLayout {
                                    spacing: 4px;
                                    for opt[oi] in row.q-options: Rectangle {
                                        border-radius: 5px;
                                        border-width: 1px;
                                        border-color: opt.selected ? Theme.c.accent : Theme.c.card-border;
                                        background: opt.selected ? Theme.c.accent-dim
                                            : opt-ta.has-hover ? Theme.c.hover-bg : Theme.c.code-bg;
                                        height: opt-line.preferred-height + 10px;
                                        opt-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.question-option-toggled(idx, oi);
                                            }
                                        }
                                        opt-line := HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 10px;
                                            spacing: 8px;
                                            Text {
                                                text: row.q-multi
                                                    ? (opt.selected ? "☑" : "☐")
                                                    : (opt.selected ? "◉" : "○");
                                                color: opt.selected ? Theme.c.accent : Theme.c.text-soft;
                                                font-size: Theme.fs(13px);
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: opt.label;
                                                color: Theme.c.text;
                                                font-size: Theme.fs(13px);
                                                vertical-alignment: center;
                                                wrap: word-wrap;
                                                horizontal-stretch: 1;
                                            }
                                        }
                                    }
                                    // The trailing free-form choice.
                                    Rectangle {
                                        border-radius: 5px;
                                        border-width: 1px;
                                        border-color: row.q-other ? Theme.c.accent : Theme.c.card-border;
                                        background: row.q-other ? Theme.c.accent-dim
                                            : other-ta.has-hover ? Theme.c.hover-bg : Theme.c.code-bg;
                                        height: other-line.preferred-height + 10px;
                                        other-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.question-option-toggled(
                                                    idx, row.q-options.length);
                                            }
                                        }
                                        other-line := HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 10px;
                                            spacing: 8px;
                                            Text {
                                                text: row.q-multi
                                                    ? (row.q-other ? "☑" : "☐")
                                                    : (row.q-other ? "◉" : "○");
                                                color: row.q-other ? Theme.c.accent : Theme.c.text-soft;
                                                font-size: Theme.fs(13px);
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: "Other";
                                                color: Theme.c.text;
                                                font-size: Theme.fs(13px);
                                                font-italic: true;
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                            }
                                        }
                                    }
                                    if row.q-other: Rectangle {
                                        border-radius: 5px;
                                        border-width: 1px;
                                        border-color: Theme.c.card-border;
                                        background: Theme.c.inset-bg;
                                        height: other-input.preferred-height + 12px;
                                        other-input := TextInput {
                                            x: 10px;
                                            y: 6px;
                                            width: parent.width - 20px;
                                            text: row.q-other-text;
                                            single-line: false;
                                            wrap: word-wrap;
                                            color: Theme.c.text;
                                            font-size: Theme.fs(13px);
                                            selection-background-color: Theme.c.selection;
                                            edited => {
                                                root.question-other-edited(idx, self.text);
                                            }
                                        }
                                    }
                                }
                                // Review page (pending) / answered summary.
                                if row.q-review: VerticalLayout {
                                    spacing: 6px;
                                    for pair in row.q-summary: VerticalLayout {
                                        spacing: 1px;
                                        Text {
                                            text: pair.prompt;
                                            color: Theme.c.text-dim;
                                            font-size: Theme.fs(12px);
                                            wrap: word-wrap;
                                        }
                                        Text {
                                            text: pair.answer;
                                            color: Theme.c.text;
                                            font-size: Theme.fs(13px);
                                            wrap: word-wrap;
                                        }
                                    }
                                    if row.q-done && row.q-summary.length == 0: Text {
                                        text: "The questions were skipped.";
                                        color: Theme.c.text-dim;
                                        font-size: Theme.fs(12px);
                                        font-italic: true;
                                    }
                                }
                                // Navigation: Back / Next (last question
                                // page says Review; the review page Submit).
                                if !row.q-done: HorizontalLayout {
                                    alignment: end;
                                    spacing: 6px;
                                    if row.q-can-back: PillButton {
                                        label: "Back";
                                        clicked => { root.question-back(idx); }
                                    }
                                    PillButton {
                                        label: row.q-review ? "Submit"
                                            : row.q-last ? "Review" : "Next";
                                        primary: true;
                                        enabled: row.q-can-next;
                                        clicked => { root.question-next(idx); }
                                    }
                                }
                            }
                            }
                        }
                    }
                }

                // Custom scrollbar: absolute cursor→position mapping (no
                // drift while dragging) and click-to-jump on the track.
                // Solid background hides the built-in bar underneath.
                sb := Rectangle {
                    property <length> total: chat-list.viewport-height;
                    property <length> page: chat-list.visible-height;
                    property <length> margin: 2px;
                    property <length> track: self.height - 2 * self.margin;
                    property <length> thumb-h: max(24px,
                        self.track * (self.page / max(1px, self.total)));
                    property <bool> scrollable: self.total > self.page;

                    visible: self.scrollable && root.center-screen == 0;
                    x: parent.width - self.width;
                    y: 0;
                    width: 14px;
                    height: parent.height;
                    background: Theme.c.win-bg;

                    function frac() -> float {
                        return self.scrollable
                            ? -chat-list.viewport-y / (self.total - self.page)
                            : 0;
                    }
                    function set-from-y(y: length, grab: length) {
                        // An explicit scrollbar move is always a user
                        // scroll: end tail-following outright (the
                        // viewport-y watcher's height heuristic could
                        // mistake a drag for layout noise while rows are
                        // still re-measuring).
                        root.begin-user-chat-scroll();
                        chat-list.viewport-y = -clamp(
                            ((y - self.margin - grab)
                                / max(1px, self.track - self.thumb-h))
                                * (self.total - self.page),
                            0px, self.total - self.page);
                    }

                    sb-thumb := Rectangle {
                        x: 4px;
                        width: parent.width - 7px;
                        y: parent.margin
                            + (parent.track - parent.thumb-h) * parent.frac();
                        height: parent.thumb-h;
                        border-radius: 3px;
                        background: sb-ta.pressed ? Theme.c.scroll-thumb-active
                            : sb-ta.has-hover ? Theme.c.scroll-thumb-hover
                            : Theme.c.scroll-thumb;
                    }
                    sb-ta := TouchArea {
                        property <length> grab;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                if (self.mouse-y >= sb-thumb.y
                                    && self.mouse-y <= sb-thumb.y + sb-thumb.height) {
                                    // Grab the thumb where it was clicked.
                                    self.grab = self.mouse-y - sb-thumb.y;
                                } else {
                                    // Track click: jump, centering the
                                    // thumb on the cursor.
                                    self.grab = parent.thumb-h / 2;
                                    parent.set-from-y(self.mouse-y, self.grab);
                                }
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                parent.set-from-y(self.mouse-y, self.grab);
                            }
                        }
                        scroll-event(ev) => {
                            if (ev.delta-y != 0) {
                                root.begin-user-chat-scroll();
                                chat-list.viewport-y = clamp(
                                    chat-list.viewport-y + ev.delta-y,
                                    -(parent.total - parent.page), 0px);
                                return accept;
                            }
                            reject
                        }
                    }
                }
                }

                // Composer: multiline prompt on top (grows with content),
                // then a controls row — pickers, model knobs, send, dial.
                // Only the chat list above stretches; the composer sticks
                // to its preferred height. Removed (not just hidden) while
                // the new-thread form is up so it doesn't reserve space.
                if root.center-screen == 0: VerticalLayout {
                    spacing: 6px;
                    vertical-stretch: 0;

                    // Connectivity warning / recovery notice for the composer.
                    if root.connectivity-text != "" || root.connectivity-notice != "": ConnectivityBanner {
                        warning: root.connectivity-text;
                        notice: root.connectivity-notice;
                        severe: root.connectivity-severe;
                    }

                    // Queued prompts: waiting their turn behind the running
                    // one. Edit in place, reorder with the arrows, delete,
                    // or — when the thread is idle — kick the queue off.
                    if root.queue-prompts.length > 0: Rectangle {
                        vertical-stretch: 0;
                        background: Theme.c.surface;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.c.border;
                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: root.queue-prompts.length == 1
                                        ? "1 queued prompt"
                                        : root.queue-prompts.length + " queued prompts";
                                    color: Theme.c.text-soft;
                                    font-size: Theme.fs(11px);
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                if root.queue-idle && !root.connectivity-blocked: PillButton {
                                    label: "Send now";
                                    primary: true;
                                    clicked => { root.queue-send-now(); }
                                }
                            }
                            for qtext[qi] in root.queue-prompts: VerticalLayout {
                                spacing: 4px;
                                Rectangle {
                                    height: Theme.fs(24px);
                                    border-radius: 4px;
                                    // Dragged row reads as "lifted"; the slot
                                    // it would land in gets a soft highlight.
                                    background: root.queue-drag-from == qi
                                        ? Theme.c.accent-bg
                                        : root.queue-drag-from != -1
                                            && root.queue-drop-target() == qi
                                        ? Theme.c.hover-strong : transparent;
                                    HorizontalLayout {
                                    spacing: 4px;
                                    padding-left: 2px;
                                    padding-right: 2px;
                                    Rectangle {
                                        width: Theme.fs(14px);
                                        qdrag-ta := TouchArea {
                                            enabled: !root.connectivity-blocked;
                                            mouse-cursor: !root.connectivity-blocked
                                                ? (root.queue-drag-from == qi
                                                    ? MouseCursor.grabbing : MouseCursor.grab)
                                                : MouseCursor.default;
                                            moved => {
                                                root.queue-editing = -1;
                                                root.queue-drag-from = qi;
                                                root.queue-drag-dy =
                                                    self.mouse-y - self.pressed-y;
                                            }
                                            pointer-event(ev) => {
                                                if (ev.kind == PointerEventKind.up
                                                        && root.queue-drag-from == qi) {
                                                    if (root.queue-drop-target() != qi) {
                                                        root.queue-reordered(
                                                            qi, root.queue-drop-target());
                                                    }
                                                    root.queue-drag-from = -1;
                                                    root.queue-drag-dy = 0px;
                                                }
                                            }
                                        }
                                        Text {
                                            width: 100%;
                                            height: 100%;
                                            text: "⠿";
                                            color: qdrag-ta.has-hover
                                                    || root.queue-drag-from == qi
                                                ? Theme.c.text-hi : Theme.c.text-faint;
                                            font-size: Theme.fs(12px);
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: (qi + 1) + ".";
                                        color: Theme.c.text-faint;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: qtext;
                                        color: Theme.c.text-mid;
                                        font-size: Theme.fs(12px);
                                        overflow: elide;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                    if qi < root.queue-badges.length && root.queue-badges[qi] != "": Text {
                                        text: root.queue-badges[qi];
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                    }
                                    IconButton {
                                        icon: "▶";
                                        tip: root.queue-idle ? "Send this prompt now" : "Run this prompt next";
                                        enabled: !root.connectivity-blocked;
                                        clicked => { root.queue-send-now-at(qi); }
                                    }
                                    IconButton {
                                        icon: "↑";
                                        tip: "Run earlier";
                                        enabled: qi > 0 && !root.connectivity-blocked;
                                        clicked => { root.queue-moved(qi, -1); }
                                    }
                                    IconButton {
                                        icon: "↓";
                                        tip: "Run later";
                                        enabled: qi < root.queue-prompts.length - 1
                                            && !root.connectivity-blocked;
                                        clicked => { root.queue-moved(qi, 1); }
                                    }
                                    IconButton {
                                        icon: "✎";
                                        tip: "Edit";
                                        enabled: !root.connectivity-blocked;
                                        clicked => {
                                            root.queue-editing =
                                                root.queue-editing == qi ? -1 : qi;
                                        }
                                    }
                                    IconButton {
                                        icon: "✕";
                                        tip: "Remove from queue";
                                        enabled: !root.connectivity-blocked;
                                        clicked => { root.queue-deleted(qi); }
                                    }
                                    }
                                }
                                if root.queue-editing == qi: VerticalLayout {
                                    spacing: 4px;
                                    qedit := TextEdit {
                                        text: qtext;
                                        height: Theme.fs(80px);
                                        wrap: word-wrap;
                                        font-size: Theme.fs(12px);
                                    }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: end;
                                        PillButton {
                                            label: "Cancel";
                                            clicked => { root.queue-editing = -1; }
                                        }
                                        PillButton {
                                            label: "Save";
                                            primary: true;
                                            enabled: !root.connectivity-blocked;
                                            clicked => {
                                                root.queue-edited(qi, qedit.text);
                                                root.queue-editing = -1;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // "/" completion popup, floated above the composer via a
                    // zero-height anchor (rows can then reach `composer`
                    // directly, which lives in this same conditional scope).
                    Rectangle {
                        height: 0;
                        visible: root.slash-active && !root.slash-suppressed;
                        Rectangle {
                            x: 0;
                            y: -self.height - 6px;
                            width: min(parent.width, 480px);
                            height: slash-list.preferred-height;
                            background: Theme.c.popup-bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.c.border;
                            slash-list := VerticalLayout {
                                padding: 6px;
                                for cmd[rank] in root.slash-matches: Rectangle {
                                    height: Theme.fs(26px);
                                    border-radius: 5px;
                                    background: rank == 0 ? Theme.c.accent-bg
                                        : slash-ta.has-hover ? Theme.c.hover-strong : transparent;
                                    slash-ta := TouchArea {
                                        clicked => {
                                            composer.apply-completion(
                                                "/" + root.slash-commands[cmd]);
                                        }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 10px;
                                        Text {
                                            text: "/" + root.slash-commands[cmd];
                                            color: Theme.c.text-hi;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: root.slash-details[cmd];
                                            color: Theme.c.text-soft;
                                            font-size: Theme.fs(11px);
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // "@" file-mention popup, floated above the composer the
                    // same way as the "/" one. ↑/↓ (handled in the PromptBox)
                    // move the highlight; click or Tab/Enter inserts.
                    Rectangle {
                        height: 0;
                        visible: root.at-active && !root.at-suppressed;
                        Rectangle {
                            x: 0;
                            y: -self.height - 6px;
                            width: min(parent.width, 480px);
                            height: at-list.preferred-height;
                            background: Theme.c.popup-bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.c.border;
                            at-list := VerticalLayout {
                                padding: 6px;
                                for file[rank] in root.at-matches: Rectangle {
                                    height: Theme.fs(26px);
                                    border-radius: 5px;
                                    background: rank == root.at-selected ? Theme.c.accent-bg
                                        : at-ta.has-hover ? Theme.c.hover-strong : transparent;
                                    at-ta := TouchArea {
                                        clicked => { root.at-picked(file); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        Text {
                                            text: root.at-files[file];
                                            color: Theme.c.text-hi;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Files staged for the next prompt: one removable chip
                    // each. Kept above the input so pasting a screenshot has
                    // visible, undoable feedback before sending.
                    if root.composer-attachments.length > 0: Flickable {
                        height: Theme.fs(26px);
                        viewport-height: self.height;
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            for chip[i] in root.composer-attachments: Rectangle {
                                background: Theme.c.accent-bg;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.c.primary-border;
                                height: Theme.fs(24px);
                                HorizontalLayout {
                                    spacing: 6px;
                                    padding-left: 8px;
                                    padding-right: 4px;
                                    Text {
                                        text: chip.name;
                                        color: Theme.c.text-hi;
                                        font-size: Theme.fs(11px);
                                        vertical-alignment: center;
                                        overflow: elide;
                                        max-width: 220px;
                                    }
                                    Text {
                                        text: chip.meta;
                                        color: Theme.c.text-soft;
                                        font-size: Theme.fs(10px);
                                        vertical-alignment: center;
                                    }
                                    IconButton {
                                        icon: "✕";
                                        tip: "Remove attachment";
                                        y: (parent.height - self.height) / 2;
                                        clicked => { root.attachment-removed(i); }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                    spacing: 8px;
                    composer := PromptBox {
                        horizontal-stretch: 1;
                        text <=> root.composer-draft;
                        placeholder: !root.composer-enabled
                            ? "Select or create a thread first"
                            : root.connectivity-blocked && root.connectivity-severe
                            ? "Server unavailable — prompts are disabled"
                            : root.connectivity-blocked
                            ? "Offline — prompts are disabled"
                            : "Message the agent…  (Shift+Enter for a new line)";
                        enabled: root.composer-enabled && !root.connectivity-blocked;
                        completion-active: root.slash-active && !root.slash-suppressed;
                        completion-text: root.slash-completion;
                        completion-dismissed => { root.slash-suppressed = true; }
                        at-active: root.at-active && !root.at-suppressed;
                        at-count: root.at-matches.length;
                        at-selected <=> root.at-selected;
                        cursor-seq: root.composer-cursor-seq;
                        cursor-target: root.composer-cursor-target;
                        at-accepted => {
                            if (root.at-selected >= 0
                                && root.at-selected < root.at-matches.length) {
                                root.at-picked(root.at-matches[root.at-selected]);
                            }
                        }
                        at-dismissed => { root.at-suppressed = true; }
                        cursor-moved(offset) => {
                            root.composer-cursor = offset;
                            root.at-filter-changed(self.text, offset);
                        }
                        paste-image-attempted => { root.paste-image-attempted() }
                        submitted(text) => {
                            root.send-message(text);
                            self.text = "";
                        }
                    }
                    Button {
                        width: Theme.fs(76px);
                        text: root.composer-turn-running
                            ? (composer.text != "" || root.composer-attachments.length > 0 ? "Queue" : "Cancel")
                            : "Send";
                        primary: !root.composer-turn-running || composer.text != "" || root.composer-attachments.length > 0;
                        enabled: root.composer-enabled && !root.connectivity-blocked
                            && (root.composer-turn-running || composer.text != "" || root.composer-attachments.length > 0);
                        clicked => {
                            if (root.composer-turn-running && composer.text == ""
                                && root.composer-attachments.length == 0) {
                                root.cancel-turn();
                            } else {
                                root.send-message(composer.text);
                                composer.text = "";
                            }
                        }
                    }
                    }

                    HorizontalLayout {
                    spacing: 8px;
                    vertical-stretch: 0;
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "Mode"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        DropUpPicker {
                            width: 130px;
                            options: root.modes;
                            current-index <=> root.mode-index;
                            enabled: root.composer-enabled && !root.connectivity-blocked;
                            placeholder: "mode";
                            changed(i) => { root.composer-mode-changed(i); }
                        }
                    }
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "Model"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        SearchPicker {
                            width: 210px;
                            options: root.models;
                            matches: root.model-filter-matches;
                            current-index <=> root.model-index;
                            enabled: root.composer-enabled && !root.connectivity-blocked;
                            placeholder: "model";
                            changed(i) => { root.composer-model-changed(i); }
                            filter-edited(q) => { root.model-filter-changed(q); }
                        }
                    }
                    if root.thinking-options.length > 0: VerticalLayout {
                        spacing: 2px;
                        Text { text: "Thinking"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        DropUpPicker {
                            width: 110px;
                            options: root.thinking-options;
                            current-index <=> root.thinking-index;
                            enabled: root.composer-enabled && !root.connectivity-blocked;
                            placeholder: "thinking";
                            changed(i) => { root.composer-thinking-changed(i); }
                        }
                    }
                    VerticalLayout {
                        spacing: 2px;
                        Text {
                            text: root.composer-yolo-selected ? "⚠ Permissions" : "Permissions";
                            color: root.composer-yolo-selected ? Theme.c.err : Theme.c.text-faint;
                            font-size: Theme.fs(10px);
                            font-weight: root.composer-yolo-selected ? 700 : 400;
                        }
                        DropUpPicker {
                            width: 105px;
                            options: root.permission-options;
                            current-index <=> root.permission-index;
                            enabled: root.composer-enabled && !root.composer-turn-running && !root.connectivity-blocked;
                            placeholder: "permissions";
                            changed(i) => { root.composer-permission-changed(i); }
                        }
                    }
                    if root.composer-yolo-selected: Rectangle {
                        width: 250px;
                        height: Theme.fs(30px);
                        background: Theme.c.err-bg;
                        border-width: 1px;
                        border-color: Theme.c.err;
                        border-radius: 6px;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 6px;
                            Text { text: "⚠"; color: Theme.c.err; font-size: Theme.fs(13px); vertical-alignment: center; }
                            Text {
                                text: "YOLO: changes run without approval";
                                color: Theme.c.err-soft;
                                font-size: Theme.fs(10px);
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                        }
                    }
                    if root.context-options.length > 0: VerticalLayout {
                        spacing: 2px;
                        Text { text: "Context"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        DropUpPicker {
                            width: 90px;
                            options: root.context-options;
                            current-index <=> root.context-index;
                            enabled: root.composer-enabled && !root.connectivity-blocked;
                            placeholder: "context";
                            changed(i) => { root.composer-context-changed(i); }
                        }
                    }
                    if root.fast-visible: VerticalLayout {
                        spacing: 2px;
                        Text { text: "Fast"; color: Theme.c.text-faint; font-size: Theme.fs(10px); }
                        Rectangle {
                            width: 44px;
                            height: Theme.fs(30px);
                            background: root.fast-checked ? Theme.c.accent-bg : Theme.c.control-bg;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: root.fast-checked ? Theme.c.primary-border : Theme.c.border;
                            TouchArea {
                                enabled: root.composer-enabled && !root.connectivity-blocked;
                                clicked => {
                                    root.fast-checked = !root.fast-checked;
                                    root.composer-fast-toggled(root.fast-checked);
                                }
                            }
                            Text {
                                text: root.fast-checked ? "On" : "Off";
                                color: root.fast-checked ? Theme.c.text-accent-soft : Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: " "; font-size: Theme.fs(10px); }
                        IconButton {
                            icon: "📎";
                            tip: "Attach files (or paste an image with Ctrl+V)";
                            icon-size: Theme.fs(14px);
                            width: Theme.fs(30px);
                            height: Theme.fs(30px);
                            enabled: root.composer-enabled && !root.connectivity-blocked;
                            clicked => { root.attach-file(); }
                        }
                    }
                    // Context usage dial; indeterminate while compacting.
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: " "; font-size: Theme.fs(10px); }
                    dial := Rectangle {
                        width: 30px;
                        height: 30px;
                        // Reduce motion: freeze the compacting animation at a
                        // full ring (the tooltip still says "compacting…").
                        Spinner {
                            width: 26px;
                            height: 26px;
                            x: 2px;
                            y: 2px;
                            progress: root.context-compacting && Theme.reduce-motion
                                ? 1.0 : root.context-fill;
                            indeterminate: root.context-compacting && !Theme.reduce-motion;
                        }
                        dial-ta := TouchArea { }
                        if dial-ta.has-hover: Rectangle {
                            x: dial.width - self.width;
                            y: -self.height - 6px;
                            width: min(tooltip-text.preferred-width + 16px, 340px);
                            height: tooltip-text.preferred-height + 12px;
                            background: Theme.c.popup-bg;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.c.border;
                            tooltip-text := Text {
                                x: 8px;
                                y: 6px;
                                width: parent.width - 16px;
                                text: root.context-compacting
                                    ? "compacting context…\n" + root.context-tooltip
                                    : root.context-tooltip;
                                color: Theme.c.text;
                                font-size: Theme.fs(11px);
                                wrap: word-wrap;
                            }
                        }
                    }
                    }
                    Text {
                        text: root.usage-text;
                        color: Theme.c.text-soft;
                        font-size: Theme.fs(11px);
                        vertical-alignment: center;
                        max-width: 190px;
                        overflow: elide;
                    }
                    }
                }
                }
            }
            }

            // ----- new-session screen (no session context to keep) -----
            if root.center-screen == 1: NewChatForm {
                session-form: true;
                workspaces: root.nc-workspaces;
                workspace-index <=> root.nc-workspace-index;
                branches: root.nc-branches;
                branch-index <=> root.nc-branch-index;
                use-latest-remote <=> root.nc-fetch-latest;
                modes: root.modes;
                mode-model-indices: root.mode-model-indices;
                mode-index <=> root.nc-mode-index;
                models: root.models;
                model-matches: root.model-filter-matches;
                model-index <=> root.nc-model-index;
                thinking-options: root.nc-thinking-options;
                thinking-index <=> root.nc-thinking-index;
                permission-options: root.nc-permission-options;
                permission-index <=> root.nc-permission-index;
                error-text: root.error-text;
                blocked: root.connectivity-blocked;
                blocked-severe: root.connectivity-severe;
                offline-warning: root.connectivity-text;
                online-notice: root.connectivity-notice;
                attachments: root.composer-attachments;
                attach-file => { root.attach-file(); }
                attachment-removed(i) => { root.attachment-removed(i); }
                paste-image-attempted => { root.paste-image-attempted() }
                start(ws, br, fetch, mode, model, thinking, permission, prompt) => {
                    root.start-new-chat(ws, br, fetch, mode, model, thinking, permission, prompt);
                }
                cancel => { root.cancel-new-chat(); }
                workspace-changed(i) => { root.nc-workspace-changed(i); }
                register-workspace(path) => { root.register-workspace-path(path); }
                model-filter(q) => { root.model-filter-changed(q); }
            }

        }

        SplitterHandle {
            value <=> root.right-width;
            direction: -1;
            min-value: 280px;
            // The panel may take everything but a readable chat column.
            max-value: max(280px, root.width - root.left-width - 340px);
        }

        // ---------------- right: inspection ----------------
        Rectangle {
            width: root.right-width;
            background: Theme.c.panel-bg;

            TabWidget {
                current-index <=> root.right-tab;
                Tab {
                    title: "Diff";
                    VerticalLayout {
                        padding: 6px;
                        spacing: 6px;
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: "↶ Undo turn";
                                clicked => { root.undo-turn(); }
                            }
                            Button {
                                text: "↷ Redo";
                                clicked => { root.redo-turn(); }
                            }
                            if root.diff-text != "": VerticalLayout {
                                alignment: center;
                                CopyButton {
                                    payload: root.diff-text;
                                    label: "copy diff";
                                    tip: "Copy diff";
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                        DiffView {
                            vertical-stretch: 1;
                            rows: root.diff-rows;
                            file-diffs: root.diff-file-texts;
                            background: Theme.c.surface;
                            code-font-size: Theme.fs(13px);
                            file-header-bg: Theme.c.hover-bg;
                            file-header-fg: Theme.c.text-hi;
                            hunk-bg: Theme.c.accent-dim;
                            hunk-fg: Theme.c.accent-tint;
                            add-bg: Theme.c.diff-add-bg;
                            add-fg: Theme.c.ok;
                            del-bg: Theme.c.diff-del-bg;
                            del-fg: Theme.c.err;
                            gutter-fg: Theme.c.gutter;
                            text-fg: Theme.c.text;
                            file-toggled(i) => { root.diff-file-toggled(i); }
                        }
                    }
                }
                Tab {
                    title: "Files";
                    HorizontalLayout {
                        padding: 6px;
                        spacing: 6px;

                        // Collapsible drawer: the worktree tree sits beside
                        // the viewer; folders expand in place, children
                        // indented underneath (IDE-style explorer).
                        if root.files-drawer-open: Rectangle {
                            width: 210px;
                            background: Theme.c.sidebar-bg;
                            border-radius: 6px;
                            ScrollKeys {
                                target-y <=> file-tree.viewport-y;
                                page: file-tree.visible-height;
                                total: file-tree.viewport-height;
                            file-tree := ListView {
                                for entry[idx] in root.file-entries: Rectangle {
                                    height: Theme.fs(22px);
                                    background: entry-ta.has-hover ? Theme.c.popup-bg : transparent;
                                    border-radius: 4px;
                                    entry-ta := TouchArea {
                                        clicked => { root.file-activated(idx); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 4px + entry.depth * 16px;
                                        spacing: 4px;
                                        // Chevron gutter: twists open for
                                        // expanded folders, blank for files so
                                        // names in one folder line up.
                                        Text {
                                            width: 12px;
                                            text: !entry.is-dir ? ""
                                                : entry.expanded ? "▾" : "▸";
                                            color: Theme.c.text-soft;
                                            font-size: Theme.fs(11px);
                                            vertical-alignment: center;
                                            horizontal-alignment: center;
                                        }
                                        Text {
                                            text: (entry.is-dir
                                                ? (entry.expanded ? "📂 " : "📁 ")
                                                : "📄 ") + entry.name;
                                            color: Theme.c.text;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                            }
                        }

                        // Viewer column: header (drawer toggle, open file
                        // name, actions) above the file contents.
                        VerticalLayout {
                        spacing: 6px;
                        horizontal-stretch: 1;
                        HorizontalLayout {
                            spacing: 6px;
                            VerticalLayout {
                                alignment: center;
                                IconButton {
                                    icon: "▤";
                                    icon-size: Theme.fs(13px);
                                    icon-color: root.files-drawer-open ? Theme.c.accent : Theme.c.text-soft;
                                    tip: root.files-drawer-open
                                        ? "Hide file list" : "Show file list";
                                    clicked => {
                                        root.files-drawer-open = !root.files-drawer-open;
                                    }
                                }
                            }
                            Text {
                                text: root.open-file-name;
                                color: Theme.c.text-dim;
                                font-size: Theme.fs(12px);
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                            if root.open-file-name != "": VerticalLayout {
                                alignment: center;
                                IconButton {
                                    icon: "↗";
                                    icon-size: Theme.fs(13px);
                                    tip: "Open in editor";
                                    clicked => {
                                        root.file-opened-externally(root.open-file-name);
                                    }
                                }
                            }
                            if root.file-is-markdown: VerticalLayout {
                                alignment: center;
                                IconButton {
                                    icon: "👁";
                                    icon-size: Theme.fs(13px);
                                    icon-color: root.file-preview ? Theme.c.accent : Theme.c.text-soft;
                                    tip: root.file-preview
                                        ? "Show source" : "Preview markdown";
                                    clicked => {
                                        root.file-preview = !root.file-preview;
                                    }
                                }
                            }
                            if root.open-file-text != "": CopyButton {
                                payload: root.open-file-text;
                                label: "copy file";
                                tip: "Copy file contents";
                            }
                        }
                        if !root.file-preview: CodeView {
                            vertical-stretch: 1;
                            lines: root.file-lines;
                            line-numbers: root.file-numbers;
                            background: Theme.c.surface;
                            code-font-size: Theme.fs(13px);
                            foreground: Theme.c.code-fg;
                            gutter-color: Theme.c.gutter;
                            selection-color: Theme.c.selection.with-alpha(0.35);
                            select-from: root.file-sel-from;
                            select-to: root.file-sel-to;
                            select-seq: root.file-sel-seq;
                        }
                        // Rendered markdown preview: the chat's block rows
                        // (headings, lists, fenced code with highlighting).
                        if root.file-preview: ScrollKeys {
                            vertical-stretch: 1;
                            target-y <=> md-preview.viewport-y;
                            page: md-preview.visible-height;
                            total: md-preview.viewport-height;
                        md-preview := ListView {
                            changed viewport-y => { Tip.hide-all(); }
                            for row in root.file-preview-rows: VerticalLayout {
                                padding-top: 3px;
                                padding-bottom: 3px;
                                padding-left: (row.md-kind == 4 || row.md-kind == 6)
                                    ? 10px + row.md-indent * 18px : 0px;
                                padding-right: 6px;
                                if row.md-kind == 5: Rectangle {
                                    background: Theme.c.code-bg;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: Theme.c.card-border;
                                    VerticalLayout {
                                        padding: 8px;
                                        spacing: 4px;
                                        HorizontalLayout {
                                            spacing: 6px;
                                            Text {
                                                text: row.md-lang == ""
                                                    ? "code" : row.md-lang;
                                                color: Theme.c.text-disabled;
                                                font-size: Theme.fs(11px);
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                            }
                                            CopyButton {
                                                payload: row.text;
                                                tip: "Copy code";
                                            }
                                        }
                                        VerticalLayout {
                                            for line in row.code-lines: Rectangle {
                                                height: Theme.fs(19px);
                                                clip: true;
                                                HorizontalLayout {
                                                    alignment: start;
                                                    for seg in line: Text {
                                                        text: seg.text;
                                                        color: seg.color == #000000
                                                            ? Theme.c.code-fg : seg.color;
                                                        font-family: "monospace";
                                                        font-size: Theme.fs(13px);
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                                if row.md-kind == 7: TableGrid {
                                    rows: row.table-rows;
                                    default-color: Theme.c.text;
                                    link-clicked(url) => { root.open-link(url); }
                                }
                                if row.md-kind != 5 && row.md-kind != 7: StyledText {
                                    text: row.styled;
                                    default-color: Theme.c.text;
                                    link-color: Theme.c.accent;
                                    default-font-size: Theme.fs(row.md-kind == 1 ? 22px
                                        : row.md-kind == 2 ? 19px
                                        : row.md-kind == 3 ? 16px
                                        : 14px);
                                    link-clicked(url) => { root.open-link(url); }
                                }
                            }
                        }
                        }
                        }
                    }
                }
                Tab {
                    title: "Pull Requests";

                    // Setup prompt: the GitHub integration is unconfigured.
                    if !root.pr-configured: VerticalLayout {
                        alignment: center;
                        padding: 24px;
                        spacing: 12px;
                        Text {
                            text: "Connect GitHub to see this session's pull requests";
                            color: Theme.c.text-hi;
                            font-size: Theme.fs(14px);
                            font-weight: 700;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                        Text {
                            text: "trouve looks up the pull requests opened from each session's branch and shows their checks and reviews here. It needs a GitHub personal access token to do that.";
                            color: Theme.c.text-mid;
                            font-size: Theme.fs(12px);
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            alignment: center;
                            Button {
                                text: "Set up GitHub integration";
                                primary: true;
                                clicked => { root.open-integrations-settings(); }
                            }
                        }
                    }

                    if root.pr-configured: VerticalLayout {
                        padding: 6px;
                        spacing: 6px;

                        HorizontalLayout {
                            spacing: 6px;
                            // Switcher between the session's PRs (hidden
                            // for the common single-PR case).
                            if root.pr-labels.length > 1: ComboBox {
                                model: root.pr-labels;
                                current-index <=> root.pr-selected;
                                selected => { root.pr-picked(self.current-index); }
                                horizontal-stretch: 1;
                            }
                            if root.pr-labels.length <= 1: Rectangle {
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: "⟳ Refresh";
                                clicked => { root.refresh-prs(); }
                            }
                            Button {
                                text: "Create PR";
                                clicked => { root.create-pr(); }
                            }
                        }

                        if root.pr-error != "": Text {
                            text: root.pr-error;
                            color: Theme.c.text-soft;
                            font-size: Theme.fs(12px);
                            wrap: word-wrap;
                        }

                        if root.pr-items.length == 0 && root.pr-error == "": VerticalLayout {
                            alignment: center;
                            vertical-stretch: 1;
                            Text {
                                text: "No pull requests for this session's branch yet.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }

                        // Detail card for the selected PR.
                        if root.pr-items.length > 0
                            && root.pr-selected >= 0
                            && root.pr-selected < root.pr-items.length: Rectangle {
                            vertical-stretch: 1;
                            background: Theme.c.surface;
                            border-radius: 6px;
                            ScrollKeys {
                                target-y <=> pr-scroll.viewport-y;
                                page: pr-scroll.visible-height;
                                total: pr-scroll.viewport-height;
                            pr-scroll := ScrollView {
                                width: 100%;
                                height: 100%;
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;
                                    alignment: start;

                                    Text {
                                        text: root.pr-items[root.pr-selected].title;
                                        color: Theme.c.text-hi;
                                        font-size: Theme.fs(15px);
                                        font-weight: 700;
                                        wrap: word-wrap;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Rectangle {
                                            width: pr-state.preferred-width + 16px;
                                            height: Theme.fs(22px);
                                            border-radius: 11px;
                                            background: root.pr-items[root.pr-selected].state == "open"
                                                ? Theme.c.diff-add-bg
                                                : root.pr-items[root.pr-selected].state == "merged"
                                                    ? Theme.c.accent-bg
                                                    : Theme.c.err-bg;
                                            pr-state := Text {
                                                width: 100%;
                                                height: 100%;
                                                text: root.pr-items[root.pr-selected].state;
                                                color: root.pr-items[root.pr-selected].state == "open"
                                                    ? Theme.c.ok
                                                    : root.pr-items[root.pr-selected].state == "merged"
                                                        ? Theme.c.accent-tint
                                                        : Theme.c.err-soft;
                                                font-size: Theme.fs(11px);
                                                font-weight: 700;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                        Text {
                                            text: root.pr-items[root.pr-selected].meta;
                                            color: Theme.c.text-mid;
                                            font-size: Theme.fs(12px);
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                            overflow: elide;
                                        }
                                    }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Button {
                                            text: "Open on GitHub ↗";
                                            clicked => {
                                                root.open-pr-url(root.pr-items[root.pr-selected].url);
                                            }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                    }

                                    if root.pr-items[root.pr-selected].checks != "": VerticalLayout {
                                        spacing: 4px;
                                        Text {
                                            text: "Checks";
                                            color: Theme.c.text-mid;
                                            font-size: Theme.fs(12px);
                                            font-weight: 700;
                                        }
                                        Text {
                                            text: root.pr-items[root.pr-selected].checks;
                                            color: Theme.c.text;
                                            font-size: Theme.fs(12px);
                                            wrap: word-wrap;
                                        }
                                    }
                                    if root.pr-items[root.pr-selected].reviews != "": VerticalLayout {
                                        spacing: 4px;
                                        Text {
                                            text: "Reviews";
                                            color: Theme.c.text-mid;
                                            font-size: Theme.fs(12px);
                                            font-weight: 700;
                                        }
                                        Text {
                                            text: root.pr-items[root.pr-selected].reviews;
                                            color: Theme.c.text;
                                            font-size: Theme.fs(12px);
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                            }
                        }
                    }
                }
                Tab {
                    title: "MCP";
                    VerticalLayout {
                        padding: 6px;
                        spacing: 6px;

                        HorizontalLayout {
                            spacing: 6px;
                            Text {
                                text: "Effective MCP servers for this session";
                                color: Theme.c.text-mid;
                                font-size: Theme.fs(12px);
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                            Button {
                                text: "⟳ Refresh";
                                clicked => { root.refresh-session-mcp(); }
                            }
                        }
                        Text {
                            text: "App-wide, workspace, and branch configs merged the way a turn in this session sees them. Each entry shows the layer whose definition won.";
                            color: Theme.c.text-soft;
                            font-size: Theme.fs(11px);
                            wrap: word-wrap;
                        }

                        if root.session-mcp-status != "": Text {
                            text: root.session-mcp-status;
                            color: Theme.c.err;
                            font-size: Theme.fs(12px);
                            wrap: word-wrap;
                        }

                        if root.session-mcp-servers.length == 0
                            && root.session-mcp-status == "": VerticalLayout {
                            alignment: center;
                            vertical-stretch: 1;
                            Text {
                                text: "No MCP servers apply to this session.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }

                        if root.session-mcp-servers.length > 0: Rectangle {
                            vertical-stretch: 1;
                            background: Theme.c.surface;
                            border-radius: 6px;
                            ScrollKeys {
                                target-y <=> session-mcp-scroll.viewport-y;
                                page: session-mcp-scroll.visible-height;
                                total: session-mcp-scroll.viewport-height;
                            session-mcp-scroll := ScrollView {
                                width: 100%;
                                height: 100%;
                                VerticalLayout {
                                    padding: 8px;
                                    spacing: 6px;
                                    alignment: start;

                                    for server in root.session-mcp-servers: Rectangle {
                                        background: Theme.c.raised-bg;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: Theme.c.border;
                                        height: session-mcp-row.preferred-height + 16px;
                                        // Tombstoned entries stay listed but dimmed
                                        // so it's clear which layer removed them.
                                        opacity: server.health == "disabled" ? 0.55 : 1;

                                        session-mcp-row := VerticalLayout {
                                            padding: 8px;
                                            spacing: 4px;

                                            HorizontalLayout {
                                                spacing: 6px;
                                                Text {
                                                    text: server.name;
                                                    color: Theme.c.text-hi;
                                                    font-size: Theme.fs(13px);
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                }
                                                // Winning layer badge.
                                                Rectangle {
                                                    width: session-mcp-scope.preferred-width + 12px;
                                                    height: Theme.fs(18px);
                                                    border-radius: 9px;
                                                    background: server.scope == "app-wide"
                                                        ? Theme.c.accent-bg
                                                        : Theme.c.hover-bg;
                                                    session-mcp-scope := Text {
                                                        width: 100%;
                                                        height: 100%;
                                                        text: server.scope;
                                                        color: server.scope == "app-wide"
                                                            ? Theme.c.accent-tint
                                                            : Theme.c.text-mid;
                                                        font-size: Theme.fs(10px);
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                                Rectangle { horizontal-stretch: 1; }
                                            }
                                            if server.command-line != "": Text {
                                                text: server.command-line;
                                                color: Theme.c.text;
                                                font-family: "monospace";
                                                font-size: Theme.fs(11px);
                                                wrap: word-wrap;
                                            }
                                            if server.env-lines != "": Text {
                                                text: "env: " + server.env-lines;
                                                color: Theme.c.text-soft;
                                                font-family: "monospace";
                                                font-size: Theme.fs(11px);
                                                wrap: word-wrap;
                                            }
                                            if server.detail != "": Text {
                                                text: server.detail;
                                                color: Theme.c.text-soft;
                                                font-size: Theme.fs(11px);
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                            }
                            }
                        }
                    }
                }
                Tab {
                    title: "Terminal";
                    VerticalLayout {
                        padding: 6px;
                        spacing: 6px;

                        HorizontalLayout {
                            spacing: 6px;
                            Text {
                                text: "Shell in the session worktree";
                                color: Theme.c.text-mid;
                                font-size: Theme.fs(12px);
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                            if root.term-status != "": Text {
                                text: root.term-status;
                                color: Theme.c.warn;
                                font-size: Theme.fs(12px);
                                vertical-alignment: center;
                            }
                            Button {
                                text: "⟳ Restart";
                                enabled: root.term-attached;
                                clicked => { root.term-restart(); }
                            }
                        }

                        if !root.term-attached: VerticalLayout {
                            alignment: center;
                            vertical-stretch: 1;
                            Text {
                                text: "Open a session to get a shell in its worktree.";
                                color: Theme.c.text-soft;
                                font-size: Theme.fs(12px);
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }

                        if root.term-attached: TerminalGrid {
                            vertical-stretch: 1;
                            border-radius: 6px;
                            clip: true;
                            grid-lines: root.term-lines;
                            cursor-row: root.term-cursor-row;
                            cursor-col: root.term-cursor-col;
                            scrollback-lines: root.term-scrollback;
                            grid-font-size: Theme.fs(13px);
                            background: Theme.c.code-bg;
                            grid-foreground: Theme.c.code-fg;
                            key-pressed(text, ctrl, alt, shift) => {
                                root.term-key(text, ctrl, alt, shift);
                            }
                            paste-text(text) => { root.term-paste(text); }
                            wheel(lines) => { root.term-wheel(lines); }
                            grid-resized(cols, rows) => { root.term-resized(cols, rows); }
                        }
                    }
                }
            }
        }
    }

    // ---------------- pull requests screen (full-window) ----------------
    if root.center-screen == 5: PullRequestsScreen {
        width: 100%;
        height: 100%;
        groups: root.pr-dash-groups;
        project-names: root.pr-dash-projects;
        project-index <=> root.pr-dash-project-index;
        status: root.pr-dash-status;
        configured: root.pr-configured;
        has-workspaces: root.pr-dash-has-workspaces;
        blocked-severe: root.connectivity-severe;
        offline-warning: root.connectivity-text;
        online-notice: root.connectivity-notice;
        reorder-focus-key <=> root.pr-group-reorder-focus-key;
        close => { root.close-pull-requests(); }
        refresh => { root.pull-requests-refresh(); }
        filter-picked(index) => { root.pr-dash-filter-picked(index); }
        group-toggled(key) => { root.pr-group-toggled(key); }
        group-drag-data(key) => { root.pr-group-drag-data(key) }
        group-drag-acceptable(data) => { root.pr-group-drag-acceptable(data) }
        group-dropped(data, target, after) => { root.pr-group-dropped(data, target, after) }
        group-moved(key, offset) => { root.pr-group-moved(key, offset); }
        chat-clicked(workspace-id, branch) => { root.pr-chat-clicked(workspace-id, branch); }
        open-url(url) => { root.open-link(url); }
        open-integrations => { root.open-integrations-settings(); }
    }

    // ---------------- automations screen (full-window) ----------------
    if root.center-screen == 4: AutomationsScreen {
        width: 100%;
        height: 100%;
        automations: root.automations;
        templates: root.automation-templates;
        status: root.automations-status;
        workspace-names: root.automation-workspace-names;
        workspace-ids: root.automation-workspace-ids;
        blocked: root.connectivity-blocked;
        blocked-severe: root.connectivity-severe;
        offline-warning: root.connectivity-text;
        online-notice: root.connectivity-notice;
        form-open <=> root.automations-screen-form-open;
        close => { root.close-automations(); }
        refresh => { root.automations-refresh(); }
        saved(id, name, prompt, ws, kind, minute, time, days, permission, enabled) => {
            root.automation-saved(
                id, name, prompt, ws, kind, minute, time, days, permission, enabled
            );
        }
        toggled(id, on) => { root.automation-toggled(id, on); }
        run-now(id) => { root.automation-run(id); }
        deleted(id) => { root.automation-deleted(id); }
    }

    // ---------------- settings screen (full-window) ----------------
    if root.center-screen == 3: SettingsScreen {
        width: 100%;
        height: 100%;
        providers: root.settings-providers;
        subscription-providers: root.settings-subscription-providers;
        api-providers: root.settings-api-providers;
        local-providers: root.settings-local-providers;
        clis: root.settings-clis;
        known-providers: root.settings-known-providers;
        known-provider-names: root.settings-known-provider-names;
        subscription-known-providers: root.settings-subscription-known-providers;
        subscription-known-provider-names: root.settings-subscription-known-provider-names;
        api-known-providers: root.settings-api-known-providers;
        api-known-provider-names: root.settings-api-known-provider-names;
        local-known-providers: root.settings-local-known-providers;
        local-known-provider-names: root.settings-local-known-provider-names;
        models: root.settings-models;
        default-model-index: root.settings-default-model-index;
        model-thinking-items: root.settings-model-thinking-items;
        default-thinking-index <=> root.settings-default-thinking-index;
        default-permission-index: root.settings-default-permission-index;
        mode-items: root.settings-mode-items;
        mode-model-names: root.settings-mode-model-names;
        settings-status: root.settings-status;
        preset-index <=> root.settings-preset-index;
        section <=> root.settings-section;
        github-hosts: root.settings-github-hosts;
        github-token-saved(host, token) => { root.github-token-saved(host, token); }
        github-host-added(host, client-id) => { root.github-host-added(host, client-id); }
        github-host-removed(host) => { root.github-host-removed(host); }
        subscriptions: root.settings-subscriptions;
        subscriptions-status: root.settings-subscriptions-status;
        mcp-servers: root.settings-mcp-servers;
        mcp-status: root.settings-mcp-status;
        mcp-logs-name: root.settings-mcp-logs-name;
        mcp-logs-text: root.settings-mcp-logs-text;
        mcp-workspace-names: root.settings-mcp-workspace-names;
        mcp-workspace-ids: root.settings-mcp-workspace-ids;
        mcp-refresh => { root.mcp-refresh(); }
        mcp-saved(name, scope, command, env, ws) => {
            root.mcp-saved(name, scope, command, env, ws);
        }
        mcp-deleted(name, scope, ws) => { root.mcp-deleted(name, scope, ws); }
        mcp-logs-requested(name) => { root.mcp-logs-requested(name); }
        mcp-logs-closed => { root.mcp-logs-closed(); }
        theme-names: root.appearance-theme-names;
        theme-index <=> root.appearance-theme-index;
        font-size-names: root.appearance-font-size-names;
        font-size-index <=> root.appearance-font-size-index;
        font-names: root.appearance-font-names;
        font-index <=> root.appearance-font-index;
        reduce-motion <=> root.appearance-reduce-motion;
        notify-enabled <=> root.notify-enabled;
        notify-finish <=> root.notify-finish;
        notify-fail <=> root.notify-fail;
        notify-attention <=> root.notify-attention;
        notify-sound <=> root.notify-sound;
        notify-pref-toggled(which, on) => { root.notify-pref-toggled(which, on); }
        notify-test => { root.notify-test(); }
        provider-saved(id, kind, url, key) => {
            root.provider-saved(id, kind, url, key);
        }
        provider-deleted(id) => { root.provider-deleted(id); }
        provider-login(id) => { root.provider-login(id); }
        default-model-picked(i, thinking) => { root.default-model-picked(i, thinking); }
        default-permission-picked(i) => { root.default-permission-picked(i); }
        mode-saved(id, name, prompt, tools, ro, perm, model, thinking) => {
            root.mode-saved(id, name, prompt, tools, ro, perm, model, thinking);
        }
        mode-deleted(id) => { root.mode-deleted(id); }
        mode-model-picked(id, model) => { root.mode-model-picked(id, model); }
        mode-thinking-picked(id, thinking) => { root.mode-thinking-picked(id, thinking); }
        refresh-settings => { root.refresh-settings(); }
        cli-install(id) => { root.cli-install(id); }
        cli-cancel(id) => { root.cli-cancel(id); }
        cli-uninstall(id) => { root.cli-uninstall(id); }
        local-models: root.local-models;
        local-enabled: root.local-enabled;
        local-hw-line: root.local-hw-line;
        local-runtime-label: root.local-runtime-label;
        local-runtime-action: root.local-runtime-action;
        local-runtime-busy: root.local-runtime-busy;
        local-runtime-progress: root.local-runtime-progress;
        local-runtime-managed: root.local-runtime-managed;
        local-runtime-update: root.local-runtime-update;
        local-runtime-status: root.local-runtime-status;
        local-server-line: root.local-server-line;
        local-server-busy: root.local-server-busy;
        local-status: root.local-status;
        local-search-query <=> root.local-search-query;
        local-search-results: root.local-search-results;
        local-search-status: root.local-search-status;
        local-search(q) => { root.local-search(q); }
        local-search-filters-changed(gpu, cpu, large) => {
            root.local-search-filters-changed(gpu, cpu, large);
        }
        local-refresh => { root.local-refresh(); }
        local-enabled-toggled(on) => { root.local-enabled-toggled(on); }
        local-runtime-install => { root.local-runtime-install(); }
        local-runtime-cancel => { root.local-runtime-cancel(); }
        local-runtime-uninstall => { root.local-runtime-uninstall(); }
        local-download(id) => { root.local-download(id); }
        local-cancel(id) => { root.local-cancel(id); }
        local-delete(id) => { root.local-delete(id); }
        local-stop-server => { root.local-stop-server(); }
        local-restart-server => { root.local-restart-server(); }
        local-added(repo, file) => { root.local-added(repo, file); }
        theme-picked(i) => { root.appearance-theme-picked(i); }
        font-size-picked(i) => { root.appearance-font-size-picked(i); }
        font-picked(i) => { root.appearance-font-picked(i); }
        reduce-motion-toggled(on) => { root.appearance-reduce-motion-toggled(on); }
        close => { root.close-settings(); }
    }

    // ---------------- modal overlays (rename / delete) ----------------
    if root.rename-row >= 0 || root.delete-row >= 0: Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.c.scrim;
        TouchArea { } // swallow clicks behind the modal

        Rectangle {
            width: 380px;
            height: modal-layout.preferred-height + 32px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.c.raised-bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.c.border;

            modal-layout := VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: root.rename-row >= 0
                        ? "Rename session"
                        : "Delete session \"" + root.modal-title + "\"?";
                    color: Theme.c.text-hi;
                    font-size: Theme.fs(15px);
                    font-weight: 700;
                    wrap: word-wrap;
                }

                if root.rename-row >= 0: LineEdit {
                    text <=> root.modal-title;
                    placeholder-text: "Session title";
                    accepted(text) => {
                        if (text != "") {
                            root.session-renamed(root.rename-row, text);
                            root.rename-row = -1;
                        }
                    }
                }

                if root.delete-row >= 0: Text {
                    text: "This removes the session's worktree, branch history in trouve, and its event log. The git branch itself is kept.";
                    color: Theme.c.text-dim;
                    font-size: Theme.fs(12px);
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: "Cancel";
                        clicked => {
                            root.rename-row = -1;
                            root.delete-row = -1;
                        }
                    }
                    if root.rename-row >= 0: Button {
                        text: "Rename";
                        primary: true;
                        clicked => {
                            root.session-renamed(root.rename-row, root.modal-title);
                            root.rename-row = -1;
                        }
                    }
                    if root.delete-row >= 0: Button {
                        text: "Delete";
                        primary: true;
                        clicked => {
                            root.session-deleted(root.delete-row);
                            root.delete-row = -1;
                        }
                    }
                }
            }
        }
    }

    // ---------------- quit confirmation (agents still running) ----------------
    if root.quit-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.c.scrim;
        TouchArea { } // swallow clicks behind the modal

        Rectangle {
            width: 440px;
            height: quit-layout.preferred-height + 32px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.c.raised-bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.c.border;

            quit-layout := VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: root.agents-running == 1
                        ? "An agent is still running"
                        : root.agents-running + " agents are still running";
                    color: Theme.c.text-hi;
                    font-size: Theme.fs(15px);
                    font-weight: 700;
                    wrap: word-wrap;
                }
                Text {
                    text: "Quitting now stops the running work mid-turn. You can also let the agents finish and quit automatically.";
                    color: Theme.c.text-dim;
                    font-size: Theme.fs(12px);
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: "Cancel";
                        clicked => { root.quit-dialog = false; }
                    }
                    Button {
                        text: "Quit when agents finish";
                        clicked => {
                            root.quit-dialog = false;
                            root.quit-when-idle();
                        }
                    }
                    Button {
                        text: "Quit";
                        primary: true;
                        clicked => { root.quit-now(); }
                    }
                }
            }
        }
    }

    // ---------------- tooltip overlay ----------------
    // Armed by icon buttons (hover/focus); shows after a short delay,
    // clamped to the window.
    Timer {
        interval: 350ms;
        running: Tip.armed && !Tip.shown;
        triggered => { Tip.shown = true; }
    }
    if Tip.shown && Tip.text != "": Rectangle {
        x: clamp(Tip.tip-x, 4px, root.width - self.width - 4px);
        y: clamp(Tip.tip-y, 4px, root.height - self.height - 4px);
        width: tip-label.preferred-width + 12px;
        height: tip-label.preferred-height + 8px;
        background: Theme.c.hover-bg;
        border-radius: 4px;
        border-width: 1px;
        border-color: Theme.c.border-strong;
        tip-label := Text {
            x: 6px;
            y: 4px;
            text: Tip.text;
            color: Theme.c.text;
            font-size: Theme.fs(11px);
        }
    }
}
