export struct MediaFrame {
    image: image,
    delay-ms: int,
}

// Plain presentation data. `kind`: 0 image, 1 GIF, 2 video, 3 other file.
export struct MediaItem {
    key: string,
    name: string,
    meta: string,
    kind: int,
    thumbnail: image,
    frames: [MediaFrame],
    loading: bool,
    failed: bool,
}

export component AttachmentTile inherits Rectangle {
    in property <MediaItem> item;
    in property <bool> removable: false;
    in property <color> background-color: #252a33;
    in property <color> foreground: #f0f3f8;
    in property <color> secondary: #a8b0bf;
    in property <color> hover-color: #343b48;
    callback activated(string);
    callback removed();

    width: item.kind <= 2 ? 116px : 220px;
    height: 96px;
    background: tile-touch.has-hover ? root.hover-color : root.background-color;
    border-width: 1px;
    border-color: #465166;
    border-radius: 7px;
    clip: true;

    tile-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            if (root.item.kind <= 2) {
                root.activated(root.item.key);
            }
        }
    }

    if root.item.kind == 0 || root.item.kind == 1: Image {
        x: 4px;
        y: 4px;
        width: parent.width - 8px;
        height: 56px;
        source: root.item.thumbnail;
        image-fit: contain;
    }

    if (root.item.kind == 0 || root.item.kind == 1) && root.item.loading: Text {
        x: 4px;
        y: 4px;
        width: parent.width - 8px;
        height: 56px;
        text: "Loading…";
        color: root.secondary;
        font-size: 10px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if (root.item.kind == 0 || root.item.kind == 1) && root.item.failed: Text {
        x: 4px;
        y: 4px;
        width: parent.width - 8px;
        height: 56px;
        text: "Preview unavailable";
        color: root.secondary;
        font-size: 9px;
        horizontal-alignment: center;
        vertical-alignment: center;
        wrap: word-wrap;
    }

    if root.item.kind == 1: Rectangle {
        x: 7px;
        y: 7px;
        width: 26px;
        height: 15px;
        background: #111111cc;
        border-radius: 3px;
        Text {
            text: "GIF";
            color: #ffffff;
            font-size: 8px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if root.item.kind == 2: Rectangle {
        x: 4px;
        y: 4px;
        width: parent.width - 8px;
        height: 56px;
        background: #151923;
        border-radius: 5px;
        Text {
            text: "▶";
            color: root.foreground;
            font-size: 25px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if root.item.kind <= 2: Text {
        x: 7px;
        y: 61px;
        width: parent.width - 14px;
        height: 15px;
        text: root.item.name;
        color: root.foreground;
        font-size: 10px;
        overflow: elide;
        vertical-alignment: center;
    }

    if root.item.kind <= 2: Text {
        x: 7px;
        y: 77px;
        width: parent.width - 14px;
        height: 13px;
        text: root.item.meta;
        color: root.secondary;
        font-size: 8px;
        overflow: elide;
        vertical-alignment: center;
    }

    if root.item.kind == 3: HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 9px;
        Text {
            text: "📄";
            color: root.foreground;
            font-size: 22px;
            vertical-alignment: center;
        }
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: root.item.name;
                color: root.foreground;
                font-size: 11px;
                overflow: elide;
            }
            Text {
                text: root.item.meta;
                color: root.secondary;
                font-size: 9px;
                overflow: elide;
            }
        }
    }

    if root.removable: Rectangle {
        x: parent.width - 23px;
        y: 4px;
        width: 19px;
        height: 19px;
        background: remove-touch.has-hover ? #5a2630ee : #141821dd;
        border-radius: 9.5px;
        remove-touch := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.removed(); }
        }
        Text {
            text: "✕";
            color: #ffffff;
            font-size: 10px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

export component MediaLightbox inherits Rectangle {
    in property <[MediaItem]> items;
    in-out property <int> selected-index: 0;
    in property <bool> reduce-motion: false;
    in property <color> panel-color: #151923;
    in property <color> foreground: #f4f6fa;
    in property <color> secondary: #a8b0bf;
    callback close();

    private property <int> frame-index: 0;
    private property <bool> valid: root.selected-index >= 0
        && root.selected-index < root.items.length
        && root.items[root.selected-index].frames.length > 0;

    function move(delta: int) {
        if (root.items.length > 1) {
            root.selected-index = Math.mod(
                root.selected-index + delta + root.items.length,
                root.items.length);
            root.frame-index = 0;
        }
    }

    changed visible => {
        if (root.visible) {
            root.frame-index = 0;
            keys.focus();
        }
    }
    init => { keys.focus(); }
    changed selected-index => { root.frame-index = 0; }

    background: #000000dd;

    TouchArea { clicked => { root.close(); } }

    keys := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.close();
                return accept;
            }
            if (event.text == Key.LeftArrow) {
                root.move(-1);
                return accept;
            }
            if (event.text == Key.RightArrow) {
                root.move(1);
                return accept;
            }
            return reject;
        }
    }

    Timer {
        running: root.visible && root.valid && !root.reduce-motion
            && root.items[root.selected-index].frames.length > 1;
        interval: root.valid
            ? max(20, root.items[root.selected-index].frames[root.frame-index].delay-ms) * 1ms
            : 100ms;
        triggered => {
            if (root.valid) {
                root.frame-index = Math.mod(
                    root.frame-index + 1,
                    root.items[root.selected-index].frames.length);
            }
        }
    }

    panel := Rectangle {
        x: 40px;
        y: 32px;
        width: parent.width - 80px;
        height: parent.height - 64px;
        background: root.panel-color;
        border-radius: 9px;
        border-width: 1px;
        border-color: #566178;

        // Keep clicks on the image/panel from falling through to the
        // backdrop's close action.
        TouchArea { clicked => { } }

        if root.valid: Image {
            x: 54px;
            y: 42px;
            width: parent.width - 108px;
            height: parent.height - 96px;
            source: root.items[root.selected-index].frames[root.frame-index].image;
            image-fit: contain;
        }

        if root.items.length > 1: Rectangle {
            x: 10px;
            y: (parent.height - 42px) / 2;
            width: 38px;
            height: 42px;
            background: prev-touch.has-hover ? #414a5c : #2b313d;
            border-radius: 6px;
            prev-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.move(-1); }
            }
            Text { text: "‹"; color: root.foreground; font-size: 28px; horizontal-alignment: center; vertical-alignment: center; }
        }

        if root.items.length > 1: Rectangle {
            x: parent.width - 48px;
            y: (parent.height - 42px) / 2;
            width: 38px;
            height: 42px;
            background: next-touch.has-hover ? #414a5c : #2b313d;
            border-radius: 6px;
            next-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.move(1); }
            }
            Text { text: "›"; color: root.foreground; font-size: 28px; horizontal-alignment: center; vertical-alignment: center; }
        }

        Text {
            x: 16px;
            y: parent.height - 35px;
            width: parent.width - 120px;
            height: 24px;
            text: root.selected-index >= 0 && root.selected-index < root.items.length
                ? root.items[root.selected-index].name : "";
            color: root.foreground;
            font-size: 12px;
            overflow: elide;
            vertical-alignment: center;
        }
        Text {
            x: parent.width - 100px;
            y: parent.height - 35px;
            width: 55px;
            height: 24px;
            text: root.items.length > 0 ? (root.selected-index + 1) + " of " + root.items.length : "";
            color: root.secondary;
            font-size: 11px;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
        Rectangle {
            x: parent.width - 38px;
            y: 8px;
            width: 30px;
            height: 30px;
            background: close-touch.has-hover ? #5a2630 : #2b313d;
            border-radius: 6px;
            close-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.close(); }
            }
            Text { text: "✕"; color: root.foreground; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
}
