import { MediaItem, MediaLightbox } from "media-view.slint";

export { MediaItem }

export component MediaViewWindow inherits Window {
    preferred-width: 900px;
    preferred-height: 640px;
    title: "slint-media-view";

    in property <[MediaItem]> items;

    MediaLightbox {
        width: 100%;
        height: 100%;
        items: root.items;
        close => { root.hide(); }
    }
}
