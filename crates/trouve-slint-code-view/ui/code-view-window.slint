// Window wrapper for direct instantiation from Rust (and the demo).
// Embedders using their own scene import CodeView from code-view.slint
// instead (add this crate's ui/ dir to the slint include paths).

import { CodeView, TextSegment } from "code-view.slint";

export { TextSegment }

export component CodeViewWindow inherits Window {
    preferred-width: 900px;
    preferred-height: 640px;
    title: "trouve-slint-code-view";

    in property <[[TextSegment]]> lines <=> view.lines;
    in property <[int]> line-numbers <=> view.line-numbers;
    in property <length> code-font-size <=> view.code-font-size;
    in property <length> char-width <=> view.char-width;
    in property <color> foreground <=> view.foreground;

    out property <int> sel-start-line: view.sel-start-line;
    out property <int> sel-start-col: view.sel-start-col;
    out property <int> sel-end-line: view.sel-end-line;
    out property <int> sel-end-col: view.sel-end-col;
    out property <bool> has-selection: view.has-selection;

    callback copy-requested <=> view.copy-requested;

    view := CodeView {
        width: 100%;
        height: 100%;
    }
}
