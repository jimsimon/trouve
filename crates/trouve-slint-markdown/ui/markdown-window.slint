// Window wrapper for direct instantiation from Rust (and the demo).

import { MarkdownView, MarkdownBlock, MarkdownTableCell } from "markdown-view.slint";

export { MarkdownBlock, MarkdownTableCell }

export component MarkdownWindow inherits Window {
    preferred-width: 720px;
    preferred-height: 640px;
    title: "trouve-slint-markdown";
    background: #1e1e1e;

    in property <[MarkdownBlock]> blocks <=> view.blocks;

    view := MarkdownView {
        width: 100%;
        height: 100%;
    }
}
