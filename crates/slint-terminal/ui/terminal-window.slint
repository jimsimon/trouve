// Window wrapper for direct instantiation from Rust (and the demo).

import { TerminalView, TermSegment } from "terminal-view.slint";

export { TermSegment }

export component TerminalWindow inherits Window {
    preferred-width: 900px;
    preferred-height: 560px;
    title: "slint-terminal";

    in property <[[TermSegment]]> lines <=> view.lines;

    public function scroll-to-end() {
        view.scroll-to-end();
    }

    view := TerminalView {
        width: 100%;
        height: 100%;
    }
}
